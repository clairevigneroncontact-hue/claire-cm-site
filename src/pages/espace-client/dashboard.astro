            ${files[0]?.url ? `<div class="w-28 sm:w-40 shrink-0 overflow-hidden" style="background:${color}10;min-height:130px"><img src="${files[0].url}" style="width:100%;height:100%;object-fit:cover;min-height:130px;display:block" onerror="this.style.display='none'" /></div>` : ''}
            <div class="flex-1 p-4">
              <p class="text-base font-semibold text-[#2C2416] mb-2">${clean}</p>
              ${a.description ? `<div class="bg-[#F5EDE4] rounded-xl p-3 border border-[#D6CCC0] mt-2"><p class="text-xs text-[#767A55] uppercase tracking-widest mb-1">Légende</p><p class="text-sm text-[#2C2416]/80 leading-relaxed whitespace-pre-wrap">${a.description}</p></div>` : '<p class="text-xs text-[#2C2416]/30 italic mt-1">Aucune description</p>'}
            </div>
