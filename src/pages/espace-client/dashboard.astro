        document.getElementById('cal-month-grid').innerHTML = months.map((m,i)=>
          `<button onclick="calGoToMonth(${i},event)" class="py-2 text-xs rounded-lg ${i===calMonth?'bg-[#8B3E22] text-white font-bold':'hover:bg-[#8B3E22] hover:text-white text-[#2C2416]'} transition-colors font-medium">${m.slice(0,3)}</button>`
        ).join('');
