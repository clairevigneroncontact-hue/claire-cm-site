    document.addEventListener('click', () => document.getElementById('cal-month-picker')?.classList.add('hidden'));

    // ─── Calendrier éditorial ────────────────────────────────────────────────
    const TYPE_COLORS_CAL = { 'POST':'#3B82F6','STORY':'#EC4899','REEL':'#8B5CF6','CARROUSEL':'#10B981','PLANNING':'#F59E0B','AUDIT':'#6B7280' };
    let calYear = new Date().getFullYear();
    let calMonth = new Date().getMonth();
    let calSelectedDate = null;
    let calApproved = [];
    let calNotes = [];

    async function loadCalData() {
      const sb2 = await getSB();
      const [{ data: approved }, { data: notes }] = await Promise.all([
        sb2.from('content_items').select('id,title,description,scheduled_at,updated_at,files').eq('client_id', uid).eq('status','approved'),
        sb2.from('calendar_notes').select('*').eq('client_id', uid),
      ]);
      calApproved = approved || [];
      calNotes    = notes    || [];
      renderCal();
    }

    function renderCal() {
      const months = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
      document.getElementById('cal-month-label').textContent = `${months[calMonth]} ${calYear}`;
      const frEvents = getFrEvents(calYear);
      const firstDay = new Date(calYear, calMonth, 1).getDay(); // 0=dim
      const startOffset = (firstDay === 0 ? 6 : firstDay - 1); // lundi=0
      const daysInMonth = new Date(calYear, calMonth+1, 0).getDate();
      const days = ['Lu','Ma','Me','Je','Ve','Sa','Di'];

      let html = `<table class="w-full border-collapse table-fixed"><thead><tr>`;
      days.forEach(d => { html += `<th class="py-2 text-center text-[#767A55] font-semibold text-xs uppercase tracking-wide">${d}</th>`; });
      html += `</tr></thead><tbody><tr>`;

      let col = 0;
      for (let i = 0; i < startOffset; i++) { html += `<td class="border border-[#D6CCC0]/30 p-1 bg-[#F5EDE4]/30" style="height:110px"></td>`; col++; }

      for (let day = 1; day <= daysInMonth; day++) {
        const dateStr = `${calYear}-${String(calMonth+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
        const isToday = dateStr === new Date().toISOString().slice(0,10);
        const dayApproved = calApproved.filter(a => (a.scheduled_at||a.updated_at||'').slice(0,10) === dateStr);
        const dayNotes    = calNotes.filter(n => n.date === dateStr);

        let cellContent = '';
        dayApproved.forEach(a => {
          const tMatch = a.title.match(/^\[([A-Z\s\-]+)\]/i);
          const tType  = tMatch ? tMatch[1].toUpperCase() : '';
          const color  = TYPE_COLORS_CAL[tType] || '#8B3E22';
          const clean  = a.title.replace(/^\[[^\]]+\]\s*/,'').slice(0,18);
          const heure  = a.scheduled_at ? ' ' + new Date(a.scheduled_at).toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'}) : '';
          const newBadge = _calNewItems.has(a.id) ? '<span style="background:#F59E0B;color:white;font-size:7px;font-weight:800;padding:0 3px;border-radius:3px;margin-right:3px;vertical-align:middle">NEW</span>' : '';
          cellContent += `<div style="background:${color}15;color:${color};border-left:2px solid ${color};font-size:14px;font-weight:600;line-height:1.4;padding:2px 4px;border-radius:0 4px 4px 0;margin-bottom:2px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis">${newBadge}${clean}${heure}</div>`;
        });
        dayNotes.forEach(n => {
          cellContent += `<div class="text-[12px] leading-tight px-1 py-0.5 rounded bg-[#EDE6DB] text-[#767A55] mb-0.5 truncate italic">${n.note.slice(0,22)}</div>`;
        });
        const hasDot = (dayNotes.length || dayApproved.length) ? `<span class="w-1 h-1 rounded-full bg-[#8B3E22] inline-block ml-0.5 mb-0.5 shrink-0"></span>` : '';

        const dayFrEv = (frEvents[dateStr] || []);
        const evHtml = dayFrEv.map(e => `<div style="font-size:12px;color:#8B3E22;line-height:1.4;padding:0 4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-weight:500">${e}</div>`).join('');

        html += `<td class="border border-[#D6CCC0]/30 p-1 align-top cursor-pointer hover:bg-[#F5EDE4] transition-colors ${dayFrEv.length ? 'bg-[#FFF8F5]' : ''}"
          style="height:110px"
          onclick="calCellClick('${dateStr}')"
          ondblclick="calDayDetail('${dateStr}')">
          <div class="flex items-center justify-center gap-0.5 mb-1">
            <span class="${isToday ? 'w-6 h-6 bg-[#8B3E22] text-white rounded-full inline-flex items-center justify-center' : ''}" style="font-size:13px;font-weight:${isToday?'700':'500'};color:${isToday?'white':'#2C2416'}">${day}</span>${hasDot}
          </div>
          ${cellContent}${evHtml}
        </td>`;
        col++;
        if (col % 7 === 0 && day < daysInMonth) html += `</tr><tr>`;
      }
      const remaining = 7 - (col % 7);
      if (remaining < 7) for (let i = 0; i < remaining; i++) html += `<td class="border border-[#D6CCC0]/30 p-1 h-16 bg-[#F5EDE4]/30"></td>`;
      html += `</tr></tbody></table>`;
      document.getElementById('cal-grid').innerHTML = html;
    }

