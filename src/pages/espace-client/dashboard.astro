    window.calClickDay = (dateStr, day) => {
      calSelectedDate = dateStr;
      const months = ['jan','fév','mar','avr','mai','juin','juil','août','sep','oct','nov','déc'];
      const [y,m,d] = dateStr.split('-');
      document.getElementById('cal-note-date-label').textContent = `Note du ${parseInt(d)} ${months[parseInt(m)-1]} ${y}`;
      const existing = calNotes.find(n => n.date === dateStr);
      document.getElementById('cal-note-input').value = existing?.note || '';
      document.getElementById('cal-note-modal').classList.remove('hidden');
      document.getElementById('cal-note-modal').scrollIntoView({ behavior:'smooth', block:'nearest' });
    };

    window.saveCalNote = async () => {
      const sb2 = await getSB();
      const note = document.getElementById('cal-note-input').value.trim();
      const date = document.getElementById('cal-note-date-picker').value || calSelectedDate;
      if (!note || !date) return;
      const existing = calNotes.find(n => n.date === date);
      if (existing) {
        await sb2.from('calendar_notes').update({ note }).eq('id', existing.id);
      } else {
        await sb2.from('calendar_notes').insert({ date, note, client_id: uid, created_by: uid });
      }
      document.getElementById('cal-note-modal').classList.add('hidden');
      await loadCalData();
    };

    loadClientNotes();
    loadTasks();
    loadCalData();

    // Entrée = envoyer une note, Maj+Entrée = nouvelle ligne
    const noteTa = document.getElementById('new-note-ta');
    if (noteTa) {
      noteTa.onkeydown = (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          window.addClientNote();
        }
      };
    }

    // Lancer le tutoriel si première connexion
    initTutorial(uid);

    // Naviguer vers une section précise si ?goto= dans l'URL
    const _goto = new URLSearchParams(window.location.search).get('goto');
    if (_goto) {
      const _map = { content: () => window.switchTab('content'),
        docs:     () => window.switchTab('docs'),
        factures: () => { window.switchTab('docs'); setTimeout(() => window.switchDocsTab('factures'), 50); },
        uploads:  () => { window.switchTab('docs'); setTimeout(() => window.switchDocsTab('uploads'), 50); },
        discussion: () => setTimeout(() => window.toggleDiscussion(), 200) };
      if (_map[_goto]) _map[_goto]();
    }
  });
</script>
