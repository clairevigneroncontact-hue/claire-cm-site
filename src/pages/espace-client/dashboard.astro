  const ADMIN_EMAIL  = 'clairevigneron.contact@gmail.com';
  const OFFER_MAP    = { audit: 'Audit Instagram', pack: 'Pack Contenu', mensuel: 'Accompagnement Mensuel' };

  const TUTO_STEPS = [
    {
      icon: 'solar:hand-stars-linear',
      title: 'Bienvenue dans votre espace ! 👋',
      text: 'Ce guide rapide vous présente chaque section en contexte. Cliquez "Suivant" pour commencer la visite.',
      tab: 'home', card: null,
      action: () => window.switchTab('home')
    },
    {
      icon: 'solar:checklist-minimalistic-linear',
      title: 'Mes tâches',
      text: 'Suivez vos actions à faire, ajoutées par Claire ou par vous. Cochez une tâche pour la marquer comme terminée.',
      tab: 'home', card: 'card-tasks',
      action: () => window.switchTab('home')
    },
    {
      icon: 'solar:calendar-linear',
      title: 'Calendrier éditorial',
      text: 'Visualisez toutes vos publications programmées mois par mois. Cliquez sur un jour pour voir le détail. Ajoutez vos notes personnelles via le crayon ✏️.',
      tab: 'home', card: 'card-calendar',
      action: () => window.switchTab('home')
    },
    {
      icon: 'solar:check-square-linear',
      title: 'Contenus à valider',
      text: 'Claire dépose ici vos posts, stories, reels et carrousels. Chaque contenu s\'ouvre pour afficher la légende et les boutons ✓ Valider / ✗ Refuser.',
      tab: 'content', card: 'card-content',
      action: () => window.switchTab('content')
    },
    {
      icon: 'solar:document-text-linear',
      title: 'Mes documents',
      text: 'Retrouvez vos contrats, factures et audits envoyés par Claire, organisés par type dans 3 sous-onglets : Documents, Factures, Fichiers déposés.',
      tab: 'docs', card: 'card-docs',
      action: () => { window.switchTab('docs'); window.switchDocsTab?.('docs'); }
    },
    {
      icon: 'solar:upload-linear',
      title: 'Déposer des fichiers',
      text: 'Partagez vos photos, vidéos ou documents avec Claire depuis l\'onglet "Fichiers déposés". Elle les utilisera pour créer vos contenus Instagram.',
      tab: 'docs', card: 'card-upload',
      action: () => { window.switchTab('docs'); setTimeout(() => window.switchDocsTab?.('uploads'), 50); }
    },
    {
      icon: 'mdi:instagram',
      title: 'Mes stats Instagram',
      text: 'Connectez votre compte Instagram Pro pour voir vos abonnés, publications, taux d\'engagement et vos 9 derniers posts en un coup d\'œil.',
      tab: 'stats', card: null,
      action: () => window.switchTab('stats')
    },
    {
      icon: 'solar:chat-round-dots-linear',
      title: 'Discussion avec Claire',
      text: 'La bulle en bas à droite vous connecte directement à Claire. Vos messages sont instantanés. Cliquez en dehors pour refermer.',
      tab: 'home', card: null,
      action: () => {
        window.switchTab('home');
        setTimeout(() => {
          const widget = document.getElementById('discussion-widget');
          if (widget) widget.style.zIndex = '95';
          const panel = document.getElementById('discussion-panel');
          if (panel && panel.classList.contains('hidden')) window.toggleDiscussion();
        }, 200);
      }
    },
  ];

  // ─── Navigation par onglets ──────────────────────────────────────────────
  window.switchTab = (tab) => {
    ['home','docs','content','infos','stats'].forEach(t => {
      document.getElementById('tab-' + t + '-panel')?.classList.toggle('hidden', t !== tab);
      const btn = document.getElementById('tab-btn-' + t);
      if (btn) {
        btn.classList.toggle('bg-white', t === tab);
        btn.classList.toggle('shadow-sm', t === tab);
        btn.classList.toggle('text-[#2C2416]', t === tab);
        btn.classList.toggle('text-[#2C2416]/50', t !== tab);
      }
    });
    if (tab === 'stats') loadClientIgStats();
  };

  window.switchDocsTab = (sub) => {
    ['docs','factures','uploads'].forEach(t => {
      document.getElementById('docs-subtab-' + t)?.classList.toggle('hidden', t !== sub);
      const btn = document.getElementById('docs-sub-btn-' + t);
      if (btn) {
        btn.classList.toggle('bg-white', t === sub);
        btn.classList.toggle('shadow-sm', t === sub);
        btn.classList.toggle('text-[#2C2416]', t === sub);
        btn.classList.toggle('text-[#2C2416]/50', t !== sub);
      }
    });
  };

  // ─── Bulle discussion ────────────────────────────────────────────────────
  window.toggleDiscussion = () => {
    const panel   = document.getElementById('discussion-panel');
    const overlay = document.getElementById('discussion-overlay');
    if (!panel) return;
    const isOpen = !panel.classList.contains('hidden');
    panel.classList.toggle('hidden');
    if (overlay) overlay.classList.toggle('hidden', isOpen);
    if (!isOpen) {
      // Ouvre → clear badge unread
      const badge = document.getElementById('discussion-unread');
      if (badge) { badge.classList.add('hidden'); badge.textContent = ''; }
      localStorage.setItem('discussionLastOpened', new Date().toISOString());
      if (window.loadClientNotes) window.loadClientNotes();
      const ta = document.getElementById('new-note-ta');
      if (ta) setTimeout(() => ta.focus(), 200);
    }
  };

  function loadScript(src) {
    return new Promise(resolve => {
      if (document.querySelector(`script[src="${src}"]`)) return resolve();
      const s = document.createElement('script'); s.src = src; s.onload = resolve; document.head.appendChild(s);
    });
  }
  async function getSB() {
    if (!window._sb) {
      await loadScript('https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.js');
      window._sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
    }
    return window._sb;
  }
  function docItem(d) {
    const label = d.name || d.file_name || 'Document';
    const url   = d.file_url || '#';
    return `<a href="${url}" target="_blank" class="flex items-center gap-2 text-sm text-[#8B3E22] hover:underline py-1.5 border-b border-[#D6CCC0]/30 last:border-0">
      <iconify-icon icon="solar:file-download-linear" stroke-width="1.5" class="shrink-0"></iconify-icon>
      <span>${label}</span>
    </a>`;
  }

  // ─── Tutoriel guidé ──────────────────────────────────────────────────────
  function initTutorial(userId) {
    const key = `tuto_done_${userId}`;
    if (localStorage.getItem(key)) return;

    let step = 0;
    let prevCard = null;

    const tuto    = document.getElementById('tutorial');
    const overlay = document.getElementById('tuto-overlay');
    const dotsEl  = document.getElementById('tuto-dots');
    const iconEl  = document.getElementById('tuto-icon');
    const stepEl  = document.getElementById('tuto-step');
    const titleEl = document.getElementById('tuto-title');
    const textEl  = document.getElementById('tuto-text');
    const prevBtn = document.getElementById('tuto-prev');
    const nextBtn = document.getElementById('tuto-next');
    const skipBtn = document.getElementById('tuto-skip');

    // Générer les dots dynamiquement
    dotsEl.innerHTML = TUTO_STEPS.map(() => '<div class="tuto-dot h-1.5 rounded-full flex-1 transition-all bg-white/20"></div>').join('');

    function clearHighlight() {
      if (prevCard) {
        prevCard.classList.remove('ring-4', 'ring-[#8B3E22]', 'ring-offset-4', 'relative', 'z-50', 'shadow-2xl');
        prevCard.style.transition = '';
        prevCard = null;
      }
      // Refermer la discussion et restaurer son z-index si on quitte cette étape
      const widget = document.getElementById('discussion-widget');
      if (widget && widget.style.zIndex === '95') {
        widget.style.zIndex = '';
        const panel = document.getElementById('discussion-panel');
        if (panel && !panel.classList.contains('hidden')) {
          panel.classList.add('hidden');
          document.getElementById('discussion-overlay')?.classList.add('hidden');
        }
      }
    }

    function highlightCard(cardId) {
      clearHighlight();
      if (!cardId) { window.scrollTo({ top: 0, behavior: 'smooth' }); return; }
      // Chercher dans le DOM après que l'action ait changé l'onglet
      setTimeout(() => {
        const card = document.getElementById(cardId);
        if (!card) return;
        card.classList.add('ring-4', 'ring-[#8B3E22]', 'ring-offset-4', 'relative', 'z-50', 'shadow-2xl');
        card.style.transition = 'all 0.35s ease';
        setTimeout(() => {
          const top = window.scrollY + card.getBoundingClientRect().top - 140;
          window.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
        }, 80);
        prevCard = card;
      }, cardId === 'card-upload' || cardId === 'card-docs' ? 120 : 60);
    }

    function render() {
      const s = TUTO_STEPS[step];
      // Dots
      dotsEl.querySelectorAll('.tuto-dot').forEach((d, i) => {
        d.className = `tuto-dot h-1.5 rounded-full flex-1 transition-all ${i < step ? 'bg-white/40' : i === step ? 'bg-[#8B3E22]' : 'bg-white/20'}`;
      });
      iconEl.setAttribute('icon', s.icon);
      stepEl.textContent  = `Étape ${step + 1} sur ${TUTO_STEPS.length}`;
      titleEl.textContent = s.title;
      textEl.textContent  = s.text;
      prevBtn.classList.toggle('hidden', step === 0);
      nextBtn.textContent = step === TUTO_STEPS.length - 1 ? '✓ C\'est parti !' : 'Suivant →';
      // Naviguer vers la bonne section + highlight
      if (s.action) s.action();
      highlightCard(s.card);
    }

    function close() {
      localStorage.setItem(key, '1');
      clearHighlight();
      tuto.classList.add('hidden');
      overlay.classList.add('hidden');
    }

    tuto.classList.remove('hidden');
    overlay.classList.remove('hidden');
    render();

    prevBtn.onclick = () => { if (step > 0) { step--; render(); } };
    nextBtn.onclick = () => { if (step < TUTO_STEPS.length - 1) { step++; render(); } else close(); };
    skipBtn.onclick = close;
  }

  // ─── Chargement principal ────────────────────────────────────────────────
  window.addEventListener('load', async () => {
    const sb = await getSB();
    const { data: { session } } = await sb.auth.getSession();
    if (!session) { window.location.href = '/espace-client'; return; }
    if (session.user.email === ADMIN_EMAIL) { window.location.href = '/espace-client/admin'; return; }

    document.getElementById('loading').classList.add('hidden');
    document.getElementById('dashboard').classList.remove('hidden');
    document.getElementById('discussion-widget')?.classList.remove('hidden');

    const uid = session.user.id;
    document.getElementById('logout-btn').onclick = async () => { await sb.auth.signOut(); window.location.href = '/espace-client'; };

    // Retour OAuth Instagram
    const _igQ = new URLSearchParams(window.location.search);
    if (_igQ.get('ig_connected') === '1') {
      history.replaceState({}, '', window.location.pathname);
      setTimeout(() => window.switchTab('stats'), 300);
    }

    window.loadClientIgStats = async () => {
      const container = document.getElementById('client-ig-stats-container');
      if (!container) return;
      container.innerHTML = '<div class="text-center py-8"><div class="w-6 h-6 border-2 border-[#8B3E22] border-t-transparent rounded-full animate-spin mx-auto mb-3"></div><p class="text-sm text-[#767A55]">Chargement…</p></div>';
      try {
        const res  = await fetch(`/api/instagram-stats?clientId=${uid}`);
        const data = await res.json();
        if (data.error === 'no_token' || data.error === 'token_invalid' || data.error === 'clientId requis') {
          container.innerHTML = `<div class="bg-white rounded-2xl p-8 border border-[#D6CCC0] text-center max-w-sm mx-auto">
            <iconify-icon icon="mdi:instagram" class="text-5xl text-[#8B3E22]/30 mb-4 block"></iconify-icon>
            <h3 class="text-sm font-medium text-[#2C2416] mb-2">Connectez votre compte Instagram</h3>
            <p class="text-xs text-[#767A55] mb-6">Reliez votre compte Instagram Pro pour accéder à vos statistiques directement ici.</p>
            <a href="/api/instagram-auth?clientId=${uid}&from=dashboard" class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-[#833ab4] via-[#fd1d1d] to-[#fcb045] text-white rounded-xl text-sm font-medium hover:opacity-90 transition-opacity">
              <iconify-icon icon="mdi:instagram" class="text-lg"></iconify-icon>
              Connecter Instagram
            </a>
          </div>`;
          return;
        }
        const prof  = data.profile || {};
        const media = data.media   || [];
        const totalEng  = media.reduce((s, m) => s + (m.like_count || 0) + (m.comments_count || 0), 0);
        const avgEngage = (media.length && prof.followers_count)
          ? ((totalEng / media.length) / prof.followers_count * 100).toFixed(2)
          : '—';
        container.innerHTML = `
          <div class="bg-white rounded-2xl p-5 border border-[#D6CCC0] mb-4">
            <div class="flex items-center gap-4 mb-4">
              ${prof.profile_picture_url
                ? `<img src="${prof.profile_picture_url}" class="w-14 h-14 rounded-full object-cover border-2 border-[#D6CCC0]" />`
                : `<div class="w-14 h-14 rounded-full bg-gradient-to-br from-[#833ab4] via-[#fd1d1d] to-[#fcb045] flex items-center justify-center"><iconify-icon icon="mdi:instagram" class="text-2xl text-white"></iconify-icon></div>`}
              <div class="flex-1 min-w-0">
                <p class="font-semibold text-[#2C2416]">@${prof.username || '—'}</p>
                ${prof.biography ? `<p class="text-xs text-[#767A55] mt-0.5 line-clamp-2">${prof.biography}</p>` : ''}
              </div>
              <a href="/api/instagram-auth?clientId=${uid}&from=dashboard" class="shrink-0 text-xs px-3 py-1.5 border border-[#D6CCC0] text-[#767A55] rounded-full hover:border-[#8B3E22] hover:text-[#8B3E22] transition-colors">↺ Reconnecter</a>
            </div>
            <div class="grid grid-cols-3 gap-3">
              <div class="text-center bg-[#F5EDE4] rounded-xl p-3">
                <p class="text-xl font-bold text-[#2C2416]">${(prof.followers_count || 0).toLocaleString('fr-FR')}</p>
                <p class="text-[10px] text-[#767A55] uppercase tracking-widest mt-0.5">Abonnés</p>
              </div>
              <div class="text-center bg-[#F5EDE4] rounded-xl p-3">
                <p class="text-xl font-bold text-[#2C2416]">${(prof.media_count || 0).toLocaleString('fr-FR')}</p>
                <p class="text-[10px] text-[#767A55] uppercase tracking-widest mt-0.5">Publications</p>
              </div>
              <div class="text-center bg-[#F5EDE4] rounded-xl p-3">
                <p class="text-xl font-bold text-[#2C2416]">${avgEngage}%</p>
                <p class="text-[10px] text-[#767A55] uppercase tracking-widest mt-0.5">Engagement</p>
              </div>
            </div>
          </div>
          ${media.length ? `<div class="bg-white rounded-2xl p-5 border border-[#D6CCC0]">
            <h3 class="text-sm font-medium text-[#2C2416] mb-3">9 dernières publications</h3>
            <div class="grid grid-cols-3 gap-0.5">
              ${media.map(m => {
                const img = m.media_type === 'VIDEO' ? (m.thumbnail_url || '') : (m.media_url || '');
                return `<a href="${m.permalink || '#'}" target="_blank" class="relative aspect-square overflow-hidden bg-[#EDE6DB] group block">
                  ${img ? `<img src="${img}" class="w-full h-full object-cover" loading="lazy" onerror="this.style.display='none'" />` : ''}
                  <div class="absolute inset-0 bg-black/0 group-hover:bg-black/60 transition-colors flex items-center justify-center">
                    <div class="opacity-0 group-hover:opacity-100 transition-opacity text-white text-xs font-semibold text-center leading-loose px-1">
                      <div>❤️ ${m.like_count || 0} &nbsp; 💬 ${m.comments_count || 0}</div>
                      <div>${m.shares_count != null ? `🔁 ${m.shares_count}` : ''}${m.shares_count != null && m.saved_count != null ? ' &nbsp; ' : ''}${m.saved_count != null ? `🔖 ${m.saved_count}` : ''}</div>
                    </div>
                  </div>
                </a>`;
              }).join('')}
            </div>
          </div>` : ''}`;
      } catch {
        container.innerHTML = `<div class="bg-white rounded-2xl p-8 border border-[#D6CCC0] text-center max-w-sm mx-auto">
          <iconify-icon icon="mdi:instagram" class="text-5xl text-[#8B3E22]/30 mb-4 block"></iconify-icon>
          <h3 class="text-sm font-medium text-[#2C2416] mb-2">Connectez votre compte Instagram</h3>
          <p class="text-xs text-[#767A55] mb-6">Reliez votre compte Instagram Pro pour accéder à vos statistiques.</p>
          <a href="/api/instagram-auth?clientId=${uid}&from=dashboard" class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-[#833ab4] via-[#fd1d1d] to-[#fcb045] text-white rounded-xl text-sm font-medium hover:opacity-90 transition-opacity">
            <iconify-icon icon="mdi:instagram" class="text-lg"></iconify-icon>
            Connecter Instagram
          </a>
        </div>`;
      }
    };

    // Profil
    const { data: p } = await sb.from('profiles').select('*').eq('id', uid).single();
    const meta = session.user.user_metadata || {};
    const fullName = p?.full_name || meta.full_name || meta.name || '';
    const prenom   = fullName ? fullName.split(' ')[0] : (session.user.email || '').split('@')[0];

    document.getElementById('welcome').textContent = `Bonjour, ${prenom} 👋`;

    // Afficher avatar uniquement dans le bloc de bienvenue (le header garde l'icône paramètres)
    if (p?.avatar_url) {
      const ts = '?t=' + Date.now();
      const dImg  = document.getElementById('dash-avatar-img');
      const dIcon = document.getElementById('dash-avatar-icon');
      if (dImg && dIcon) { dImg.src = p.avatar_url + ts; dImg.classList.remove('hidden'); dIcon.classList.add('hidden'); }
    }

    // Sauvegarder le nom depuis les métadonnées si manquant
    if (fullName && p && !p.full_name) {
      await sb.from('profiles').update({ full_name: fullName }).eq('id', uid);
    }

    // Notes discussion
    window.loadClientNotes = async function loadClientNotes() {
      const sb2 = await getSB();
      const { data } = await sb2.from('client_notes').select('*').eq('client_id', uid).order('created_at', { ascending: true }).limit(100);
      const feed = document.getElementById('notes-feed');
      if (!feed) return;
      if (!data || !data.length) { feed.innerHTML = '<p class="text-sm text-[#F5EDE4]/30 italic text-center pt-4">Aucun message pour l\'instant</p>'; return; }
      feed.innerHTML = data.map(n => {
        const d   = new Date(n.created_at).toLocaleDateString('fr-FR', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' });
        const txt = n.note.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        if (n.from_admin) {
          // Bulle gauche — Claire
          return `<div class="flex items-end gap-2 pr-10" data-search="${n.note.toLowerCase()}">
            <div class="w-7 h-7 bg-[#8B3E22] rounded-full flex items-center justify-center shrink-0 text-white text-xs font-bold mb-0.5">C</div>
            <div class="bg-white/15 rounded-2xl rounded-bl-sm px-4 py-3 border border-white/10" style="max-width:78%">
              <p class="text-[10px] text-[#8B3E22] font-semibold mb-1">Claire CM</p>
              <p class="text-sm text-[#F5EDE4] leading-relaxed">${txt}</p>
              <p class="text-[10px] text-[#F5EDE4]/40 mt-1.5">${d}</p>
            </div>
          </div>`;
        }
        // Bulle droite — client
        return `<div class="flex justify-end pl-10" data-search="${n.note.toLowerCase()}">
          <div class="bg-[#8B3E22] rounded-2xl rounded-br-sm px-4 py-3" style="max-width:78%">
            <p class="text-sm text-white leading-relaxed">${txt}</p>
            <p class="text-[10px] text-white/50 mt-1.5 text-right">${d}</p>
          </div>
        </div>`;
      }).join('');
      feed.scrollTop = feed.scrollHeight;
      // Badge unread : messages admin non vus quand le panel est fermé
      const lastOpened = localStorage.getItem('discussionLastOpened') || '1970-01-01';
      const panel = document.getElementById('discussion-panel');
      if (panel && panel.classList.contains('hidden')) {
        const unreadAdmin = (data||[]).filter(n => n.from_admin && n.created_at > lastOpened).length;
        const badge = document.getElementById('discussion-unread');
        if (badge) {
          badge.classList.toggle('hidden', unreadAdmin === 0);
          badge.textContent = unreadAdmin > 9 ? '9+' : String(unreadAdmin);
        }
      }
    }
    window.addClientNote = async () => {
      const sb2 = await getSB();
      const ta = document.getElementById('new-note-ta');
      const note = ta.value.trim();
      if (!note) return;
      const { error } = await sb2.from('client_notes').insert({ client_id: uid, note });
      if (!error) {
        ta.value = '';
        const msg = document.getElementById('notes-send-msg');
        msg.classList.remove('hidden'); setTimeout(() => msg.classList.add('hidden'), 2000);
        await loadClientNotes();
      }
    };

    // Tâches
    async function loadTasks() {
      const sb2 = await getSB();
      const { data } = await sb2.from('tasks').select('*').eq('client_id', uid).order('created_at', { ascending: true });
      const el = document.getElementById('tasks-list');
      if (!el) return;
      if (!data || !data.length) { el.innerHTML = '<p class="text-xs text-[#2C2416]/30 italic">Aucune tâche</p>'; return; }
      el.innerHTML = data.map(t => {
        const title = t.title.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        return `<div class="flex items-center gap-3 py-2 border-b border-[#D6CCC0]/30 last:border-0" data-search="${t.title.toLowerCase()}">
          <button onclick="toggleTask('${t.id}',${t.done})" class="w-5 h-5 rounded-full border-2 flex items-center justify-center shrink-0 transition-colors ${t.done ? 'bg-[#8B3E22] border-[#8B3E22]' : 'border-[#D6CCC0] hover:border-[#8B3E22]'}">
            ${t.done ? '<iconify-icon icon="solar:check-linear" stroke-width="2.5" class="text-white" style="font-size:9px"></iconify-icon>' : ''}
          </button>
          <span class="text-sm flex-1 ${t.done ? 'line-through text-[#2C2416]/40' : 'text-[#2C2416]'}">${title}</span>
          <button onclick="deleteTask('${t.id}')" class="text-[#D6CCC0] hover:text-red-400 transition-colors shrink-0">
            <iconify-icon icon="solar:close-circle-linear" stroke-width="1.5" class="text-base"></iconify-icon>
          </button>
        </div>`;
      }).join('');
    }
    window.addTask = async () => {
      const sb2 = await getSB();
      const input = document.getElementById('new-task-input');
      const title = input.value.trim();
      if (!title) return;
      // Si 5 tâches ou plus : supprimer d'abord les cochées pour faire de la place
      const { data: existing } = await sb2.from('tasks').select('id,done').eq('client_id', uid);
      if ((existing||[]).length >= 5) {
        const doneIds = (existing||[]).filter(t => t.done).map(t => t.id);
        if (doneIds.length > 0) await sb2.from('tasks').delete().in('id', doneIds);
      }
      await sb2.from('tasks').insert({ client_id: uid, title });
      input.value = '';
      await loadTasks();
    };
    window.toggleTask = async (id, done) => {
      const sb2 = await getSB();
      await sb2.from('tasks').update({ done: !done }).eq('id', id);
      await loadTasks();
    };
    window.deleteTask = async (id) => {
      const sb2 = await getSB();
      await sb2.from('tasks').delete().eq('id', id);
      await loadTasks();
    };

    if (p) {
      if (p.offer) document.getElementById('offer-badge').textContent = `Offre : ${OFFER_MAP[p.offer] || p.offer}`;
      document.getElementById('infos-content').innerHTML = [
        fullName              ? `<p><span class="font-medium text-[#2C2416]">Nom :</span> ${fullName}</p>` : '',
        (p.email || session.user.email) ? `<p><span class="font-medium text-[#2C2416]">Email :</span> ${p.email || session.user.email}</p>` : '',
        p.phone               ? `<p><span class="font-medium text-[#2C2416]">Téléphone :</span> ${p.phone}</p>` : '',
        p.instagram_handle    ? `<p><span class="font-medium text-[#2C2416]">Instagram :</span> @${p.instagram_handle}</p>` : '',
        p.offer               ? `<p><span class="font-medium text-[#2C2416]">Offre :</span> ${OFFER_MAP[p.offer] || p.offer}</p>` : '',
      ].join('') || '<p class="text-xs text-[#2C2416]/30 italic">À compléter dans les paramètres</p>';
    }

    // Documents + fichiers déposés (fusionnés)
    const [{ data: docs }, { data: clientUploads }] = await Promise.all([
      sb.from('documents').select('*').eq('client_id', uid).order('created_at', { ascending: false }),
      sb.from('client_uploads').select('*').eq('client_id', uid).order('created_at', { ascending: false }),
    ]);
    const TYPE_LABELS = {
      contrat: 'Contrat', facture: 'Facture', post: 'Post',
      reel: 'Reel', carrousel: 'Carrousel', planning: 'Planning éditorial',
      audit: 'Audit Instagram', autre: 'Document',
    };
    const invoices  = (docs||[]).filter(d => d.type === 'facture');
    const contracts = (docs||[]).filter(d => d.type === 'contrat');
    const content   = (docs||[]).filter(d => !['facture','contrat'].includes(d.type));
    const allDocs   = [...contracts, ...content];

    function docItemTyped(d) {
      const label = d.name || d.file_name || 'Document';
      const type  = TYPE_LABELS[d.type] || d.type || '';
      const url   = d.file_url || '#';
      return `<a href="${url}" target="_blank" class="flex items-center justify-between gap-3 text-sm py-2 border-b border-[#D6CCC0]/30 last:border-0 hover:text-[#8B3E22] transition-colors group">
        <div class="flex items-center gap-2 min-w-0">
          <iconify-icon icon="solar:file-download-linear" stroke-width="1.5" class="text-[#8B3E22] shrink-0"></iconify-icon>
          <span class="truncate">${label}</span>
        </div>
        ${type ? `<span class="text-xs text-[#767A55] shrink-0 bg-[#EDE6DB] px-2 py-0.5 rounded-full">${type}</span>` : ''}
      </a>`;
    }

    // docs-list est peuplé par refreshDocsList() défini plus bas

    window.filterDocs = (q) => globalSearch(q);
    window._searchResults = [];

    window.globalSearch = (q) => {
      const term = q.trim().toLowerCase();
      const panel = document.getElementById('search-results-panel');
      if (!panel) return;
      if (!term) { panel.classList.add('hidden'); panel.innerHTML = ''; return; }

      const results = [];

      // Documents
      document.querySelectorAll('#docs-list [data-search]').forEach(el => {
        if (!(el.dataset.search||'').includes(term)) return;
        const label = el.querySelector('span.truncate')?.textContent?.trim() || el.dataset.search.split(' ')[0];
        const badge = el.querySelector('.rounded-full')?.textContent?.trim() || 'Document';
        results.push({ label: label.slice(0,50), section: 'Documents · ' + badge, icon:'solar:document-text-linear', el, tab:'docs', docsSub:'docs' });
      });
      // Factures
      document.querySelectorAll('#invoices-list [data-search]').forEach(el => {
        if (!(el.dataset.search||'').includes(term)) return;
        const label = el.querySelector('span.truncate')?.textContent?.trim() || el.dataset.search.split(' ')[0];
        results.push({ label: label.slice(0,50), section: 'Factures', icon:'solar:bill-linear', el, tab:'docs', docsSub:'factures' });
      });
      // Fichiers déposés
      document.querySelectorAll('#uploads-list [data-search]').forEach(el => {
        if (!(el.dataset.search||'').includes(term)) return;
        const label = el.querySelector('#uname-' + (el.id||''))?.textContent?.trim()
          || el.querySelector('span.truncate, [id^="uname-"]')?.textContent?.trim()
          || el.dataset.search.split(' ')[0];
        results.push({ label: label.slice(0,50), section: 'Fichiers déposés', icon:'solar:upload-linear', el, tab:'docs', docsSub:'uploads' });
      });

      // Contenus à valider (full list)
      document.querySelectorAll('#content-list [data-search]').forEach(el => {
        if (!(el.dataset.search||'').includes(term)) return;
        const title = el.querySelector('p.font-medium')?.textContent?.trim() || el.dataset.search.slice(0,40);
        const badge = el.querySelector('.rounded-full')?.textContent?.trim() || '';
        const detailEl = el.querySelector('[id^="dash-detail-"]');
        const itemId = detailEl?.id?.replace('dash-detail-','');
        results.push({ label: title.slice(0,50), section: 'Contenus' + (badge ? ' · ' + badge : ''), icon:'solar:check-square-linear', el, itemId, tab:'content' });
      });

      // Tâches
      document.querySelectorAll('#tasks-list [data-search]').forEach(el => {
        if (!(el.dataset.search||'').includes(term)) return;
        const text = el.querySelector('span.flex-1')?.textContent?.trim() || el.dataset.search;
        const done = el.querySelector('span.flex-1')?.classList.contains('line-through');
        results.push({ label: text.slice(0,50), section: 'Tâche' + (done ? ' · Terminée' : ''), icon:'solar:checklist-minimalistic-linear', el, tab:'home' });
      });

      // Discussion (notes)
      document.querySelectorAll('#notes-feed [data-search]').forEach(el => {
        if (!(el.dataset.search||'').includes(term)) return;
        const text = el.querySelector('p.text-sm')?.textContent?.trim() || el.dataset.search;
        const fromAdmin = el.dataset.search === el.dataset.search && el.querySelector('.text-\\[\\#8B3E22\\]');
        results.push({ label: text.slice(0,50), section: 'Discussion', icon:'solar:chat-round-dots-linear', el, openDiscussion: true });
      });

      window._searchResults = results;

      if (!results.length) {
        panel.innerHTML = '<p class="text-sm text-[#2C2416]/40 italic p-4 text-center">Aucun résultat</p>';
      } else {
        panel.innerHTML = results.map((r, i) => `
          <div onclick="window.searchGoTo(${i})"
            class="flex items-center gap-3 px-4 py-3 cursor-pointer hover:bg-[#F5EDE4] transition-colors border-b border-[#D6CCC0]/30 last:border-0">
            <iconify-icon icon="${r.icon}" stroke-width="1.5" class="text-[#8B3E22] text-lg shrink-0"></iconify-icon>
            <div class="min-w-0 flex-1">
              <p class="text-sm text-[#2C2416] truncate font-medium">${r.label}</p>
              <p class="text-xs text-[#767A55]">${r.section}</p>
            </div>
            <iconify-icon icon="solar:arrow-right-linear" stroke-width="1.5" class="text-[#D6CCC0] shrink-0"></iconify-icon>
          </div>`).join('');
      }
      panel.classList.remove('hidden');
    };

    window.searchGoTo = (i) => {
      const r = window._searchResults?.[i];
      if (!r) return;
      document.getElementById('search-results-panel').classList.add('hidden');
      document.getElementById('doc-search-input').value = '';

      // Ouvrir le bon onglet d'abord
      if (r.tab) window.switchTab(r.tab);
      // Ouvrir le sous-onglet docs si besoin
      if (r.docsSub) setTimeout(() => window.switchDocsTab?.(r.docsSub), 50);
      // Ouvrir la discussion si besoin
      if (r.openDiscussion) window.toggleDiscussion?.();

      const delay = (r.tab || r.openDiscussion) ? 200 : 0;
      setTimeout(() => {
        if (!r.el) return;
        // Ouvrir le <details> parent si fermé
        const details = r.el.closest('details');
        if (details) details.open = true;
        // Scroll + highlight
        r.el.scrollIntoView({ behavior: 'smooth', block: 'center' });
        r.el.style.transition = 'box-shadow 0.3s';
        r.el.style.boxShadow = '0 0 0 3px #8B3E2240';
        setTimeout(() => { r.el.style.boxShadow = ''; }, 2000);
        // Ouvrir le détail du contenu si applicable
        if (r.itemId) setTimeout(() => window.toggleDashContent(r.itemId), 300);
      }, delay);
    };

    // Fermer le panel en cliquant ailleurs
    document.addEventListener('click', (e) => {
      const inp = document.getElementById('doc-search-input');
      const panel = document.getElementById('search-results-panel');
      if (inp && panel && !inp.contains(e.target) && !panel.contains(e.target))
        panel.classList.add('hidden');
    }, true);

    // Contenu (tous statuts)
    const { data: allItems } = await sb.from('content_items').select('*').eq('client_id', uid).order('created_at', { ascending: false });
    const pending  = (allItems||[]).filter(i => i.status === 'pending');
    const done     = (allItems||[]).filter(i => i.status !== 'pending');
    const contentEl = document.getElementById('content-list');

    const TYPE_COLORS_DASH = { 'POST':'bg-blue-100 text-blue-700', 'STORY':'bg-pink-100 text-pink-700', 'REEL':'bg-purple-100 text-purple-700', 'CARROUSEL':'bg-emerald-100 text-emerald-700', 'PLANNING':'bg-orange-100 text-orange-700', 'AUDIT':'bg-gray-100 text-gray-500' };
    function renderContentCard(item, statusBadge) {
      let files = [];
      try { files = Array.isArray(item.files) ? item.files : (item.files ? JSON.parse(item.files) : []); } catch(e) {}
      const f0 = files[0];
      const isImg = f0?.url && /\.(jpg|jpeg|png|gif|webp|svg)(\?|$)/i.test(f0.url);
      const tMatch = item.title.match(/^\[([A-Z\s\-]+)\]/i);
      const tType  = tMatch ? tMatch[1].toUpperCase() : '';
      const cleanT = item.title.replace(/^\[[^\]]+\]\s*/, '') || item.title;
      const tColor = TYPE_COLORS_DASH[tType] || 'bg-[#8B3E22]/10 text-[#8B3E22]';
      const typeTag = tType ? `<span class="text-[10px] font-bold px-2 py-0.5 rounded-full ${tColor} uppercase tracking-wide shrink-0">${tType}</span>` : '';
      const isPending = item.status === 'pending';
      return `
      <div class="border border-[#D6CCC0] rounded-xl overflow-hidden mb-3 last:mb-0" data-search="${(item.title + ' ' + (item.description||'')).toLowerCase().replace(/"/g,'').replace(/\[.*?\]/g,'').trim()}">
        <div class="flex items-center justify-between gap-2 p-3 cursor-pointer hover:bg-[#F5EDE4]/50 transition-colors" onclick="toggleDashContent('${item.id}')">
          <div class="flex items-center gap-2 min-w-0">
            ${f0?.url
              ? `<div class="w-9 h-9 rounded-lg shrink-0 overflow-hidden bg-[#8B3E22]/10 flex items-center justify-center">
                   <img src="${f0.url}" class="w-full h-full object-cover" onerror="this.style.display='none'" />
                 </div>`
              : `<div class="w-9 h-9 bg-[#8B3E22]/10 rounded-lg flex items-center justify-center shrink-0"><iconify-icon icon="solar:image-linear" stroke-width="1.5" class="text-[#8B3E22] text-sm"></iconify-icon></div>`
            }
            <div class="min-w-0">
              ${typeTag ? `<div class="mb-0.5">${typeTag}</div>` : ''}
              <p class="font-medium text-[#2C2416] text-sm truncate leading-tight">${cleanT}</p>
            </div>
          </div>
          <div class="flex items-center gap-1 shrink-0">
            ${f0?.url ? `<a href="${f0.url}" target="_blank" onclick="event.stopPropagation()" class="p-1.5 text-[#8B3E22] hover:bg-[#8B3E22]/10 rounded-lg transition-colors" title="Voir"><iconify-icon icon="solar:eye-linear" stroke-width="1.5" class="text-base"></iconify-icon></a>` : ''}
            ${statusBadge}
            <iconify-icon id="dash-chev-${item.id}" icon="solar:alt-arrow-down-linear" stroke-width="1.5" class="text-[#767A55] transition-transform ml-1 ${isPending ? 'rotate-180' : ''}"></iconify-icon>
          </div>
        </div>
        <div id="dash-detail-${item.id}" class="${isPending ? '' : 'hidden'} border-t border-[#D6CCC0]/50 p-3">
          ${f0?.url && !isImg ? `<a href="${f0.url}" target="_blank" class="flex items-center gap-3 p-3 bg-[#EDE6DB] rounded-xl hover:bg-[#D6CCC0] transition-colors mb-3"><iconify-icon icon="solar:file-download-linear" stroke-width="1.5" class="text-[#8B3E22] text-2xl shrink-0"></iconify-icon><span class="text-sm text-[#2C2416] truncate">${f0.name||'Ouvrir'}</span></a>` : ''}
          ${item.description ? `<div class="bg-[#F5EDE4] rounded-xl p-3 mb-3 border border-[#D6CCC0]"><p class="text-xs text-[#767A55] uppercase tracking-widest mb-1">Légende</p><p class="text-sm text-[#2C2416]/75 leading-relaxed whitespace-pre-wrap">${item.description}</p></div>` : ''}
          ${isPending ? `
          <div class="mt-2">
            <div class="relative mb-3"><textarea spellcheck="true" id="approve-text-${item.id}" placeholder="Commentaire optionnel…" rows="2" class="w-full px-3 py-2 rounded-xl border border-[#D6CCC0] bg-[#F5EDE4]/50 text-sm focus:outline-none focus:border-[#8B3E22] focus:bg-white resize-none transition-colors"></textarea><button data-emoji-btn type="button" onclick="toggleEmojiPicker(this,'approve-text-${item.id}')" class="absolute bottom-1.5 right-1.5 text-base p-1 rounded-lg hover:bg-[#EDE6DB] text-[#767A55]" title="Emoji">😊</button></div>
            <div class="flex gap-2 flex-wrap">
              <button onclick="validateWithNote('${item.id}')" class="px-3 py-1.5 bg-green-600 text-white text-xs rounded-lg hover:bg-green-700">✓ Valider</button>
              <button onclick="showFeedback('${item.id}')" class="px-3 py-1.5 bg-red-500 text-white text-xs rounded-lg hover:bg-red-600">✗ Refuser</button>
            </div>
          </div>
          <div id="feedback-${item.id}" class="hidden mt-3">
            <p class="text-xs text-[#767A55] mb-1">Motif du refus :</p>
            <div class="relative mb-2"><textarea spellcheck="true" id="feedback-text-${item.id}" placeholder="Expliquez ce que vous souhaitez modifier…" rows="2" class="w-full px-3 py-2 rounded-xl border border-[#D6CCC0] text-sm focus:outline-none focus:border-red-400 resize-none"></textarea><button data-emoji-btn type="button" onclick="toggleEmojiPicker(this,'feedback-text-${item.id}')" class="absolute bottom-1.5 right-1.5 text-base p-1 rounded-lg hover:bg-[#EDE6DB] text-[#767A55]" title="Emoji">😊</button></div>
            <button onclick="validateWithFeedback('${item.id}')" class="px-3 py-1.5 bg-red-500 text-white text-xs rounded-lg hover:bg-red-600">Envoyer le refus</button>
          </div>` : `
          <div class="mt-1">
            ${item.feedback ? `<div class="bg-[#F5EDE4] rounded-xl p-3 mb-2 border border-[#D6CCC0]"><p class="text-xs text-[#767A55] uppercase tracking-widest mb-1">Commentaire</p><p class="text-sm text-[#2C2416]/70 leading-relaxed whitespace-pre-wrap">${item.feedback.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</p></div>` : ''}
            <button onclick="toggleEditComment('${item.id}')" class="text-[10px] text-[#767A55] hover:text-[#8B3E22] transition-colors hover:underline underline-offset-2">${item.feedback ? '✏️ Modifier le commentaire' : '+ Ajouter un commentaire'}</button>
            <div id="edit-comment-${item.id}" class="hidden mt-2">
              <div class="relative mb-2"><textarea spellcheck="true" id="edit-comment-text-${item.id}" placeholder="Commentaire optionnel…" rows="2" class="w-full px-3 py-2 rounded-xl border border-[#D6CCC0] text-sm focus:outline-none focus:border-[#8B3E22] resize-none">${item.feedback ? item.feedback.replace(/</g,'&lt;').replace(/>/g,'&gt;') : ''}</textarea><button data-emoji-btn type="button" onclick="toggleEmojiPicker(this,'edit-comment-text-${item.id}')" class="absolute bottom-1.5 right-1.5 text-base p-1 rounded-lg hover:bg-[#EDE6DB] text-[#767A55]" title="Emoji">😊</button></div>
              <button onclick="saveComment('${item.id}')" class="px-3 py-1.5 bg-[#8B3E22] text-white text-xs rounded-lg hover:bg-[#6B2E1A]">Enregistrer</button>
            </div>
          </div>`}
        </div>
      </div>`;
    }
    window.toggleDashContent = (id) => {
      const d = document.getElementById('dash-detail-' + id);
      const c = document.getElementById('dash-chev-' + id);
      if (d) d.classList.toggle('hidden');
      if (c) c.classList.toggle('rotate-180');
    };

    // Regroupement par mois
    function groupByMonth(items, getBadge, alwaysClosed = false) {
      if (!items.length) return '';
      const groups = {};
      items.forEach(item => {
        const d = item.scheduled_at || item.created_at;
        const k = (d||'').slice(0,7) || '0000-00';
        if (!groups[k]) groups[k] = { items:[], label: d ? new Date(d).toLocaleDateString('fr-FR',{month:'long',year:'numeric'}) : 'Sans date' };
        groups[k].items.push(item);
      });
      const nowM = new Date().toISOString().slice(0,7);
      return Object.keys(groups).sort().reverse().map(k => {
        const { items: gItems, label } = groups[k];
        const cap = label[0].toUpperCase() + label.slice(1);
        const isOpen = !alwaysClosed && k >= nowM;
        return '<details class="mb-2 border border-[#D6CCC0] rounded-xl overflow-hidden" ' + (isOpen?'open':'') + '>'
          + '<summary class="flex items-center justify-between px-4 py-3 bg-[#F5EDE4] cursor-pointer hover:bg-[#EDE6DB] transition-colors select-none">'
          + '<span class="text-sm font-semibold text-[#2C2416] capitalize">' + cap + '</span>'
          + '<span class="text-xs text-[#767A55] bg-white px-2.5 py-1 rounded-full border border-[#D6CCC0]">' + gItems.length + ' contenu' + (gItems.length>1?'s':'') + '</span>'
          + '</summary><div class="p-3">' + gItems.map(i => renderContentCard(i, getBadge(i))).join('') + '</div></details>';
      }).join('');
    }

    if (!allItems || !allItems.length) {
      contentEl.innerHTML = '<p class="text-xs text-[#2C2416]/30 italic">Aucun contenu envoyé</p>';
    } else {
      const pendingHtml = pending.length
        ? '<p class="text-xs uppercase tracking-widest text-[#767A55] mb-3">En attente de validation</p>'
          + groupByMonth(pending, () => '<span class="text-xs px-2 py-0.5 bg-yellow-100 text-yellow-700 rounded-full shrink-0">En attente</span>')
        : '<p class="text-xs text-[#2C2416]/30 italic mb-4">Aucun contenu en attente ✓</p>';
      const historyHtml = done.length
        ? '<p class="text-xs uppercase tracking-widest text-[#767A55] mb-3 mt-6">Historique</p>'
          + groupByMonth(done, (i) => `<span class="text-xs px-2 py-0.5 rounded-full shrink-0 ${i.status==='approved'?'bg-green-100 text-green-700':'bg-red-100 text-red-600'}">${i.status==='approved'?'Validé ✓':'Refusé'}</span>`, true)
        : '';
      contentEl.innerHTML = pendingHtml + historyHtml;
    }
    // Aperçu sur l'onglet Accueil (max 3 en attente)
    const homePreviewEl = document.getElementById('content-list-home');
    if (homePreviewEl) {
      if (!pending.length) {
        homePreviewEl.innerHTML = '<p class="text-xs text-[#2C2416]/30 italic">Aucun contenu en attente ✓</p>';
      } else {
        homePreviewEl.innerHTML = pending.slice(0,3).map(i => renderContentCard(i, '<span class="text-xs px-2 py-0.5 bg-yellow-100 text-yellow-700 rounded-full shrink-0">En attente</span>')).join('');
        if (pending.length > 3) {
          homePreviewEl.innerHTML += `<button onclick="switchTab('content')" class="mt-2 text-xs text-[#8B3E22] hover:underline block">+ ${pending.length - 3} autre(s) → Voir tout</button>`;
        }
      }
    }
    // IDs validés dans cette session → badge "Nouveau" sur le calendrier
    // Le badge disparaît à la prochaine connexion (access_token change à chaque login)
    const _calNewKey     = 'calNewlyApproved_' + uid;
    const _calTokenKey   = 'calSessionToken_'  + uid;
    const _currentToken  = session.access_token?.slice(-16) || '';  // 16 derniers chars suffisent
    const _storedToken   = sessionStorage.getItem(_calTokenKey);
    if (_storedToken !== _currentToken) {
      // Nouvelle connexion → effacer les badges NEW de la session précédente
      sessionStorage.removeItem(_calNewKey);
      sessionStorage.setItem(_calTokenKey, _currentToken);
    }
    const _calNewItems = new Set(JSON.parse(sessionStorage.getItem(_calNewKey) || '[]'));

    window.validate = async (id, status, feedback = '') => {
      const sb2 = await getSB();
      await sb2.from('content_items').update({ status, feedback, updated_at: new Date().toISOString() }).eq('id', id);
      if (status === 'approved') {
        _calNewItems.add(id);
        sessionStorage.setItem(_calNewKey, JSON.stringify([..._calNewItems]));
      }
      window.location.reload();
    };

    window.showFeedback = (id) => {
      document.getElementById('feedback-' + id).classList.toggle('hidden');
    };

    window.validateWithFeedback = (id) => {
      const text = document.getElementById('feedback-text-' + id).value.trim();
      window.validate(id, 'rejected', text);
    };

    window.toggleApproveNote = (id) => {
      document.getElementById('approve-note-' + id)?.classList.toggle('hidden');
    };
    window.validateWithNote = (id) => {
      const text = document.getElementById('approve-text-' + id)?.value.trim() || '';
      window.validate(id, 'approved', text);
    };
    window.toggleEditComment = (id) => {
      document.getElementById('edit-comment-' + id)?.classList.toggle('hidden');
    };
    window.saveComment = async (id) => {
      const text = document.getElementById('edit-comment-text-' + id)?.value.trim() || '';
      const sb2 = await getSB();
      await sb2.from('content_items').update({ feedback: text, updated_at: new Date().toISOString() }).eq('id', id);
      document.getElementById('edit-comment-' + id)?.classList.add('hidden');
      window.location.reload();
    };

    // ── Uploads : rendu inline + renommer + supprimer ────────────────────────
    const TYPE_LABELS_UPLOAD = { 'image':'Photo', 'video':'Vidéo', 'pdf':'PDF', 'document':'Document', 'photo':'Photo' };

    function uploadDisplayName(f) {
      if (f.name) return f.name;
      try { return decodeURIComponent((f.file_url||'').split('/').pop().replace(/^\d+-/, '') || 'Fichier'); } catch(e) { return 'Fichier'; }
    }

    function renderUploadItem(f) {
      const rawName = uploadDisplayName(f);
      const ext  = rawName.split('.').pop()?.toLowerCase() || '';
      const isImg = /^(jpg|jpeg|png|gif|webp|svg)$/.test(ext);
      const isPdf = ext === 'pdf';
      const isVid = /^(mp4|mov|avi|webm|mkv)$/.test(ext);
      const icon  = isImg ? 'solar:gallery-linear' : isPdf ? 'solar:file-text-linear' : isVid ? 'solar:videocamera-linear' : 'solar:paperclip-linear';
      const safeUrl = (f.file_url || '#').replace(/'/g, "\\'");
      const safeName = rawName.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      return `<div class="flex items-center gap-3 py-2.5 border-b border-[#D6CCC0]/30 last:border-0 group" data-search="${(f.name||'').toLowerCase()}">
        <iconify-icon icon="${icon}" stroke-width="1.5" class="text-[#8B3E22] shrink-0 text-base"></iconify-icon>
        <div class="flex-1 min-w-0">
          <span id="uname-${f.id}" class="text-sm text-[#2C2416] truncate block">${safeName}</span>
          <div id="urename-${f.id}" class="hidden flex gap-1 items-center">
            <input type="text" value="${safeName}" spellcheck="true"
              class="flex-1 px-2 py-1 text-sm rounded-lg border border-[#8B3E22] focus:outline-none"
              onkeydown="if(event.key==='Enter') saveUploadName('${f.id}',this.value); if(event.key==='Escape') cancelRename('${f.id}')"
              onblur="cancelRename('${f.id}')" />
            <button onmousedown="event.preventDefault(); saveUploadName('${f.id}', document.querySelector('#urename-${f.id} input').value)" class="px-2 py-1 bg-[#8B3E22] text-white text-xs rounded-lg">✓</button>
          </div>
        </div>
        <a href="${f.file_url||'#'}" target="_blank" class="shrink-0 p-1 text-[#767A55] hover:text-[#8B3E22] transition-colors" title="Ouvrir">
          <iconify-icon icon="solar:eye-linear" stroke-width="1.5" class="text-base"></iconify-icon>
        </a>
        <div class="flex gap-0.5 opacity-0 group-hover:opacity-100 transition-opacity shrink-0">
          <button onclick="startRename('${f.id}')" class="p-1.5 text-[#767A55] hover:text-[#8B3E22] transition-colors rounded-lg hover:bg-[#8B3E22]/10" title="Renommer">
            <iconify-icon icon="solar:pen-linear" stroke-width="1.5" class="text-sm"></iconify-icon>
          </button>
          <button onclick="deleteUpload('${f.id}','${safeUrl}')" class="p-1.5 text-[#767A55] hover:text-red-500 transition-colors rounded-lg hover:bg-red-50" title="Supprimer">
            <iconify-icon icon="solar:trash-bin-minimalistic-linear" stroke-width="1.5" class="text-sm"></iconify-icon>
          </button>
        </div>
        <span class="text-[10px] text-[#767A55] shrink-0 bg-[#EDE6DB] px-2 py-0.5 rounded-full">Déposé</span>
      </div>`;
    }

    const TYPE_MAP_DOCS = { contrat:'Contrat', devis:'Devis', 'audit-instagram':'Audit', 'compte-rendu':'Bilan', post:'Post', reel:'Reel', carrousel:'Carrousel', planning:'Planning' };

    function docRowHtml(d, icon) {
      const label = d.name || d.file_name || 'Document';
      const type  = TYPE_MAP_DOCS[d.type] || d.type || '';
      return `<a href="${d.file_url||'#'}" target="_blank" data-search="${label.toLowerCase()}"
        class="flex items-center justify-between gap-3 text-sm py-2.5 border-b border-[#D6CCC0]/30 last:border-0 hover:text-[#8B3E22] transition-colors">
        <div class="flex items-center gap-2 min-w-0">
          <iconify-icon icon="${icon}" stroke-width="1.5" class="text-[#8B3E22] shrink-0"></iconify-icon>
          <span class="truncate">${label}</span>
        </div>
        ${type ? `<span class="text-[10px] text-[#767A55] shrink-0 bg-[#EDE6DB] px-2 py-0.5 rounded-full">${type}</span>` : ''}
      </a>`;
    }

    async function refreshDocsList() {
      const sb2 = await getSB();
      const [{ data: freshDocs }, { data: freshUploads }] = await Promise.all([
        sb2.from('documents').select('*').eq('client_id', uid).order('created_at', { ascending: false }),
        sb2.from('client_uploads').select('*').eq('client_id', uid).order('created_at', { ascending: false }),
      ]);

      const nonInvoices = (freshDocs||[]).filter(d => d.type !== 'facture');
      const invoices    = (freshDocs||[]).filter(d => d.type === 'facture');

      const docsEl = document.getElementById('docs-list');
      if (docsEl) docsEl.innerHTML = nonInvoices.map(d => docRowHtml(d, 'solar:file-download-linear')).join('')
        || '<p class="text-xs text-[#2C2416]/30 italic">Aucun document</p>';

      const invEl = document.getElementById('invoices-list');
      if (invEl) invEl.innerHTML = invoices.map(d => docRowHtml(d, 'solar:bill-linear')).join('')
        || '<p class="text-xs text-[#2C2416]/30 italic">Aucune facture</p>';

      const uploadsEl = document.getElementById('uploads-list');
      if (uploadsEl) uploadsEl.innerHTML = (freshUploads||[]).map(renderUploadItem).join('')
        || '<p class="text-xs text-[#2C2416]/30 italic">Aucun fichier déposé</p>';
    }

    await refreshDocsList();

    window.startRename = (id) => {
      document.getElementById('uname-' + id)?.classList.add('hidden');
      const wrap = document.getElementById('urename-' + id);
      wrap?.classList.remove('hidden');
      wrap?.querySelector('input')?.focus();
      wrap?.querySelector('input')?.select();
    };
    window.cancelRename = (id) => {
      document.getElementById('uname-' + id)?.classList.remove('hidden');
      document.getElementById('urename-' + id)?.classList.add('hidden');
    };
    window.saveUploadName = async (id, newName) => {
      const name = (newName || '').trim();
      if (!name) { window.cancelRename(id); return; }
      const sb2 = await getSB();
      await sb2.from('client_uploads').update({ name }).eq('id', id);
      const nameEl = document.getElementById('uname-' + id);
      if (nameEl) nameEl.textContent = name;
      window.cancelRename(id);
    };
    window.deleteUpload = async (id, fileUrl) => {
      if (!confirm('Supprimer ce fichier définitivement ?')) return;
      const sb2 = await getSB();
      try {
        if (fileUrl && fileUrl !== '#') {
          const url = new URL(fileUrl);
          const parts = url.pathname.split('/client-uploads/');
          if (parts[1]) await sb2.storage.from('client-uploads').remove([decodeURIComponent(parts[1])]);
        }
      } catch(e) {}
      await sb2.from('client_uploads').delete().eq('id', id);
      await refreshDocsList();
    };

    document.getElementById('upload-input').onchange = async (e) => {
      const files = Array.from(e.target.files || []);
      if (!files.length) return;
      const status = document.getElementById('upload-status');
      status.textContent = 'Envoi en cours…';
      const sb2 = await getSB();
      let ok = 0;
      const sanitize = (name) => name
        .normalize('NFD').replace(/[̀-ͯ]/g, '')
        .replace(/[^a-zA-Z0-9._-]/g, '_')
        .replace(/_+/g, '_').replace(/^_|_$/g, '');

      let lastError = '';
      for (const file of files) {
        const safeName = sanitize(file.name) || 'fichier';
        const path = `${uid}/${Date.now()}-${safeName}`;
        const { data, error } = await sb2.storage.from('client-uploads').upload(path, file);
        if (error) { lastError = error.message || JSON.stringify(error); continue; }
        if (data) {
          const { data: urlData } = sb2.storage.from('client-uploads').getPublicUrl(path);
          const { error: insertError } = await sb2.from('client_uploads').insert({ client_id: uid, file_url: urlData.publicUrl });
          if (insertError) { lastError = insertError.message || JSON.stringify(insertError); continue; }
          ok++;
        }
      }
      status.textContent = ok > 0 ? `${ok} fichier(s) envoyé(s) ✓` : `Erreur : ${lastError || 'inconnu'}`;
      e.target.value = '';
      await refreshDocsList();
      if (ok > 0) { window.switchTab?.('docs'); setTimeout(() => window.switchDocsTab?.('uploads'), 50); }
    };

    // ─── Notifications ───────────────────────────────────────────────────────
    // Cible de redirection selon type de notification
    function notifTarget(type) {
      if (type === 'content')  return { id: 'card-content',  label: 'Contenu à valider' };
      if (type === 'document') return { id: 'card-docs',     label: 'Contrats & documents' };
      if (type === 'facture')  return { id: 'card-invoices', label: 'Factures' };
      if (type === 'message')  return { id: 'discussion',    label: 'Discussion' };
      return null;
    }

    // Cache local des notifs rejetées (résiste aux échecs RLS)
    const NOTIF_LOCAL_KEY = 'notifDismissed_' + uid;
    function getLocalDismissed() { return new Set(JSON.parse(localStorage.getItem(NOTIF_LOCAL_KEY) || '[]')); }
    function addLocalDismissed(id) {
      const s = getLocalDismissed(); s.add(id);
      localStorage.setItem(NOTIF_LOCAL_KEY, JSON.stringify([...s]));
    }
    function addAllLocalDismissed(ids) {
      const s = getLocalDismissed(); ids.forEach(id => s.add(id));
      localStorage.setItem(NOTIF_LOCAL_KEY, JSON.stringify([...s]));
    }

    async function loadNotifications() {
      const { data: notifs } = await sb.from('notifications')
        .select('*').eq('client_id', uid).order('created_at', { ascending: false }).limit(20);
      const localDismissed = getLocalDismissed();
      // Non-lues ET non rejetées localement
      const unread = (notifs||[]).filter(n => !n.read && !localDismissed.has(n.id));
      const badge  = document.getElementById('notif-badge');
      const list   = document.getElementById('notif-list');

      if (unread.length > 0) {
        badge.textContent = unread.length > 9 ? '9+' : String(unread.length);
        badge.classList.remove('hidden');
        badge.classList.add('flex');
      } else {
        badge.classList.add('hidden');
        badge.classList.remove('flex');
      }

      if (list) {
        const unreadNotifs = unread;
        if (!unreadNotifs.length) { list.innerHTML = '<p class="text-xs text-[#2C2416]/40 italic p-4">Aucune notification</p>'; return; }
        list.innerHTML = unreadNotifs.map(n => {
          const target  = notifTarget(n.type);
          const dateStr = new Date(n.created_at).toLocaleDateString('fr-FR', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' });
          return `<div data-notif-id="${n.id}" onclick="markNotifRead('${n.id}'); goToSection('${n.id}','${target?.id||''}','${n.type||''}','${n.content_id||''}')"
            class="flex items-start gap-2.5 px-4 py-3 cursor-pointer hover:bg-[#F5EDE4] transition-colors bg-[#8B3E22]/10">
            <button data-checkbox onclick="event.stopPropagation(); markNotifRead('${n.id}')" title="Marquer comme lu"
              class="w-4 h-4 rounded border-2 shrink-0 mt-0.5 flex items-center justify-center transition-colors border-[#8B3E22] hover:bg-[#8B3E22]/30">
            </button>
            <div class="flex-1 min-w-0">
              <p data-notif-text class="text-xs text-[#2C2416] leading-relaxed font-medium">${n.message}</p>
              <p class="text-[10px] text-[#767A55] mt-0.5">${dateStr}</p>
            </div>
          </div>`;
        }).join('');
      }
    }

    // Mise à jour visuelle immédiate d'une ligne notification
    function markNotifRowRead(id) {
      const row = document.querySelector(`[data-notif-id="${id}"]`);
      if (!row) return;
      row.classList.remove('bg-[#8B3E22]/10');
      row.classList.add('bg-white');
      const btn = row.querySelector('[data-checkbox]');
      if (btn) {
        btn.className = 'w-4 h-4 rounded border-2 shrink-0 mt-0.5 flex items-center justify-center transition-colors border-[#D6CCC0] bg-[#D6CCC0]/20 cursor-default';
        btn.innerHTML = '<iconify-icon icon="solar:check-linear" stroke-width="3" class="text-[#767A55]" style="font-size:8px"></iconify-icon>';
      }
      const txt = row.querySelector('[data-notif-text]');
      if (txt) txt.classList.remove('font-medium');
    }

    function removeNotifRow(id) {
      const row = document.querySelector(`[data-notif-id="${id}"]`);
      if (!row) return;
      row.style.transition = 'opacity 0.12s';
      row.style.opacity = '0';
      setTimeout(() => { row.remove(); updateNotifBadge(); }, 120);
    }
    function updateNotifBadge() {
      const remaining = document.querySelectorAll('[data-notif-id]').length;
      const badge = document.getElementById('notif-badge');
      if (badge) {
        if (remaining === 0) { badge.classList.add('hidden'); badge.classList.remove('flex'); }
        else { badge.textContent = remaining > 9 ? '9+' : String(remaining); badge.classList.remove('hidden'); badge.classList.add('flex'); }
      }
    }

    window.markNotifRead = (id) => {
      addLocalDismissed(id);  // cache local immédiat
      sb.from('notifications').update({ read: true }).eq('id', id);  // tentative DB
      removeNotifRow(id);
    };

    window.markAllNotifRead = () => {
      const ids = [...document.querySelectorAll('[data-notif-id]')].map(r => r.dataset.notifId);
      addAllLocalDismissed(ids);  // cache local
      ids.forEach(id => removeNotifRow(id));
      sb.from('notifications').update({ read: true }).eq('client_id', uid);  // tentative DB
    };

    // Clic sur notification → marquer lu + naviguer vers le bon endroit
    window.goToSection = async (notifId, cardId, type, contentId) => {
      addLocalDismissed(notifId);  // cache local immédiat
      removeNotifRow(notifId);
      sb.from('notifications').update({ read: true }).eq('id', notifId);
      document.getElementById('notif-panel').classList.add('hidden');
      document.getElementById('notif-overlay').classList.add('hidden');
      // Discussion
      if (type === 'message') {
        const panel = document.getElementById('discussion-panel');
        if (panel && panel.classList.contains('hidden')) window.toggleDiscussion();
        return;
      }
      // Contenu : ouvrir le détail de l'item concerné
      if (type === 'content') {
        window.switchTab('content');
        setTimeout(() => {
          // Priorité : content_id fourni par la notif, sinon premier item en attente
          const targetId = contentId || pending[0]?.id;
          if (targetId) {
            // Ouvrir le <details> parent si fermé
            const detail = document.getElementById('dash-detail-' + targetId);
            const detailsEl = detail?.closest('details');
            if (detailsEl) detailsEl.open = true;
            if (detail?.classList.contains('hidden')) window.toggleDashContent(targetId);
            setTimeout(() => {
              const row = detail?.closest('[data-search]') || detail;
              if (row) {
                row.scrollIntoView({ behavior:'smooth', block:'center' });
                row.style.transition = 'box-shadow 0.3s';
                row.style.boxShadow = '0 0 0 3px #8B3E2250';
                setTimeout(() => { row.style.boxShadow = ''; }, 2000);
              }
            }, 100);
          }
        }, 300);
        return;
      }
      if (cardId) {
        if (cardId === 'card-docs') { window.switchTab('docs'); setTimeout(() => window.switchDocsTab?.('docs'), 50); }
        else if (cardId === 'card-invoices') { window.switchTab('docs'); setTimeout(() => window.switchDocsTab?.('factures'), 50); }
        setTimeout(() => {
          const card = document.getElementById(cardId);
          if (card) {
            card.scrollIntoView({ behavior: 'smooth', block: 'center' });
            card.classList.add('ring-4', 'ring-[#8B3E22]', 'ring-offset-2');
            setTimeout(() => card.classList.remove('ring-4', 'ring-[#8B3E22]', 'ring-offset-2'), 2500);
          }
        }, 150);
      }
    };

    document.getElementById('notif-btn').onclick = () => {
      const panel   = document.getElementById('notif-panel');
      const overlay = document.getElementById('notif-overlay');
      const isOpen  = !panel.classList.contains('hidden');
      panel.classList.toggle('hidden', isOpen);
      overlay.classList.toggle('hidden', isOpen);
      if (!isOpen) loadNotifications();
    };

    loadNotifications();

    // Realtime — notification en temps réel quand Claire dépose quelque chose
    sb.channel('notifications-' + uid)
      .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'notifications', filter: `client_id=eq.${uid}` },
        payload => {
          const toast = document.getElementById('notif-toast');
          document.getElementById('notif-toast-text').textContent = payload.new.message;
          toast.classList.remove('hidden');
          toast.classList.add('flex');
          setTimeout(() => toast.classList.add('hidden'), 6000);
          loadNotifications();
          window.location.reload(); // Recharger pour voir le nouveau contenu
        })
      .subscribe();

    // Realtime — tâches : mise à jour auto quand l'admin ajoute/modifie une tâche
    sb.channel('client-tasks-sync')
      .on('postgres_changes', { event: '*', schema: 'public', table: 'tasks' }, (payload) => {
        if ((payload.new?.client_id || payload.old?.client_id) === uid) loadTasks();
      })
      .subscribe();

    // Realtime — notes admin : apparaît instantanément dans "Dernières notes"
    sb.channel('client-notes-sync')
      .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'client_notes' }, (payload) => {
        if (payload.new?.client_id === uid && payload.new?.from_admin) loadClientNotes();
      })
      .subscribe();

    // ─── Événements français ─────────────────────────────────────────────────
    function getEasterDate(y) {
      const a=y%19,b=Math.floor(y/100),c=y%100,d=Math.floor(b/4),e=b%4,f=Math.floor((b+8)/25);
      const g=Math.floor((b-f+1)/3),h=(19*a+b-d-g+15)%30,i=Math.floor(c/4),k=c%4;
      const l=(32+2*e+2*i-h-k)%7,m=Math.floor((a+11*h+22*l)/451);
      return new Date(y,Math.floor((h+l-7*m+114)/31)-1,((h+l-7*m+114)%31)+1);
    }
    function getFrEvents(y) {
      const ev={};
      const add=(m,d,n)=>{ const k=`${y}-${String(m).padStart(2,'0')}-${String(d).padStart(2,'0')}`; if(!ev[k])ev[k]=[]; ev[k].push(n); };
      const addD=(dt,n)=>add(dt.getMonth()+1,dt.getDate(),n);
      add(1,1,'🥂 Jour de l\'an'); add(5,1,'🏛 Fête du Travail');
      add(7,14,'🎆 Fête Nationale'); add(11,1,'🕯 Toussaint');
      add(11,11,'🕊 Armistice'); add(12,25,'🎄 Noël');
      const pa=getEasterDate(y);
      addD(pa,'🐣 Pâques');
      const lpa=new Date(pa); lpa.setDate(pa.getDate()+1); addD(lpa,'🐣 Lundi Pâques');
      const asc=new Date(pa); asc.setDate(pa.getDate()+39);
      const pen=new Date(pa); pen.setDate(pa.getDate()+49);
      const lpe=new Date(pa); lpe.setDate(pa.getDate()+50);
      add(2,14,'❤️ St-Valentin'); add(3,8,'💜 Journée Femme');
      add(4,1,'🐟 Poisson d\'avril'); add(10,31,'🎃 Halloween'); add(12,31,'🥂 Réveillon');
      function lastSun(mo){const d=new Date(y,mo+1,0);d.setDate(d.getDate()-d.getDay());return d;}
      function firstSun(mo){const d=new Date(y,mo,1);while(d.getDay()!==0)d.setDate(d.getDate()+1);return d;}
      function nthSun(mo,n){const d=firstSun(mo);d.setDate(d.getDate()+(n-1)*7);return d;}
      function nthFri(mo,n){const d=new Date(y,mo,1);while(d.getDay()!==5)d.setDate(d.getDate()+1);d.setDate(d.getDate()+(n-1)*7);return d;}
      const fmt=(dt)=>`${y}-${String(dt.getMonth()+1).padStart(2,'0')}-${String(dt.getDate()).padStart(2,'0')}`;
      const fm=lastSun(4);
      addD(fmt(fm)===fmt(pen)?firstSun(5):fm,'💐 Fête des Mères');
      addD(nthSun(5,3),'👔 Fête des Pères');
      addD(nthFri(10,4),'🛍 Black Friday');
      return ev;
    }

