      const [y,m,d] = dateStr.split('-');
      const months = ['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'];
      const FD_HEX  = { 'POST':'#3B82F6','REEL':'#8B5CF6','CARROUSEL':'#10B981','PLANNING':'#F59E0B','CALENDRIER ÉDITORIAL':'#F59E0B','AUDIT':'#6B7280' };
      const FD_ICON = { 'POST':'solar:image-linear','REEL':'solar:videocamera-linear','CARROUSEL':'solar:gallery-linear','PLANNING':'solar:calendar-linear','CALENDRIER ÉDITORIAL':'solar:calendar-linear' };
      let html = '';
