---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Nouveau mot de passe — Claire Vigneron" hideChatWidget={true}>
  <div class="min-h-screen bg-[#2C2416] flex items-center justify-center px-6">
    <div class="w-full max-w-md bg-[#F5EDE4] rounded-3xl p-8 shadow-2xl">
      <h1 class="text-2xl text-[#2C2416] tracking-tight mb-2">Nouveau mot de passe</h1>
      <p class="text-sm text-[#2C2416]/60 font-light mb-6">Choisissez votre nouveau mot de passe (minimum 6 caractères).</p>
      <input id="new-pwd" type="password" placeholder="Nouveau mot de passe" minlength="6"
        class="w-full px-4 py-3 rounded-xl border border-[#D6CCC0] bg-white text-[#2C2416] focus:outline-none focus:border-[#8B3E22] text-sm mb-3" />
      <input id="confirm-pwd" type="password" placeholder="Confirmer le mot de passe" minlength="6"
        class="w-full px-4 py-3 rounded-xl border border-[#D6CCC0] bg-white text-[#2C2416] focus:outline-none focus:border-[#8B3E22] text-sm mb-4" />
      <div id="msg" class="hidden text-sm rounded-xl px-4 py-3 mb-4"></div>
      <button id="save-btn" class="w-full py-4 bg-[#8B3E22] text-[#F5EDE4] rounded-xl font-medium hover:bg-[#6B2E1A] transition-colors">
        Enregistrer
      </button>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  const SUPABASE_URL = 'https://etubpowlffhdvnfqkjij.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_AyehSGHv6TEwFvPQIuMivg_-_mJ7zUH';

  function loadScript(src) {
    return new Promise((resolve) => {
      const s = document.createElement('script');
      s.src = src; s.onload = resolve;
      document.head.appendChild(s);
    });
  }

  document.getElementById('save-btn').onclick = async () => {
    const pwd  = document.getElementById('new-pwd').value;
    const conf = document.getElementById('confirm-pwd').value;
    const msg  = document.getElementById('msg');
    msg.classList.remove('hidden', 'text-red-600', 'bg-red-50', 'text-green-700', 'bg-green-50');
    if (pwd !== conf) { msg.textContent = 'Les mots de passe ne correspondent pas.'; msg.classList.add('text-red-600', 'bg-red-50'); return; }
    if (pwd.length < 6)  { msg.textContent = 'Minimum 6 caractères.'; msg.classList.add('text-red-600', 'bg-red-50'); return; }
    await loadScript('https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.js');
    const sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
    const { error } = await sb.auth.updateUser({ password: pwd });
    if (error) { msg.textContent = 'Erreur : ' + error.message; msg.classList.add('text-red-600', 'bg-red-50'); }
    else { msg.textContent = 'Mot de passe mis à jour ! Redirection…'; msg.classList.add('text-green-700', 'bg-green-50'); setTimeout(() => window.location.href = '/espace-client', 1500); }
    msg.classList.remove('hidden');
  };
</script>
