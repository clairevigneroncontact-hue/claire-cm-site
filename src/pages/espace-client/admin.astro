              <div><label class="text-xs text-[#767A55] uppercase tracking-widest block mb-1">Mot de passe Instagram</label>
                <div class="relative">
                  <input id="ci-ig-pwd" type="password" data-no-spellcheck value="${c?.instagram_password||''}" placeholder="••••••••" class="w-full px-3 py-2 pr-10 rounded-xl border border-[#D6CCC0] text-sm focus:outline-none focus:border-[#8B3E22]" />
                  <button type="button" onclick="const f=document.getElementById('ci-ig-pwd');f.type=f.type==='password'?'text':'password'" class="absolute right-3 top-1/2 -translate-y-1/2 text-[#767A55] hover:text-[#2C2416]">
                    <iconify-icon icon="solar:eye-linear" stroke-width="1.5"></iconify-icon>
                  </button>
