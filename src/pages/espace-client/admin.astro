              </div>
            </div>
          </div>
        </div>

        <!-- Tab : Infos client -->
        <!-- Tab : Notes -->
        <div id="ctab-notes-panel" class="hidden space-y-4">
          <!-- Notes personnelles + Tâches côte à côte -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="bg-white rounded-2xl p-5 border border-[#D6CCC0] flex flex-col">
              <div class="flex items-center gap-2 mb-3">
                <iconify-icon icon="solar:notebook-linear" stroke-width="1.5" class="text-[#8B3E22]"></iconify-icon>
                <h3 class="text-sm font-medium text-[#2C2416]">Mes notes</h3>
              </div>
              <p class="text-xs text-[#767A55] mb-3">Tes réflexions privées, idées de contenu.</p>
              <textarea spellcheck="true" id="notes-admin" rows="7" placeholder="Idées de posts, prochains thèmes…" class="w-full px-4 py-3 rounded-xl border border-[#D6CCC0] text-sm focus:outline-none focus:border-[#8B3E22] resize-none flex-1">${c?.admin_notes||''}</textarea>
              <div id="notes-msg" class="hidden text-sm rounded-xl px-4 py-2 mt-2"></div>
              <button onclick="saveNotes('${clientId}')" class="mt-3 px-5 py-2 bg-[#8B3E22] text-white rounded-xl text-sm font-medium hover:bg-[#6B2E1A] transition-colors self-start">Enregistrer</button>
            </div>
            <div class="bg-white rounded-2xl p-5 border border-[#D6CCC0]">
              <div class="flex items-center gap-2 mb-3">
                <iconify-icon icon="solar:checklist-minimalistic-linear" stroke-width="1.5" class="text-[#8B3E22]"></iconify-icon>
                <h3 class="text-sm font-medium text-[#2C2416]">Tâches</h3>
                <span class="text-xs text-[#767A55]">(visibles par le client)</span>
              </div>
              <div id="admin-tasks-list" class="space-y-2 mb-4 max-h-64 overflow-y-auto">
                <p class="text-xs text-[#2C2416]/30 italic">Aucune tâche</p>
              </div>
              <div class="flex gap-2">
                <input id="admin-task-input" type="text" spellcheck="true" placeholder="Nouvelle tâche pour le client…"
                  onkeydown="if(event.key==='Enter') addAdminTask()"
                  class="flex-1 px-3 py-2 rounded-xl border border-[#D6CCC0] text-sm focus:outline-none focus:border-[#8B3E22]" />
                <button onclick="addAdminTask()" class="px-4 py-2 bg-[#8B3E22] text-white rounded-xl text-sm font-medium hover:bg-[#6B2E1A] transition-colors">+</button>
              </div>
            </div>
          </div>
