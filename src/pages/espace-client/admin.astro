              + '<span class="text-xs text-[#767A55] bg-white px-2.5 py-1 rounded-full border border-[#D6CCC0]">' + items.length + ' contenu' + (items.length>1?'s':'') + '</span>'
              + '</summary><div class="p-2">' + items.map(_renderCtItem).join('') + '</div></details>';
          }).join('');
        }
        return html || '<p class="text-xs text-[#2C2416]/30 italic">Aucun contenu envoyé</p>';
      })();

