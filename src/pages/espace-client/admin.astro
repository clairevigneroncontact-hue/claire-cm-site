                    <button id="client-cal-label" onclick="clientToggleMonthPicker(event)" class="text-xs font-semibold text-[#2C2416] min-w-[120px] text-center px-2 py-1 rounded-lg hover:bg-[#EDE6DB] cursor-pointer transition-colors"></button>
