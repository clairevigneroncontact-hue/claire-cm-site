                    <div class="flex items-center justify-between mt-1">
                      <p class="text-[10px] text-[#767A55]">${date}</p>
                      <button onclick="deleteUpload('${u.id}','${(u.file_url||'').replace(/'/g,"\\'")}','${clientId}')" class="p-1 text-red-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors">
