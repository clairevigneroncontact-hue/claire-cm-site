  window.sendBilanFromModal = async () => {
    if (!_bilanClientId) return;
    const month      = document.getElementById('bilan-month')?.value || '';
    const year       = parseInt(document.getElementById('bilan-year')?.value) || new Date().getFullYear();
    const contenus   = document.getElementById('bilan-contenus')?.value.trim() || '—';
    const abonnes    = document.getElementById('bilan-abonnes')?.value.trim() || '—';
    const portee     = document.getElementById('bilan-portee')?.value.trim() || '—';
    const engagement = document.getElementById('bilan-engagement')?.value.trim() || '—';
    const highlights = document.getElementById('bilan-highlights')?.value.trim() || '';
    const next       = document.getElementById('bilan-next')?.value.trim() || '';

    const btn = document.querySelector('#bilan-modal button[onclick="sendBilanFromModal()"]');
    if (btn) { btn.disabled = true; btn.textContent = 'Envoi en cours…'; }

    const res = await fetch('/api/send-notification', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        clientId: _bilanClientId,
        type: 'bilan',
        data: { month, year, contenusPublies: contenus, nouveauxAbonnes: abonnes, porteeMovenne: portee, engagementMoyen: engagement, highlights, next },
      }),
    });
    const d = await res.json().catch(()=>({}));

    if (btn) { btn.disabled = false; btn.innerHTML = '<iconify-icon icon="solar:letter-linear" stroke-width="1.5"></iconify-icon> Envoyer le bilan'; }
    const msg = document.getElementById('bilan-send-msg');
    if (msg) {
      msg.className = `text-sm rounded-xl px-4 py-2.5 ${d.sent ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-600'}`;
      msg.textContent = d.sent ? '✅ Bilan envoyé avec succès' : `❌ Erreur : ${d.error || 'inconnue'}`;
      msg.classList.remove('hidden');
