              <div class="w-6 h-6 border-2 border-[#8B3E22] border-t-transparent rounded-full animate-spin mx-auto mb-3"></div>
              <p class="text-sm text-[#767A55]">Chargement…</p>
            </div>
          </div>
        </div>

      `;

      // Initialiser les créneaux — rétrocompatibilité tous formats
      const _rawPrefs = c?.posting_prefs || {};
      let _initSlots = _rawPrefs.slots || [];
      if (!_initSlots.length) {
        // Ancien format par type → fusionner
        const all = ['post','story','reel','carrousel'].flatMap(t => _rawPrefs[t]||[]);
        if (all.length) _initSlots = all;
        else if (_rawPrefs.days?.length && _rawPrefs.times?.length)
          _rawPrefs.days.forEach(d => _rawPrefs.times.forEach(t => _initSlots.push({day:d,time:t})));
      }
      _currentPostingPrefs = { slots: _initSlots };
      _prefSelectedDays = new Set();
      renderPrefChips();
    }

    // Supprimer un document
    window.deleteDoc = async (docId, fileUrl, clientId) => {
      if (!confirm('Supprimer ce document ? Le client ne pourra plus y accéder.')) return;
      const sb = await getSB();
      try {
        const url = new URL(fileUrl);
        const pathParts = url.pathname.split('/documents/');
        if (pathParts[1]) await sb.storage.from('documents').remove([decodeURIComponent(pathParts[1])]);
      } catch(e) {}
      await sb.from('documents').delete().eq('id', docId);
      await window.openClient(clientId);
      switchClientTab('documents');
    };

    // Switcher d'onglets client
    window.switchAdminDocsTab = (sub) => {
      ['docs','factures','files'].forEach(t => {
        document.getElementById('adocs-subtab-' + t)?.classList.toggle('hidden', t !== sub);
        const btn = document.getElementById('adocs-btn-' + t);
        if (btn) {
          btn.classList.toggle('bg-white', t === sub);
          btn.classList.toggle('shadow-sm', t === sub);
          btn.classList.toggle('text-[#2C2416]', t === sub);
          btn.classList.toggle('text-[#2C2416]/50', t !== sub);
        }
      });
    };

    window.switchClientTab = (tab) => {
      ['contenu','documents','notes','stats'].forEach(t => {
        const panel = document.getElementById(`ctab-${t}-panel`);
        if (panel) panel.classList.toggle('hidden', t !== tab);
        const btn = document.getElementById(`ctab-${t}`);
        if (btn) {
          btn.classList.toggle('bg-white', t === tab);
          btn.classList.toggle('shadow-sm', t === tab);
          btn.classList.toggle('text-[#2C2416]', t === tab);
          btn.classList.toggle('text-[#2C2416]/50', t !== tab);
        }
      });
      if (tab === 'contenu') loadClientCal();
      if (tab === 'notes')   loadAdminTasks(_clientCalClientId || '');
      if (tab === 'notes')   loadAdminClientNotes(window._currentAdminClientId);
      if (tab === 'stats')   loadIgStats(window._currentAdminClientId);
    };

    window.loadIgStats = async (clientId) => {
      const container = document.getElementById('ig-stats-container');
      if (!container || !clientId) return;
      container.innerHTML = '<div class="text-center py-8"><div class="w-6 h-6 border-2 border-[#8B3E22] border-t-transparent rounded-full animate-spin mx-auto mb-3"></div><p class="text-sm text-[#767A55]">Chargement…</p></div>';
      try {
        const res  = await fetch(`/api/instagram-stats?clientId=${clientId}`);
        const data = await res.json();
        if (data.error === 'no_token' || data.error === 'token_invalid') {
          container.innerHTML = `<div class="bg-white rounded-2xl p-8 border border-[#D6CCC0] text-center">
            <iconify-icon icon="mdi:instagram" class="text-5xl text-[#8B3E22]/30 mb-4 block"></iconify-icon>
            <h3 class="text-sm font-medium text-[#2C2416] mb-2">Compte Instagram non connecté</h3>
            <p class="text-xs text-[#767A55] mb-6">Connecte le compte Instagram Pro pour accéder aux statistiques.</p>
            <a href="/api/instagram-auth?clientId=${clientId}" class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-[#833ab4] via-[#fd1d1d] to-[#fcb045] text-white rounded-xl text-sm font-medium hover:opacity-90 transition-opacity">
              <iconify-icon icon="mdi:instagram" class="text-lg"></iconify-icon>
              Connecter Instagram
            </a>
          </div>`;
          return;
        }
        const p     = data.profile || {};
        const media = data.media   || [];
        const totalEng  = media.reduce((s, m) => s + (m.like_count || 0) + (m.comments_count || 0), 0);
        const avgEngage = (media.length && p.followers_count)
          ? ((totalEng / media.length) / p.followers_count * 100).toFixed(2)
          : '—';
        container.innerHTML = `
          <div class="bg-white rounded-2xl p-5 border border-[#D6CCC0] mb-4">
            <div class="flex items-center gap-4 mb-4">
              ${p.profile_picture_url
                ? `<img src="${p.profile_picture_url}" class="w-14 h-14 rounded-full object-cover border-2 border-[#D6CCC0]" />`
                : `<div class="w-14 h-14 rounded-full bg-gradient-to-br from-[#833ab4] via-[#fd1d1d] to-[#fcb045] flex items-center justify-center"><iconify-icon icon="mdi:instagram" class="text-2xl text-white"></iconify-icon></div>`}
              <div class="flex-1 min-w-0">
                <p class="font-semibold text-[#2C2416]">@${p.username || '—'}</p>
                ${p.biography ? `<p class="text-xs text-[#767A55] mt-0.5 line-clamp-2">${p.biography}</p>` : ''}
              </div>
              <a href="/api/instagram-auth?clientId=${clientId}" class="shrink-0 text-xs px-3 py-1.5 border border-[#D6CCC0] text-[#767A55] rounded-full hover:border-[#8B3E22] hover:text-[#8B3E22] transition-colors">↺ Reconnecter</a>
            </div>
            <div class="grid grid-cols-3 gap-3">
              <div class="text-center bg-[#F5EDE4] rounded-xl p-3">
                <p class="text-xl font-bold text-[#2C2416]">${(p.followers_count || 0).toLocaleString('fr-FR')}</p>
                <p class="text-[10px] text-[#767A55] uppercase tracking-widest mt-0.5">Abonnés</p>
              </div>
              <div class="text-center bg-[#F5EDE4] rounded-xl p-3">
                <p class="text-xl font-bold text-[#2C2416]">${(p.media_count || 0).toLocaleString('fr-FR')}</p>
                <p class="text-[10px] text-[#767A55] uppercase tracking-widest mt-0.5">Publications</p>
              </div>
              <div class="text-center bg-[#F5EDE4] rounded-xl p-3">
                <p class="text-xl font-bold text-[#2C2416]">${avgEngage}%</p>
                <p class="text-[10px] text-[#767A55] uppercase tracking-widest mt-0.5">Engagement</p>
              </div>
            </div>
          </div>
          ${media.length ? `<div class="bg-white rounded-2xl p-5 border border-[#D6CCC0]">
            <h3 class="text-sm font-medium text-[#2C2416] mb-3">9 dernières publications</h3>
            <div class="grid grid-cols-3 gap-0.5">
              ${media.map(m => {
                const img = m.media_type === 'VIDEO' ? (m.thumbnail_url || '') : (m.media_url || '');
                return `<a href="${m.permalink || '#'}" target="_blank" class="relative aspect-square overflow-hidden bg-[#EDE6DB] group block">
                  ${img ? `<img src="${img}" class="w-full h-full object-cover" loading="lazy" onerror="this.style.display='none'" />` : ''}
                  <div class="absolute inset-0 bg-black/0 group-hover:bg-black/60 transition-colors flex items-center justify-center">
                    <div class="opacity-0 group-hover:opacity-100 transition-opacity text-white text-xs font-semibold text-center leading-loose px-1">
                      <div>❤️ ${m.like_count || 0} &nbsp; 💬 ${m.comments_count || 0}</div>
                      <div>${m.reposts_count != null ? `<iconify-icon icon="ph:arrows-clockwise" class="align-middle"></iconify-icon> ${m.reposts_count}` : ''}${m.reposts_count != null && m.saved_count != null ? ' &nbsp; ' : ''}${m.saved_count != null ? `🔖 ${m.saved_count}` : ''}</div>
                    </div>
                  </div>
                </a>`;
              }).join('')}
            </div>
          </div>` : ''}`;

        // Post le plus performant du mois
        const thisMonth = new Date().toISOString().slice(0, 7);
        const monthMedia = media.filter(m => (m.timestamp || '').slice(0, 7) === thisMonth);
        const scored = (monthMedia.length ? monthMedia : media).map(m => ({
          ...m,
          score: (m.like_count || 0) + (m.comments_count || 0) * 2 + (m.reposts_count || 0) * 2 + (m.saved_count || 0) * 3,
        })).sort((a, b) => b.score - a.score);
        const best = scored[0];
        if (best) {
          const bestImg = best.media_type === 'VIDEO' ? (best.thumbnail_url || '') : (best.media_url || '');
          container.innerHTML += `<div class="bg-white rounded-2xl p-5 border border-[#D6CCC0] mt-4">
            <h3 class="text-sm font-medium text-[#2C2416] mb-3">🏆 Post du mois</h3>
            <a href="${best.permalink || '#'}" target="_blank" class="flex gap-3 items-center group">
              ${bestImg ? `<img src="${bestImg}" class="w-16 h-16 rounded-xl object-cover shrink-0 border border-[#D6CCC0]" />` : '<div class="w-16 h-16 rounded-xl bg-[#EDE6DB] shrink-0"></div>'}
              <div class="flex-1 min-w-0">
                <p class="text-xs text-[#767A55] mb-1.5">${new Date(best.timestamp || Date.now()).toLocaleDateString('fr-FR', {day:'2-digit',month:'long'})}</p>
                <div class="flex flex-wrap gap-2 text-xs font-semibold text-[#2C2416]">
                  <span>❤️ ${(best.like_count||0).toLocaleString('fr-FR')}</span>
                  <span>💬 ${(best.comments_count||0).toLocaleString('fr-FR')}</span>
                  ${best.reposts_count != null ? `<span><iconify-icon icon="ph:arrows-clockwise" class="align-middle"></iconify-icon> ${best.reposts_count}</span>` : ''}
                  ${best.saved_count != null ? `<span>🔖 ${best.saved_count}</span>` : ''}
                </div>
                ${best.caption ? `<p class="text-xs text-[#767A55] mt-1 line-clamp-2">${best.caption.slice(0,80)}</p>` : ''}
              </div>
              <iconify-icon icon="solar:arrow-right-up-linear" stroke-width="1.5" class="text-[#D6CCC0] group-hover:text-[#8B3E22] shrink-0 transition-colors"></iconify-icon>
            </a>
          </div>`;
        }

        // Courbes d'évolution
        const insightsRes  = await fetch(`/api/instagram-account-insights?clientId=${clientId}`);
        const insightsData = await insightsRes.json();

        const sparkline = (points, color = '#8B3E22') => {
          if (!points?.length) return '<p class="text-xs text-[#767A55]/50 italic">Données non disponibles</p>';
          const vals = points.map(p => p.value);
          const min = Math.min(...vals), max = Math.max(...vals), range = max - min || 1;
          const w = 300, h = 50;
          const pts = vals.map((v, i) => {
            const x = (i / (vals.length - 1 || 1)) * w;
            const y = h - ((v - min) / range) * (h - 4) - 2;
            return `${x.toFixed(1)},${y.toFixed(1)}`;
          }).join(' ');
          const last = vals[vals.length - 1];
          const prev = vals[vals.length - 2] ?? last;
          const trend = last > prev ? '▲' : last < prev ? '▼' : '—';
          const trendColor = last > prev ? 'text-green-600' : last < prev ? 'text-red-500' : 'text-[#767A55]';
          return `<div class="flex items-end justify-between mb-1"><span class="text-lg font-bold text-[#2C2416]">${last.toLocaleString('fr-FR')}</span><span class="text-xs font-semibold ${trendColor}">${trend} vs hier</span></div>
          <svg viewBox="0 0 ${w} ${h}" class="w-full h-12" preserveAspectRatio="none">
            <polyline points="${pts}" fill="none" stroke="${color}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <p class="text-[10px] text-[#767A55] mt-1">${points[0]?.date || ''} → ${points[points.length-1]?.date || ''}</p>`;
        };

        if (insightsData.reach?.length || insightsData.followers?.length || insightsData.impressions?.length) {
          container.innerHTML += `<div class="bg-white rounded-2xl p-5 border border-[#D6CCC0] mt-4">
            <h3 class="text-sm font-medium text-[#2C2416] mb-4">📈 Évolution — 30 derniers jours</h3>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              <div class="bg-[#F5EDE4] rounded-xl p-3">
                <p class="text-[10px] text-[#767A55] uppercase tracking-widest mb-2">Portée</p>
                ${sparkline(insightsData.reach, '#8B3E22')}
              </div>
              <div class="bg-[#F5EDE4] rounded-xl p-3">
                <p class="text-[10px] text-[#767A55] uppercase tracking-widest mb-2">Abonnés (variation)</p>
                ${sparkline(insightsData.followers, '#767A55')}
              </div>
              <div class="bg-[#F5EDE4] rounded-xl p-3">
                <p class="text-[10px] text-[#767A55] uppercase tracking-widest mb-2">Impressions</p>
                ${sparkline(insightsData.impressions, '#2C2416')}
              </div>
            </div>
          </div>`;
        }

      } catch(err) {
        container.innerHTML = `<div class="bg-white rounded-2xl p-8 border border-[#D6CCC0] text-center">
          <iconify-icon icon="mdi:instagram" class="text-5xl text-[#8B3E22]/30 mb-4 block"></iconify-icon>
          <h3 class="text-sm font-medium text-[#2C2416] mb-2">Compte Instagram non connecté</h3>
          <p class="text-xs text-[#767A55] mb-6">Connecte le compte Instagram Pro pour accéder aux statistiques.</p>
          <a href="/api/instagram-auth?clientId=${clientId}" class="inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-[#833ab4] via-[#fd1d1d] to-[#fcb045] text-white rounded-xl text-sm font-medium hover:opacity-90 transition-opacity">
            <iconify-icon icon="mdi:instagram" class="text-lg"></iconify-icon>
            Connecter Instagram
          </a>
        </div>`;
      }
    };

    // Sauvegarder infos client
    window.saveClientInfo = async (clientId) => {
      const sb  = await getSB();
      const msg = document.getElementById('ci-msg');
      const { error } = await sb.from('profiles').update({
        full_name:        document.getElementById('ci-name').value.trim(),
        phone:            document.getElementById('ci-phone').value.trim(),
        instagram_handle:  document.getElementById('ci-insta').value.trim().replace('@',''),
        instagram_password: document.getElementById('ci-ig-pwd').value,
        offer:             document.getElementById('ci-offer').value,
      }).eq('id', clientId);
      msg.className = `text-sm rounded-xl px-4 py-3 mb-3 ${error ? 'text-red-600 bg-red-50' : 'text-green-700 bg-green-50'}`;
      msg.textContent = error ? `Erreur : ${error.message}` : 'Informations mises à jour ✓';
      msg.classList.remove('hidden');
      setTimeout(() => msg.classList.add('hidden'), 3000);
    };

    // Programmer / publier un post sur Instagram
    window.publishToInstagram = async (contentItemId) => {
      const btn = document.querySelector(`button[onclick="publishToInstagram('${contentItemId}')"]`);
      if (btn) { btn.disabled = true; btn.textContent = 'Publication…'; }
      try {
        const res  = await fetch('/api/instagram-publish-post', {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({ contentItemId }),
        });
        const json = await res.json();
        if (json.error) {
          const detail = json.detail ? `\nCode: ${json.detail.code} · Type: ${json.detail.type}\n${json.detail.error_user_msg || ''}` : '';
          alert(`Erreur Meta : ${json.error}${detail}`);
          if (btn) { btn.disabled = false; btn.innerHTML = '<iconify-icon icon="mdi:instagram" class="text-base"></iconify-icon> Programmer'; }
        } else {
          const msg = json.scheduled ? 'Post programmé sur Instagram ✓' : 'Post publié sur Instagram ✓';
          alert(msg);
          await window.openClient(window._currentAdminClientId);
        }
      } catch(err) {
        alert(`Erreur : ${err.message}`);
        if (btn) { btn.disabled = false; btn.innerHTML = '<iconify-icon icon="mdi:instagram" class="text-base"></iconify-icon> Programmer'; }
      }
    };

    // Supprimer un fichier client (DB + Storage)
    window.deleteUpload = async (uploadId, fileUrl, clientId) => {
      if (!confirm('Supprimer ce fichier ? Cette action est irréversible.')) return;
      const sb = await getSB();
      // Extraire le path du fichier dans le bucket
      try {
        const url = new URL(fileUrl);
        const pathParts = url.pathname.split('/client-uploads/');
        if (pathParts[1]) {
          await sb.storage.from('client-uploads').remove([decodeURIComponent(pathParts[1])]);
        }
      } catch(e) {}
      await sb.from('client_uploads').delete().eq('id', uploadId);
      await window.openClient(clientId);
    };

    // Répondre à un contenu refusé (envoyer nouvelle version)
    window.replyToRefused = (contentId, clientId) => {
      const panel = document.getElementById('reply-' + contentId);
      if (panel) panel.classList.toggle('hidden');
    };

    window.sendReply = async (contentId, clientId) => {
      const sb      = await getSB();
      const type    = document.getElementById('reply-type-' + contentId).value;
      const caption = document.getElementById('reply-caption-' + contentId).value.trim();
      const file    = document.getElementById('reply-file-' + contentId).files?.[0];
      let fileUrl = '', fileName = '';
      if (file) {
        const path = `${clientId}/${Date.now()}-${file.name.replace(/[^a-zA-Z0-9._-]/g, '_')}`;
        const { data, error: uploadErr } = await sb.storage.from('content').upload(path, file);
        if (uploadErr) { alert('Erreur upload : ' + uploadErr.message); return; }
