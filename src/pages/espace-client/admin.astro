                    <a href="${d.file_url||'#'}" target="_blank" class="w-11 h-11 rounded-lg overflow-hidden shrink-0 border border-[#D6CCC0] hover:border-[#8B3E22] transition-colors flex items-center justify-center" style="background:#F5EDE4;min-width:44px">
