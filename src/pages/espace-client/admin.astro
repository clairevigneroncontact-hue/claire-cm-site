</option>${_mOpts}</select></div></div></div><div class="flex gap-2"><button onclick="saveContentEdit('${ct.id}','${clientId}')" class="flex-1 py-2 bg-[#8B3E22] text-white rounded-xl text-sm font-medium hover:bg-[#6B2E1A] transition-colors">Enregistrer</button><button onclick="document.getElementById('edit-${ct.id}').classList.add('hidden')" class="px-4 py-2 border border-[#D6CCC0] text-[#2C2416]/60 rounded-xl text-sm hover:bg-[#EDE6DB] transition-colors">Annuler</button></div></div>`;
        return `<div class="border ${ct.status === 'rejected' ? 'border-red-200' : 'border-[#D6CCC0]'} rounded-xl mb-3 overflow-hidden" data-search="${safeTitle.toLowerCase()}"><div class="flex hover:bg-[#F5EDE4]/20 transition-colors"><div onclick="toggleContentDetail('${ct.id}')" class="w-16 sm:w-24 md:w-32 shrink-0 overflow-hidden rounded-l-xl flex items-center justify-center cursor-pointer" style="background:${tHex}18;height:90px">${file0?.url?`<img src="${file0.url}" alt="visuel" style="width:100%;height:90px;object-fit:cover;display:block" onerror="this.style.display='none'" />`:`<iconify-icon icon="${tIcon}" stroke-width="1.5" style="color:${tHex};font-size:2rem"></iconify-icon>`}</div><div onclick="toggleContentDetail('${ct.id}')" class="flex-1 p-2 sm:p-4 min-w-0 cursor-pointer"><div class="flex items-start justify-between gap-2 mb-1.5"><div class="flex flex-wrap items-center gap-2 min-w-0">${typeTag}<p class="font-semibold text-[#2C2416] text-sm truncate">${cleanT}</p></div><div class="flex items-center gap-1 shrink-0 ml-1" onclick="event.stopPropagation()"><a href="${file0?.url||'#'}" target="${file0?.url?'_blank':'_self'}" onclick="${file0?.url?'event.stopPropagation()':`event.preventDefault();event.stopPropagation();toggleContentDetail('${ct.id}')`}" class="p-1.5 text-[#8B3E22] hover:bg-[#8B3E22]/10 rounded-lg transition-colors"><iconify-icon icon="solar:eye-linear" stroke-width="1.5" class="text-base"></iconify-icon></a>${statusBadge(ct.status, ct.id)}<button onclick="toggleContentDetail('${ct.id}')" class="p-1 text-[#767A55] hover:text-[#2C2416] rounded-lg transition-colors"><iconify-icon id="chevron-${ct.id}" icon="solar:alt-arrow-down-linear" stroke-width="1.5" class="transition-transform block"></iconify-icon></button></div></div>${shortDesc}<p class="text-xs text-[#767A55] mt-1.5">${schedDate}</p></div></div><div id="detail-${ct.id}" class="hidden border-t border-[#D6CCC0]/50 p-4">${fileBlock}${captionBlock}${feedbackBlock}<div class="flex gap-2 mt-3 flex-wrap"><button onclick="toggleEdit('${ct.id}')" class="px-4 py-2 border border-[#8B3E22] text-[#8B3E22] rounded-full text-xs font-medium hover:bg-[#8B3E22]/10 transition-colors">✏️ Modifier</button>${ct.status==='rejected'?`<button onclick="replyToRefused('${ct.id}','${clientId}')" class="px-4 py-2 border border-[#2C2416] text-[#2C2416] rounded-full text-xs font-medium hover:bg-[#EDE6DB] transition-colors">↩ Nouvelle version</button>`:''}${ct.status==='approved' && file0?.url ? (ct.ig_post_id ? `<span class="px-4 py-2 bg-green-50 text-green-700 border border-green-200 rounded-full text-xs font-medium flex items-center gap-1"><iconify-icon icon="mdi:instagram" class="text-base"></iconify-icon> Publié sur Instagram</span>` : `<button onclick="publishToInstagram('${ct.id}')" class="px-4 py-2 border border-purple-300 text-purple-700 rounded-full text-xs font-medium hover:bg-purple-50 transition-colors flex items-center gap-1"><iconify-icon icon="mdi:instagram" class="text-base"></iconify-icon> Programmer</button>`) : ''}<button onclick="deleteContent('${ct.id}','${file0?.url?file0.url.replace(/'/g,"\\'"):''}','${clientId}')" class="px-4 py-2 border border-red-300 text-red-500 rounded-full text-xs font-medium hover:bg-red-50 transition-colors">🗑 Supprimer</button></div>${editPanel}${replyPanel}</div></div>`;
