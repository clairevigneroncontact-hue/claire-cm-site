    async function loadClientCal() {
      const sb2 = await getSB();
      const cid = _clientCalClientId;
      if (!cid) return;
      const [{ data: allContent }, { data: notes }] = await Promise.all([
        sb2.from('content_items').select('id,title,status,description,scheduled_at,updated_at,files').eq('client_id', cid),
        sb2.from('calendar_notes').select('*').eq('client_id', cid),
