  // ─── Créneaux de publication ──────────────────────────────────────────────
  let _currentPostingPrefs = { slots: [] };
  let _prefSelectedDays = new Set();
  const _DAYS = ['','Lun','Mar','Mer','Jeu','Ven','Sam','Dim'];

  // Basculer un jour (plusieurs possibles simultanément)
  window.togglePrefDayMulti = (day) => {
    const btn = document.querySelector(`.pref-day-btn[data-day="${day}"]`);
    if (_prefSelectedDays.has(day)) {
      _prefSelectedDays.delete(day);
      btn?.classList.remove('bg-[#8B3E22]','border-[#8B3E22]','text-white');
      btn?.classList.add('border-[#D6CCC0]','text-[#2C2416]/50');
    } else {
      _prefSelectedDays.add(day);
      btn?.classList.add('bg-[#8B3E22]','border-[#8B3E22]','text-white');
      btn?.classList.remove('border-[#D6CCC0]','text-[#2C2416]/50');
    }
    const hint = document.getElementById('pref-add-hint');
    if (hint) hint.textContent = _prefSelectedDays.size
      ? `${[..._prefSelectedDays].sort().map(d=>_DAYS[d]).join(', ')} sélectionné(s)`
      : 'Sélectionne un ou plusieurs jours + heure';
  };

  // Ajouter des paires jour+heure
  window.addPrefSlot = () => {
    const hint = document.getElementById('pref-add-hint');
    const warn = (msg) => { if(hint) { hint.textContent = '⚠️ ' + msg; hint.classList.add('text-amber-600'); setTimeout(()=>{ hint.classList.remove('text-amber-600'); hint.textContent = 'Sélectionne un ou plusieurs jours + heure'; }, 2000); } };
    if (!_prefSelectedDays.size) { warn('Sélectionne au moins un jour'); return; }
    const h = document.getElementById('pref-hour')?.value;
    const m = document.getElementById('pref-min')?.value;
    if (!h || !m) { warn('Choisis une heure'); return; }
    const time = `${h}:${m}`;
    if (!_currentPostingPrefs.slots) _currentPostingPrefs.slots = [];
    let added = 0;
    _prefSelectedDays.forEach(day => {
      if (!_currentPostingPrefs.slots.some(s => s.day === day && s.time === time)) {
        _currentPostingPrefs.slots.push({ day, time });
        added++;
      }
    });
    _currentPostingPrefs.slots.sort((a,b) => a.day - b.day || a.time.localeCompare(b.time));
    _prefSelectedDays = new Set();
    document.querySelectorAll('.pref-day-btn').forEach(b => {
      b.classList.remove('bg-[#8B3E22]','border-[#8B3E22]','text-white');
      b.classList.add('border-[#D6CCC0]','text-[#2C2416]/50');
    });
    document.getElementById('pref-hour').value = '';
    document.getElementById('pref-min').value = '';
    if (hint) hint.textContent = added ? `${added} créneau(x) ajouté(s) ✓` : 'Ces créneaux existent déjà';
    renderPrefSlotsList();
  };

  // Supprimer un créneau par index
  window.removePrefSlot = (idx) => {
    (_currentPostingPrefs.slots || []).splice(idx, 1);
    _prefSelectedDays = new Set();
    renderPrefSlotsList();
  };

  // Mise à jour de la liste affichée + chips
  function renderPrefSlotsList() {
    const el = document.getElementById('pref-times-list');
    if (!el) return;
    const slots = _currentPostingPrefs.slots || [];
    el.innerHTML = slots.length
      ? `<div class="flex flex-wrap gap-1.5">${slots.map((s,i) => `<span class="flex items-center gap-1 bg-[#EDE6DB] text-[#2C2416] text-xs px-2.5 py-1 rounded-full font-medium">${_DAYS[s.day]} ${s.time}<button type="button" onclick="removePrefSlot(${i})" class="ml-1 text-[#767A55] hover:text-red-500 font-bold leading-none">×</button></span>`).join('')}</div>`
      : '<p class="text-xs text-[#2C2416]/30 italic">Aucun créneau — ajoutes-en ci-dessous</p>';
    renderPrefChips();
  }

  // Chips dans le formulaire d'envoi
  function renderPrefChips() {
    const slotsDiv = document.getElementById('ct-prefs-slots');
    const chipsDiv = document.getElementById('ct-prefs-chips');
    if (!slotsDiv || !chipsDiv) return;
    const slots = _currentPostingPrefs.slots || [];
    if (!slots.length) { slotsDiv.classList.add('hidden'); return; }
    chipsDiv.innerHTML = slots.map(s =>
      `<button type="button" onclick="applyPrefSlot(${s.day},'${s.time}')" class="bg-[#EDE6DB] hover:bg-[#8B3E22] hover:text-white text-[#2C2416] text-xs px-2.5 py-1.5 rounded-full transition-colors font-medium">${_DAYS[s.day]} ${s.time}</button>`
    ).join('');
    slotsDiv.classList.remove('hidden');
  }

  // Appliquer un créneau → remplir date+heure dans le formulaire
  window.applyPrefSlot = (dayISO, time) => {
    const [h, m] = time.split(':').map(Number);
    const now = new Date();
    const todayISO = now.getDay() === 0 ? 7 : now.getDay();
    let ahead = (dayISO - todayISO + 7) % 7;
    if (ahead === 0) { const t = new Date(now); t.setHours(h,m,0,0); if (t <= now) ahead = 7; }
    const result = new Date(now);
    result.setDate(result.getDate() + ahead);
    result.setHours(h, m, 0, 0);
    const dateInput = document.getElementById('ct-date');
    if (dateInput) dateInput.value = result.toISOString().slice(0,10);
    const hourSel = document.getElementById('ct-hour');
    const minSel  = document.getElementById('ct-min');
    if (hourSel) hourSel.value = String(h).padStart(2,'0');
    if (minSel)  minSel.value  = String(m).padStart(2,'0');
  };

