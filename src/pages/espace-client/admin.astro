---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Admin — Claire Vigneron" hideChatWidget={true}>

  <div id="loading" class="min-h-screen bg-[#2C2416] flex items-center justify-center">
    <p class="text-[#F5EDE4]/50 text-sm">Vérification…</p>
  </div>

  <div id="admin-panel" class="hidden min-h-screen bg-[#F5EDE4]">
    <header class="bg-[#2C2416] px-4 md:px-6 py-3 md:py-5 flex items-center justify-between gap-3 relative z-40">
      <a href="/" class="text-base md:text-xl font-serif text-[#F5EDE4] tracking-tight shrink-0">
        Claire Vigneron <span class="text-[#767A55]">·</span> CM
        <span class="text-[#8B3E22] text-xs ml-1 uppercase tracking-widest font-sans">Admin</span>
      </a>
      <div class="flex items-center gap-2 sm:gap-3">
        <button id="admin-bell-btn" class="relative w-9 h-9 sm:w-10 sm:h-10 rounded-xl border border-[#F5EDE4]/20 flex items-center justify-center text-[#F5EDE4]/70 hover:text-white hover:border-white/40 hover:bg-white/10 transition-colors shrink-0" title="Notifications">
          <iconify-icon icon="solar:bell-linear" stroke-width="1.5" class="text-lg sm:text-xl"></iconify-icon>
          <span id="admin-notif-badge" class="hidden absolute -top-1 -right-1 min-w-[18px] h-[18px] bg-[#8B3E22] text-white text-[10px] font-bold rounded-full flex items-center justify-center px-1 leading-none"></span>
        </button>
        <button id="admin-settings-btn" class="w-9 h-9 sm:w-10 sm:h-10 rounded-xl border border-[#F5EDE4]/20 flex items-center justify-center text-[#F5EDE4]/70 hover:text-white hover:border-white/40 hover:bg-white/10 transition-colors shrink-0" title="Paramètres">
          <iconify-icon icon="solar:settings-linear" stroke-width="1.5" class="text-lg sm:text-xl"></iconify-icon>
        </button>
        <button id="logout-btn" class="flex items-center gap-1.5 text-[#F5EDE4]/70 hover:text-white transition-colors px-2 sm:px-4 py-2 rounded-xl border border-[#F5EDE4]/20 hover:bg-white/10 shrink-0">
          <iconify-icon icon="solar:logout-3-linear" stroke-width="1.5" class="text-lg shrink-0"></iconify-icon>
          <span class="hidden sm:inline text-sm">Déconnexion</span>
        </button>
      </div>
    </header>

    <!-- Panel notifications flottant (cloche, mobile/tablette) -->
    <div id="admin-bell-float-panel" class="hidden fixed top-[76px] right-4 w-80 max-w-[calc(100vw-2rem)] bg-white rounded-2xl shadow-2xl border border-[#D6CCC0] z-50 overflow-hidden">
      <div class="px-4 py-3 bg-[#2C2416] flex items-center justify-between">
        <span class="text-sm font-semibold text-[#F5EDE4]">Notifications</span>
        <button onclick="clearAllImpNotifs()" class="text-xs text-[#F5EDE4]/50 hover:text-[#F5EDE4] transition-colors">Tout effacer</button>
      </div>
      <div id="admin-bell-float-list" class="max-h-80 overflow-y-auto divide-y divide-[#D6CCC0]/30">
        <p class="text-xs text-[#2C2416]/40 italic p-4 text-center">Aucune notification</p>
      </div>
    </div>

    <!-- Panel Paramètres admin -->
    <div id="admin-settings-overlay" class="hidden fixed inset-0 z-40 bg-[#2C2416]/40" onclick="toggleAdminSettings()"></div>
    <div id="admin-settings-panel" class="hidden fixed top-0 right-0 h-full w-full sm:w-96 bg-white z-50 shadow-2xl overflow-y-auto">
      <div class="bg-[#2C2416] px-6 py-5 flex items-center justify-between">
        <span class="text-base font-semibold text-[#F5EDE4]">Paramètres</span>
        <button onclick="toggleAdminSettings()" class="text-[#F5EDE4]/50 hover:text-white transition-colors">
          <iconify-icon icon="solar:close-circle-linear" stroke-width="1.5" class="text-xl"></iconify-icon>
        </button>
      </div>
      <div class="p-6 space-y-6">
        <!-- Mot de passe -->
        <div>
          <h2 class="text-sm font-semibold text-[#2C2416] uppercase tracking-widest mb-4">Changer le mot de passe</h2>
          <div class="space-y-3">
            <div>
              <label class="text-xs text-[#767A55] block mb-1">Nouveau mot de passe</label>
              <input id="admin-set-pwd1" type="password" class="w-full px-3 py-2.5 rounded-xl border border-[#D6CCC0] text-sm focus:outline-none focus:border-[#8B3E22] bg-white" placeholder="••••••••" />
            </div>
            <div>
              <label class="text-xs text-[#767A55] block mb-1">Confirmer</label>
              <input id="admin-set-pwd2" type="password" class="w-full px-3 py-2.5 rounded-xl border border-[#D6CCC0] text-sm focus:outline-none focus:border-[#8B3E22] bg-white" placeholder="••••••••" />
            </div>
          </div>
          <div id="admin-set-pwd-msg" class="hidden mt-3 text-sm rounded-xl px-4 py-2"></div>
          <button onclick="saveAdminPassword()" class="mt-4 w-full py-2.5 bg-[#2C2416] text-white rounded-xl text-sm font-medium hover:bg-[#8B3E22] transition-colors">Changer le mot de passe</button>
        </div>
        <!-- FAQ & Aide admin -->
        <div class="border-t border-[#D6CCC0] pt-6">
          <h2 class="text-sm font-semibold text-[#2C2416] uppercase tracking-widest mb-4">FAQ & Aide</h2>
          <a href="/espace-client/admin-faq" class="flex items-center justify-between bg-[#EDE6DB] rounded-2xl p-4 hover:bg-[#D6CCC0]/40 transition-colors group">
            <div class="flex items-center gap-3">
              <iconify-icon icon="solar:question-circle-linear" stroke-width="1.5" class="text-[#8B3E22] text-xl shrink-0"></iconify-icon>
              <div>
                <p class="text-sm font-medium text-[#2C2416]">Guide d'utilisation — Espace Admin</p>
                <p class="text-xs text-[#767A55] font-light mt-0.5">Créer un client, envoyer du contenu, calendrier, documents…</p>
              </div>
            </div>
            <iconify-icon icon="solar:arrow-right-linear" stroke-width="1.5" class="text-[#8B3E22] group-hover:translate-x-1 transition-transform shrink-0 ml-3"></iconify-icon>
          </a>
        </div>
      </div>
    </div>

    <main class="max-w-6xl mx-auto px-4 md:px-6 py-6 md:py-10">

      <!-- Vue liste clients -->
      <div id="view-list">
        <div class="mb-5 flex flex-col sm:flex-row sm:items-center justify-between gap-3">
          <div>
            <h1 class="text-2xl md:text-3xl text-[#2C2416] tracking-tight">Vue admin</h1>
            <p class="text-[#767A55] text-sm mt-1 font-light">Accès à tous les espaces clients</p>
          </div>
          <button id="new-client-btn" class="self-start sm:self-auto flex items-center gap-1.5 px-3 py-2 sm:px-5 sm:py-2.5 bg-[#8B3E22] text-[#F5EDE4] rounded-full text-sm font-medium hover:bg-[#6B2E1A] transition-colors">
            <iconify-icon icon="solar:user-plus-linear" stroke-width="1.5" class="text-base shrink-0"></iconify-icon>
            <span class="hidden sm:inline">Nouveau client</span>
            <span class="sm:hidden">Nouveau</span>
          </button>
        </div>


        <!-- Formulaire nouveau client -->
        <div id="new-client-form" class="hidden bg-white rounded-2xl p-6 border border-[#D6CCC0] mb-6">
          <h2 class="text-lg text-[#2C2416] mb-2 font-medium">Créer un espace client</h2>
          <p class="text-xs text-[#767A55] mb-4">Le client recevra un email pour définir son mot de passe.</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-4">
            <input id="nc-email"     type="email" placeholder="Email *"       class="px-4 py-3 rounded-xl border border-[#D6CCC0] text-sm focus:outline-none focus:border-[#8B3E22]" />
            <input id="nc-name"      type="text"  placeholder="Nom complet"   class="px-4 py-3 rounded-xl border border-[#D6CCC0] text-sm focus:outline-none focus:border-[#8B3E22]" />
            <input id="nc-instagram" type="text" data-no-spellcheck placeholder="@instagram"    class="px-4 py-3 rounded-xl border border-[#D6CCC0] text-sm focus:outline-none focus:border-[#8B3E22]" />
            <input id="nc-phone"     type="tel"   placeholder="Téléphone"     class="px-4 py-3 rounded-xl border border-[#D6CCC0] text-sm focus:outline-none focus:border-[#8B3E22]" />
            <select id="nc-offer" class="px-4 py-3 rounded-xl border border-[#D6CCC0] text-sm focus:outline-none focus:border-[#8B3E22] bg-white">
              <option value="">Choisir l'offre…</option>
              <option value="audit">Audit Instagram — 97 €</option>
              <option value="pack">Pack Contenu — 320 €</option>
              <option value="mensuel">Accompagnement Mensuel — 550 €/mois</option>
            </select>
          </div>
          <div id="nc-msg" class="hidden text-sm rounded-xl px-4 py-3 mb-3"></div>
          <div class="flex gap-3">
            <button id="nc-submit" class="px-5 py-2.5 bg-[#8B3E22] text-[#F5EDE4] rounded-full text-sm font-medium hover:bg-[#6B2E1A] transition-colors">Créer l'espace</button>
            <button id="nc-cancel" class="px-5 py-2.5 border border-[#D6CCC0] text-[#2C2416]/60 rounded-full text-sm hover:bg-[#EDE6DB] transition-colors">Annuler</button>
          </div>
        </div>

        <!-- Layout 2 colonnes -->
        <div class="flex flex-col xl:flex-row gap-6 items-start">

          <!-- Colonne gauche : liste clients -->
          <div class="flex-1 min-w-0">
            <div id="mtab-clients-panel">
              <!-- Barre de recherche -->
              <div class="relative mb-4">
                <iconify-icon icon="solar:magnifer-linear" stroke-width="1.5" class="absolute left-4 top-1/2 -translate-y-1/2 text-[#767A55] text-lg pointer-events-none"></iconify-icon>
                <input id="client-search" type="text" data-no-spellcheck placeholder="Rechercher un client par nom, email ou Instagram…"
                  class="w-full pl-11 pr-4 py-3 rounded-xl border border-[#D6CCC0] bg-white text-sm text-[#2C2416] focus:outline-none focus:border-[#8B3E22] transition-colors" />
              </div>
              <div class="flex items-center justify-between mb-3">
                <p id="clients-count" class="text-sm text-[#2C2416]/50 font-light"></p>
                <button id="refresh-btn" class="flex items-center gap-2 text-sm text-[#767A55] hover:text-[#8B3E22] transition-colors">
                  <iconify-icon icon="solar:refresh-linear" stroke-width="1.5"></iconify-icon>Actualiser
                </button>
              </div>
              <div id="clients-list" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-1 gap-3">
                <p class="text-sm text-[#2C2416]/40 italic col-span-full">Chargement des clients…</p>
              </div>
            </div>
          </div>

          <!-- Colonne droite : notifications importantes (masquée sur mobile — accès via la cloche) -->
          <div class="xl:w-80 w-full shrink-0 hidden xl:block">
            <div class="bg-white rounded-2xl border border-[#D6CCC0] overflow-hidden sticky top-6">
              <div class="px-4 py-3 bg-[#2C2416] flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <iconify-icon icon="solar:bell-bing-linear" stroke-width="1.5" class="text-[#8B3E22] text-lg"></iconify-icon>
                  <span class="text-sm font-semibold text-[#F5EDE4]">Notifications</span>
                  <span id="imp-notif-count" class="hidden min-w-[18px] h-[18px] bg-[#8B3E22] rounded-full text-[10px] text-white flex items-center justify-center font-bold px-1 leading-none"></span>
                </div>
                <button onclick="clearAllImpNotifs()" class="text-xs text-[#F5EDE4]/50 hover:text-[#F5EDE4] transition-colors">Tout effacer</button>
              </div>
              <div id="imp-notif-list" class="max-h-[70vh] overflow-y-auto divide-y divide-[#D6CCC0]/30">
                <p class="text-xs text-[#2C2416]/40 italic p-4 text-center">Aucune notification</p>
              </div>
            </div>
          </div>

        </div>

      </div>

      <!-- Vue client sélectionné -->
      <div id="view-client" class="hidden">
        <button id="back-btn" class="inline-flex items-center gap-2 text-sm text-[#767A55] hover:text-[#8B3E22] transition-colors mb-6">
          <iconify-icon icon="solar:arrow-left-linear" stroke-width="1.5"></iconify-icon> Retour à la liste
        </button>
        <div id="client-detail"></div>
      </div>
    </main>

    <!-- Overlay fermeture bulle discussion admin -->
    <div id="admin-discussion-overlay" class="hidden fixed inset-0 z-[38]" onclick="document.getElementById('admin-discussion-panel').classList.add('hidden'); document.getElementById('admin-discussion-overlay').classList.add('hidden')"></div>

    <!-- Bulle discussion flottante admin (visible quand un client est ouvert) -->
    <div id="admin-discussion-widget" class="hidden fixed bottom-6 right-6 z-40">
      <!-- Panel -->
      <div id="admin-discussion-panel" class="hidden absolute bottom-16 right-0 bg-[#2C2416] rounded-2xl overflow-hidden shadow-2xl border border-white/10" style="width:min(360px,calc(100vw - 1.5rem));max-height:520px">
        <div class="flex items-center justify-between px-4 py-3 border-b border-white/10">
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 bg-[#8B3E22] rounded-xl flex items-center justify-center shrink-0">
              <iconify-icon icon="solar:chat-round-dots-linear" stroke-width="1.5" class="text-white text-sm"></iconify-icon>
            </div>
            <span id="admin-discussion-title" class="text-sm font-medium text-[#F5EDE4]">Discussion</span>
          </div>
          <button onclick="toggleAdminDiscussion()" class="text-[#F5EDE4]/50 hover:text-white transition-colors p-1">
            <iconify-icon icon="solar:close-circle-linear" stroke-width="1.5" class="text-xl"></iconify-icon>
          </button>
        </div>
        <div id="admin-client-notes-feed" class="overflow-y-auto px-4 py-3 space-y-2" style="height:290px">
          <p class="text-xs text-[#F5EDE4]/40 italic text-center pt-4">Chargement…</p>
        </div>
        <!-- Templates rapides -->
        <div id="admin-templates-panel" class="hidden px-4 py-2 border-t border-white/10 max-h-40 overflow-y-auto">
          <div id="admin-templates-list" class="space-y-1">
            <p class="text-xs text-[#F5EDE4]/40 italic">Chargement…</p>
          </div>
        </div>
        <div class="flex gap-2 items-end px-4 py-3 border-t border-white/10">
          <button type="button" onclick="toggleAdminTemplates()" class="text-sm p-1.5 text-[#F5EDE4]/50 hover:text-[#F5EDE4] transition-colors shrink-0" title="Templates">📋</button>
          <textarea spellcheck="true" id="admin-reply-input" rows="2" placeholder="Message…"
            class="flex-1 px-3 py-2 rounded-xl border border-white/20 bg-white/10 text-[#F5EDE4] text-sm placeholder-[#F5EDE4]/40 resize-none focus:outline-none focus:border-[#8B3E22]"></textarea>
          <button data-emoji-btn type="button" onclick="toggleEmojiPicker(this,'admin-reply-input')" class="text-xl p-1.5 text-[#F5EDE4]/50 hover:text-[#F5EDE4] transition-colors shrink-0" title="Emoji">😊</button>
          <button id="admin-send-btn" onclick="sendAdminNote(window._currentAdminClientId)" class="px-4 py-2 bg-[#8B3E22] text-white rounded-xl text-sm font-medium hover:bg-[#6B2E1A] transition-colors shrink-0">Envoyer</button>
        </div>
      </div>
      <!-- Bouton bulle -->
      <button onclick="toggleAdminDiscussion()" class="w-14 h-14 bg-[#8B3E22] rounded-full shadow-xl flex items-center justify-center text-white hover:bg-[#6B2E1A] transition-all hover:scale-105 relative">
        <iconify-icon icon="solar:chat-round-dots-bold" class="text-2xl"></iconify-icon>
        <span id="admin-discussion-badge" class="hidden absolute -top-1 -right-1 min-w-[18px] h-[18px] bg-red-500 rounded-full text-[10px] text-white font-bold flex items-center justify-center px-1 leading-none"></span>
      </button>
    </div>

  </div>

  <!-- Modal éditeur de bilan mensuel -->
  <div id="bilan-overlay" class="hidden fixed inset-0 z-[198] bg-black/40" onclick="closeBilanModal()"></div>
  <div id="bilan-modal" class="hidden fixed inset-x-0 bottom-0 z-[199] bg-white rounded-t-2xl shadow-2xl" style="max-height:92vh;overflow-y:auto;padding-bottom:max(1.5rem,env(safe-area-inset-bottom))">
    <div class="sticky top-0 bg-white z-10 px-5 pt-4 pb-3 border-b border-[#D6CCC0] flex items-center justify-between">
      <div class="flex items-center gap-2">
        <iconify-icon icon="solar:chart-2-linear" stroke-width="1.5" class="text-[#8B3E22] text-xl"></iconify-icon>
        <p class="text-sm font-semibold text-[#2C2416]">Éditer le bilan mensuel</p>
      </div>
      <button onclick="closeBilanModal()" class="w-7 h-7 flex items-center justify-center rounded-full text-[#767A55] hover:bg-[#EDE6DB] transition-colors text-base">×</button>
    </div>

    <div class="px-5 py-4 space-y-4">
      <!-- Mois + Année -->
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="text-xs text-[#767A55] block mb-1.5">Mois</label>
          <select id="bilan-month" class="w-full px-3 py-2.5 rounded-xl border border-[#D6CCC0] text-sm focus:outline-none focus:border-[#8B3E22] bg-white">
            <option value="janvier">Janvier</option><option value="février">Février</option>
            <option value="mars">Mars</option><option value="avril">Avril</option>
            <option value="mai">Mai</option><option value="juin">Juin</option>
            <option value="juillet">Juillet</option><option value="août">Août</option>
            <option value="septembre">Septembre</option><option value="octobre">Octobre</option>
            <option value="novembre">Novembre</option><option value="décembre">Décembre</option>
          </select>
        </div>
        <div>
          <label class="text-xs text-[#767A55] block mb-1.5">Année</label>
          <input id="bilan-year" type="number" class="w-full px-3 py-2.5 rounded-xl border border-[#D6CCC0] text-sm focus:outline-none focus:border-[#8B3E22] bg-white" />
        </div>
      </div>

      <!-- Statistiques -->
      <div>
        <p class="text-xs text-[#767A55] uppercase tracking-widest mb-3">Statistiques du mois</p>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="text-xs text-[#767A55] block mb-1.5">Contenus publiés</label>
            <input id="bilan-contenus" type="text" placeholder="ex : 12" class="w-full px-3 py-2.5 rounded-xl border border-[#D6CCC0] text-sm focus:outline-none focus:border-[#8B3E22] bg-white" />
          </div>
          <div>
            <label class="text-xs text-[#767A55] block mb-1.5">Nouveaux abonnés</label>
            <input id="bilan-abonnes" type="text" placeholder="ex : +47" class="w-full px-3 py-2.5 rounded-xl border border-[#D6CCC0] text-sm focus:outline-none focus:border-[#8B3E22] bg-white" />
          </div>
          <div>
            <label class="text-xs text-[#767A55] block mb-1.5">Portée moyenne</label>
            <input id="bilan-portee" type="text" placeholder="ex : 1 240" class="w-full px-3 py-2.5 rounded-xl border border-[#D6CCC0] text-sm focus:outline-none focus:border-[#8B3E22] bg-white" />
          </div>
          <div>
            <label class="text-xs text-[#767A55] block mb-1.5">Engagement moyen</label>
            <input id="bilan-engagement" type="text" placeholder="ex : 4,2 %" class="w-full px-3 py-2.5 rounded-xl border border-[#D6CCC0] text-sm focus:outline-none focus:border-[#8B3E22] bg-white" />
          </div>
        </div>
      </div>

      <!-- Highlights / message perso -->
      <div>
        <label class="text-xs text-[#767A55] block mb-1.5">Points forts du mois (optionnel)</label>
        <textarea spellcheck="true" id="bilan-highlights" rows="3" placeholder="ex : Le reel sur l'atelier a bien performé, on continue sur ce format en juin…"
          class="w-full px-3 py-2.5 rounded-xl border border-[#D6CCC0] text-sm focus:outline-none focus:border-[#8B3E22] resize-none bg-white"></textarea>
      </div>

      <!-- Prochain mois -->
      <div>
        <label class="text-xs text-[#767A55] block mb-1.5">Orientations pour le mois prochain (optionnel)</label>
        <textarea spellcheck="true" id="bilan-next" rows="2" placeholder="ex : Focus sur les reels, objectif +50 abonnés…"
          class="w-full px-3 py-2.5 rounded-xl border border-[#D6CCC0] text-sm focus:outline-none focus:border-[#8B3E22] resize-none bg-white"></textarea>
      </div>

      <div id="bilan-send-msg" class="hidden text-sm rounded-xl px-4 py-2.5"></div>

      <div class="flex gap-2 pt-1">
        <button onclick="sendBilanFromModal()" class="flex-1 py-3 bg-[#8B3E22] text-white rounded-xl text-sm font-semibold hover:bg-[#6B2E1A] transition-colors flex items-center justify-center gap-2">
          <iconify-icon icon="solar:letter-linear" stroke-width="1.5"></iconify-icon>
          Envoyer le bilan
        </button>
        <button onclick="closeBilanModal()" class="px-5 py-3 border border-[#D6CCC0] text-[#2C2416]/60 rounded-xl text-sm hover:bg-[#EDE6DB] transition-colors">Annuler</button>
      </div>
    </div>
  </div>

</BaseLayout>

<script is:inline>
  const SUPABASE_URL = 'https://etubpowlffhdvnfqkjij.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_AyehSGHv6TEwFvPQIuMivg_-_mJ7zUH';
  const ADMIN_EMAIL  = 'clairevigneron.contact@gmail.com';
  const OFFER_MAP    = { audit: 'Audit', pack: 'Pack Contenu', mensuel: 'Accompagnement' };

  function loadScript(src) {
    return new Promise(resolve => {
      if (document.querySelector(`script[src="${src}"]`)) return resolve();
      const s = document.createElement('script'); s.src = src; s.onload = resolve; document.head.appendChild(s);
    });
  }

  async function getSB() {
    if (!window._sb) {
      await loadScript('https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.js');
      window._sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
    }
    return window._sb;
  }

  window.addEventListener('load', async () => {
    const sb = await getSB();
    const { data: { session } } = await sb.auth.getSession();
    if (!session || session.user.email !== ADMIN_EMAIL) { window.location.href = '/espace-client'; return; }

    document.getElementById('loading').classList.add('hidden');
    document.getElementById('admin-panel').classList.remove('hidden');

    document.getElementById('logout-btn').onclick = async () => { await sb.auth.signOut(); window.location.href = '/espace-client'; };

    // ===== Notifications admin =====
    const NOTIFS_KEY = 'adminNotifsLastSeen';
    const NOTIFS_DISMISSED_KEY = 'adminNotifsDismissed';

    function showAdminToast(message) {
      const t = document.createElement('div');
      t.className = 'fixed bottom-6 left-6 z-[999] bg-[#2C2416] text-[#F5EDE4] text-sm px-4 py-3 rounded-xl shadow-lg flex items-center gap-2';
      t.textContent = message;
      document.body.appendChild(t);
      setTimeout(() => t.remove(), 4000);
    }

    async function loadAdminNotifs() {
      const sb2  = await getSB();
      const since    = new Date(Date.now() - 14 * 24 * 3600 * 1000).toISOString();
      const lastSeen = localStorage.getItem(NOTIFS_KEY) || '1970-01-01';

      const [{ data: contentEvents }, { data: uploads }, { data: newClients }, { data: newMessages }] = await Promise.all([
        sb2.from('content_items')
          .select('id, title, status, updated_at, client_id, profiles(full_name, email)')
          .in('status', ['approved', 'rejected'])
          .gte('updated_at', since)
          .order('updated_at', { ascending: false })
          .limit(20),
        sb2.from('client_uploads')
          .select('id, file_url, created_at, client_id, profiles(full_name, email)')
          .gte('created_at', since)
          .order('created_at', { ascending: false })
          .limit(10),
        sb2.from('profiles')
          .select('id, full_name, email, created_at')
          .eq('role', 'client')
          .gte('created_at', since)
          .order('created_at', { ascending: false })
          .limit(5),
        sb2.from('client_notes')
          .select('id, note, created_at, client_id, from_admin, profiles(full_name, email)')
          .eq('from_admin', false)
          .gte('created_at', since)
          .order('created_at', { ascending: false })
          .limit(20),
      ]);

      const items = [];
      (contentEvents || []).forEach(e => {
        const client = e.profiles?.full_name || e.profiles?.email || 'Client';
        items.push({ id:'c-'+e.id, date:e.updated_at, unread:e.updated_at>lastSeen,
          icon: e.status==='approved' ? '✅' : '❌',
          text: e.status==='approved' ? `${client} a validé "${e.title}"` : `${client} a refusé "${e.title}"`,
          clientId:e.client_id, tab:'contenu' });
      });
      (uploads || []).forEach(u => {
        const client = u.profiles?.full_name || u.profiles?.email || 'Client';
        const uName = (() => { try { return decodeURIComponent((u.file_url||'').split('/').pop().replace(/^\d+-/,'')) || 'fichier'; } catch(e) { return 'fichier'; } })();
        items.push({ id:'u-'+u.id, date:u.created_at, unread:u.created_at>lastSeen,
          icon:'📎', text:`${client} a déposé "${uName}"`, clientId:u.client_id, tab:'fichiers' });
      });
      (newClients || []).forEach(nc => {
        items.push({ id:'nc-'+nc.id, date:nc.created_at, unread:nc.created_at>lastSeen,
          icon:'👤', text:`Nouveau client : ${nc.full_name||nc.email}`, clientId:nc.id, tab:'infos' });
      });
      (newMessages || []).forEach(m => {
        const client = m.profiles?.full_name || m.profiles?.email || 'Client';
        const preview = (m.note||'').slice(0,40) + ((m.note||'').length > 40 ? '…' : '');
        items.push({ id:'msg-'+m.id, date:m.created_at, unread:m.created_at>lastSeen,
          icon:'💬', text:`${client} : "${preview}"`, clientId:m.client_id, tab:'notes' });
      });
      items.sort((a,b) => b.date.localeCompare(a.date));

      window._lastAdminNotifItems = items;
      renderImpNotifs(items);

      // Backup : détecter l'activité non encore acquittée (sans limite de temps)
      if (allClients.length) {
        const latestByClient = {};
        items.forEach(n => {
          if (n.clientId && (!latestByClient[n.clientId] || n.date > latestByClient[n.clientId])) latestByClient[n.clientId] = n.date;
        });
        const acks = getAcks();
        let changed = false;
        Object.entries(latestByClient).forEach(([cid, date]) => {
          const ackedAt = acks[cid] || '0';
          if (date > ackedAt && !_activeQueue.includes(cid)) {
            _recentActivity[cid] = Date.parse(date);
            _activeQueue = [..._activeQueue, cid];
            changed = true;
          }
        });
        if (changed) sortAndRenderClients();
      }
    }

    function dismissNotifRow(id) {
      const row = document.querySelector(`[data-admin-notif-id="${id}"]`);
      if (!row) return;
      row.classList.remove('bg-[#8B3E22]/10');
      row.classList.add('bg-white');
      const btn = row.querySelector('[data-admin-checkbox]');
      if (btn) {
        btn.className = 'shrink-0 w-5 h-5 rounded-md border-2 flex items-center justify-center transition-colors ml-1 border-[#D6CCC0] bg-[#F5EDE4]';
        btn.innerHTML = '<iconify-icon icon="solar:check-linear" stroke-width="2.5" style="font-size:9px;color:#8B3E22"></iconify-icon>';
      }
      const txt = row.querySelector('[data-admin-notif-text]');
      if (txt) txt.classList.remove('font-medium');
    }

    window.dismissNotif = (id) => {
      dismissNotifRow(id);
      const dismissed = new Set(JSON.parse(localStorage.getItem(NOTIFS_DISMISSED_KEY)||'[]'));
      dismissed.add(id);
      localStorage.setItem(NOTIFS_DISMISSED_KEY, JSON.stringify([...dismissed]));
    };

    window.markAdminNotifsRead = () => {
      document.querySelectorAll('[data-admin-notif-id]').forEach(row => dismissNotifRow(row.dataset.adminNotifId));
      localStorage.setItem(NOTIFS_KEY, new Date().toISOString());
    };

    window.toggleAdminNotifPanel = () => {}; // conservé pour compatibilité (plus de cloche)

    // ─── Panel Paramètres admin ───────────────────────────────────────────────
    window.toggleAdminSettings = () => {
      const panel   = document.getElementById('admin-settings-panel');
      const overlay = document.getElementById('admin-settings-overlay');
      if (!panel) return;
      const isOpen = !panel.classList.contains('hidden');
      panel.classList.toggle('hidden');
      overlay.classList.toggle('hidden', isOpen);
    };

    document.getElementById('admin-settings-btn').onclick = () => window.toggleAdminSettings();

    window.saveAdminPassword = async () => {
      const sb2 = await getSB();
      const msg  = document.getElementById('admin-set-pwd-msg');
      const pwd1 = document.getElementById('admin-set-pwd1').value;
      const pwd2 = document.getElementById('admin-set-pwd2').value;
      if (!pwd1 || pwd1.length < 6) {
        msg.className = 'mt-3 text-sm rounded-xl px-4 py-2 bg-red-50 text-red-600';
        msg.textContent = 'Le mot de passe doit faire au moins 6 caractères.';
        msg.classList.remove('hidden'); return;
      }
      if (pwd1 !== pwd2) {
        msg.className = 'mt-3 text-sm rounded-xl px-4 py-2 bg-red-50 text-red-600';
        msg.textContent = 'Les mots de passe ne correspondent pas.';
        msg.classList.remove('hidden'); return;
      }
      const { error } = await sb2.auth.updateUser({ password: pwd1 });
      msg.className = `mt-3 text-sm rounded-xl px-4 py-2 ${error ? 'bg-red-50 text-red-600' : 'bg-green-50 text-green-700'}`;
      msg.textContent = error ? `Erreur : ${error.message}` : 'Mot de passe modifié ✓';
      msg.classList.remove('hidden');
      if (!error) { document.getElementById('admin-set-pwd1').value = ''; document.getElementById('admin-set-pwd2').value = ''; }
      setTimeout(() => msg.classList.add('hidden'), 4000);
    };

    loadAdminNotifs();
    setInterval(loadAdminNotifs, 60000);

    // ─── Panel notifications importantes ─────────────────────────────────────
    const IMP_DISMISSED_KEY = 'impNotifsDismissed';

    function renderImpNotifs(items) {
      const dismissed = new Set(JSON.parse(localStorage.getItem(IMP_DISMISSED_KEY)||'[]'));
      const visible = items.filter(n => !dismissed.has(n.id));
      const list  = document.getElementById('imp-notif-list');
      const badge = document.getElementById('imp-notif-count');
      if (!list) return;

      if (badge) {
        badge.textContent = visible.length > 9 ? '9+' : String(visible.length);
        badge.classList.toggle('hidden', visible.length === 0);
        badge.classList.toggle('flex', visible.length > 0);
      }

      if (!visible.length) {
        const empty = '<p class="text-xs text-[#2C2416]/40 italic p-4 text-center">Aucune notification</p>';
        list.innerHTML = empty;
        const floatListE = document.getElementById('admin-bell-float-list');
        if (floatListE) floatListE.innerHTML = empty;
        updateImpBadge();
        return;
      }

      const rowsHtml = visible.map(item => {
        const when = new Date(item.date).toLocaleDateString('fr-FR', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' });
        const bg   = item.unread ? 'bg-[#8B3E22]/5' : 'bg-white';
        const tab  = item.tab === 'fichiers' ? 'documents' : (item.tab || 'contenu');
        return `<div data-imp-notif="${item.id}" data-client="${item.clientId}" data-tab="${tab}"
          class="relative overflow-hidden ${bg} cursor-pointer hover:bg-[#F5EDE4] transition-colors"
          style="transform:translateX(0);transition:transform 0.3s ease,opacity 0.3s ease"
          onclick="dismissAndNavigate('${item.id}','${item.clientId}','${tab}')">
          <div class="flex items-start gap-3 px-4 py-3">
            <span class="text-xl shrink-0 mt-0.5 select-none">${item.icon}</span>
            <div class="flex-1 min-w-0">
              <p class="text-xs text-[#2C2416] leading-relaxed ${item.unread?'font-medium':''}">${item.text}</p>
              <p class="text-[10px] text-[#767A55] mt-0.5">${when}</p>
            </div>
            <button onclick="event.stopPropagation(); dismissImpNotif('${item.id}')" title="Supprimer"
              class="shrink-0 w-6 h-6 rounded-lg flex items-center justify-center transition-colors text-[#D6CCC0] hover:text-[#8B3E22] hover:bg-[#8B3E22]/10">
              <iconify-icon icon="solar:close-circle-linear" stroke-width="1.5" style="font-size:14px"></iconify-icon>
            </button>
          </div>
        </div>`;
      }).join('');

      list.innerHTML = rowsHtml;

      // Synchroniser le panel flottant (cloche) — même HTML
      const floatList = document.getElementById('admin-bell-float-list');
      if (floatList) floatList.innerHTML = rowsHtml;

      // Swipe to dismiss — les deux panels
      function addSwipe(container) {
        if (!container) return;
        container.querySelectorAll('[data-imp-notif]').forEach(row => {
          let startX = 0, startY = 0, didSwipe = false;
          row.addEventListener('touchstart', e => {
            startX = e.touches[0].clientX;
            startY = e.touches[0].clientY;
            didSwipe = false;
          }, { passive: true });
          row.addEventListener('touchmove', e => {
            const dx = e.touches[0].clientX - startX;
            const dy = e.touches[0].clientY - startY;
            // Swipe horizontal dominant
            if (Math.abs(dx) > Math.abs(dy) && dx < -20) {
              row.style.transform = `translateX(${Math.min(0, dx)}px)`;
              row.style.opacity = String(Math.max(0, 1 + dx / 150));
            }
          }, { passive: true });
          row.addEventListener('touchend', e => {
            const dx = e.changedTouches[0].clientX - startX;
            const dy = e.changedTouches[0].clientY - startY;
            if (Math.abs(dx) > Math.abs(dy) && dx < -60) {
              didSwipe = true;
              row.style.transform = 'translateX(-100%)';
              row.style.opacity = '0';
              setTimeout(() => dismissImpNotif(row.dataset.impNotif), 280);
            } else {
              row.style.transform = '';
              row.style.opacity = '';
            }
          }, { passive: true });
          row.addEventListener('click', e => {
            if (didSwipe) { e.stopPropagation(); didSwipe = false; }
          }, true);
        });
      }
      addSwipe(list);
      addSwipe(floatList);

      // Mettre à jour les badges
      updateImpBadge();
    }

    window.dismissAndNavigate = (id, clientId, tab) => {
      dismissImpNotif(id);  // supprime des deux panels + badge
      if (clientId) {
        window.openClient(clientId);
        setTimeout(() => window.switchClientTab(tab || 'contenu'), 600);
      }
    };

    // Sync dismissals Supabase → localStorage au démarrage (cross-appareils)
    async function syncDismissedFromDB() {
      try {
        const sb2 = await getSB();
        const { data: { user } } = await sb2.auth.getUser();
        if (!user) return;
        const { data } = await sb2.from('profiles').select('dismissed_notifs').eq('id', user.id).single();
        if (data?.dismissed_notifs?.length) {
          const local   = new Set(JSON.parse(localStorage.getItem(IMP_DISMISSED_KEY)||'[]'));
          const remote  = new Set(data.dismissed_notifs);
          const merged  = new Set([...local, ...remote]);
          localStorage.setItem(IMP_DISMISSED_KEY, JSON.stringify([...merged]));
        }
      } catch(e) {}
    }
    syncDismissedFromDB().then(() => {
      if (window._lastAdminNotifItems) renderImpNotifs(window._lastAdminNotifItems);
    });

    async function _saveDismissedToDB(ids) {
      try {
        const sb2 = await getSB();
        const { data: { user } } = await sb2.auth.getUser();
        if (user) await sb2.from('profiles').update({ dismissed_notifs: [...ids] }).eq('id', user.id);
      } catch(e) {}
    }

    window.dismissImpNotif = (id) => {
      const dismissed = new Set(JSON.parse(localStorage.getItem(IMP_DISMISSED_KEY)||'[]'));
      dismissed.add(id);
      localStorage.setItem(IMP_DISMISSED_KEY, JSON.stringify([...dismissed]));
      _saveDismissedToDB(dismissed);
      if (window._lastAdminNotifItems) renderImpNotifs(window._lastAdminNotifItems);
    };
    window.clearAllImpNotifs = () => {
      if (window._lastAdminNotifItems) {
        const d = new Set(JSON.parse(localStorage.getItem(IMP_DISMISSED_KEY)||'[]'));
        window._lastAdminNotifItems.forEach(n => d.add(n.id));
        localStorage.setItem(IMP_DISMISSED_KEY, JSON.stringify([...d]));
        _saveDismissedToDB(d);
        renderImpNotifs(window._lastAdminNotifItems);
      }
    };
    function updateImpBadge() {
      // Compter uniquement depuis imp-notif-list (source de vérité, pas le panel flottant)
      const remaining = document.getElementById('imp-notif-list')?.querySelectorAll('[data-imp-notif]').length || 0;
      const badge = document.getElementById('imp-notif-count');
      if (badge) { badge.textContent = String(remaining); badge.classList.toggle('hidden', remaining === 0); badge.classList.toggle('flex', remaining > 0); }
      // Synchroniser le badge de la cloche
      const bellBadge = document.getElementById('admin-notif-badge');
      if (bellBadge) { bellBadge.textContent = String(remaining); bellBadge.classList.toggle('hidden', remaining === 0); bellBadge.classList.toggle('flex', remaining > 0); }
    }
    window.openClientFromNotif = (clientId, tab) => {
      window.openClient(clientId);
      setTimeout(() => window.switchClientTab(tab||'contenu'), 600);
    };

    // ─── Cloche : panel flottant fusionné avec le panel droit ────────────────
    document.getElementById('admin-bell-btn').onclick = (e) => {
      e.stopPropagation();
      const fp = document.getElementById('admin-bell-float-panel');
      if (!fp) return;
      fp.classList.toggle('hidden');
      if (!fp.classList.contains('hidden') && window._lastAdminNotifItems) renderImpNotifs(window._lastAdminNotifItems);
    };
    document.addEventListener('click', (e) => {
      const fp   = document.getElementById('admin-bell-float-panel');
      const bell = document.getElementById('admin-bell-btn');
      if (fp && !fp.contains(e.target) && bell && !bell.contains(e.target)) fp.classList.add('hidden');
    });
    // renderImpNotifs est appelé directement depuis loadAdminNotifs (via _lastAdminNotifItems)

    // ─── Suivi activité clients (temps réel) ──────────────────────────────────
    const ACK_KEY         = 'adminClientAck';  // localStorage : { clientId → ISO date dernier clic admin }
    const _recentActivity = {};                // clientId → timestamp (session courante)
    let   _activeQueue    = [];                // file ordonnée : le plus récent en tête

    function getAcks() { return JSON.parse(localStorage.getItem(ACK_KEY) || '{}'); }
    function saveAck(clientId) {
      const acks = getAcks();
      acks[clientId] = new Date().toISOString();
      localStorage.setItem(ACK_KEY, JSON.stringify(acks));
    }

    function sortAndRenderClients() {
      if (!allClients.length) return;
      const qSet   = new Set(_activeQueue);
      const active = _activeQueue.map(id => allClients.find(c => c.id === id)).filter(Boolean);
      const rest   = allClients.filter(c => !qSet.has(c.id));
      renderClients([...active, ...rest]);
    }

    function bumpClient(clientId) {
      if (!clientId) return;
      _recentActivity[clientId] = Date.now();
      _activeQueue = [clientId, ..._activeQueue.filter(id => id !== clientId)];
      sortAndRenderClients();
    }

    function unbumpClient(clientId) {
      // L'admin a ouvert la fiche → acquitter + retirer de la file
      saveAck(clientId);
      _activeQueue = _activeQueue.filter(id => id !== clientId);
      delete _recentActivity[clientId];
      sortAndRenderClients();
    }

    // Realtime — nouvelles activités clients
    sb.channel('admin-realtime')
      .on('postgres_changes', { event: 'UPDATE', schema: 'public', table: 'content_items' }, (payload) => {
        if (['approved','rejected'].includes(payload.new?.status)) {
          loadAdminNotifs();
          bumpClient(payload.new?.client_id);
          showAdminToast(payload.new.status === 'approved' ? '✅ Contenu validé par un client' : '❌ Contenu refusé par un client');
        }
      })
      .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'client_uploads' }, (payload) => {
        loadAdminNotifs();
        bumpClient(payload.new?.client_id);
        showAdminToast('📎 Nouveau fichier déposé par un client');
      })
      .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'profiles' }, (payload) => {
        if (payload.new?.role === 'client') {
          loadAdminNotifs();
          showAdminToast('👤 Nouveau client inscrit');
        }
      })
      .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'client_notes' }, (payload) => {
        if (!payload.new?.from_admin) {
          loadAdminNotifs();
          bumpClient(payload.new?.client_id);
          showAdminToast('💬 Nouveau message d\'un client');
        }
      })
      .on('postgres_changes', { event: '*', schema: 'public', table: 'tasks' }, (payload) => {
        const cid = payload.new?.client_id || payload.old?.client_id;
        if (cid) bumpClient(cid);
      })
      .on('postgres_changes', { event: 'UPDATE', schema: 'public', table: 'profiles' }, (payload) => {
        const cid = payload.new?.id;
        if (!cid || payload.new?.role !== 'client') return;
        // Mettre à jour l'avatar dans allClients sans recharger tout
        const idx = allClients.findIndex(c => c.id === cid);
        if (idx !== -1 && payload.new?.avatar_url) {
          allClients[idx].avatar_url = payload.new.avatar_url;
          sortAndRenderClients();
        }
        // Si la fiche du client est ouverte, rafraîchir l'avatar dans l'en-tête
        if (window._currentAdminClientId === cid && payload.new?.avatar_url) {
          const headerAvatar = document.querySelector('#client-detail .rounded-full img');
          if (headerAvatar) headerAvatar.src = payload.new.avatar_url + '?t=' + Date.now();
        }
      })
      .subscribe();

    // ─── Calendrier admin ─────────────────────────────────────────────────────
    const ADMIN_CAL_COLORS = { 'POST':'#3B82F6','STORY':'#EC4899','REEL':'#8B5CF6','CARROUSEL':'#10B981','PLANNING':'#F59E0B','AUDIT':'#6B7280' };
    let adminCalYear  = new Date().getFullYear();
    let adminCalMonth = new Date().getMonth();
    let adminCalSel   = null;
    let adminCalApproved = [];
    let adminCalPending  = [];
    let adminCalNotes    = [];

    async function loadAdminCalData() {
      const sb2 = await getSB();
      const [{ data: approved }, { data: pending }, { data: notes }] = await Promise.all([
        sb2.from('content_items').select('id,title,scheduled_at,updated_at,client_id,profiles(full_name,email)').eq('status','approved'),
        sb2.from('content_items').select('id,title,scheduled_at,created_at,client_id,profiles(full_name,email)').eq('status','pending'),
        sb2.from('calendar_notes').select('*'),
      ]);
      adminCalApproved = approved || [];
      adminCalPending  = pending  || [];
      adminCalNotes    = notes    || [];
      renderAdminCal();
    }

    function renderAdminCal() {
      const months = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
      document.getElementById('admin-cal-label').textContent = `${months[adminCalMonth]} ${adminCalYear}`;
      const firstDay   = new Date(adminCalYear, adminCalMonth, 1).getDay();
      const startOffset = (firstDay === 0 ? 6 : firstDay - 1);
      const daysInMonth = new Date(adminCalYear, adminCalMonth+1, 0).getDate();
      const days = ['Lu','Ma','Me','Je','Ve','Sa','Di'];

      let html = `<table class="w-full border-collapse text-xs table-fixed"><thead><tr>`;
      days.forEach(d => { html += `<th class="py-1.5 text-center text-[#767A55] font-medium text-[10px] uppercase tracking-widest">${d}</th>`; });
      html += `</tr></thead><tbody><tr>`;

      let col = 0;
      for (let i = 0; i < startOffset; i++) { html += `<td class="border border-[#D6CCC0]/30 p-1 h-16 align-top bg-[#F5EDE4]/30"></td>`; col++; }

      for (let day = 1; day <= daysInMonth; day++) {
        const dateStr      = `${adminCalYear}-${String(adminCalMonth+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
        const isToday      = dateStr === new Date().toISOString().slice(0,10);
        const dayItems     = adminCalApproved.filter(a => (a.scheduled_at||a.updated_at||'').slice(0,10) === dateStr);
        const dayPendAdmin = adminCalPending.filter(a => (a.scheduled_at||a.created_at||'').slice(0,10) === dateStr);
        const dayNotes     = adminCalNotes.filter(n => n.date === dateStr);

        let cellContent = '';
        dayItems.forEach(a => {
          const tMatch = a.title.match(/^\[([A-Z\s\-]+)\]/i);
          const tType  = tMatch ? tMatch[1].toUpperCase() : '';
          const color  = ADMIN_CAL_COLORS[tType] || '#8B3E22';
          const clean  = a.title.replace(/^\[[^\]]+\]\s*/,'').slice(0,16);
          const client = a.profiles?.full_name || a.profiles?.email || '';
          cellContent += `<div style="background:${color}15;color:${color};border-left:2px solid ${color}" class="text-[9px] leading-tight px-1 py-0.5 rounded-r mb-0.5 truncate font-medium" title="${client}">${clean}</div>`;
        });
        dayPendAdmin.forEach(a => {
          const clean  = a.title.replace(/^\[[^\]]+\]\s*/,'').slice(0,14);
          const client = a.profiles?.full_name || a.profiles?.email || '';
          cellContent += `<div style="background:#FEF3C715;color:#D97706;border-left:2px dashed #D97706" class="text-[9px] leading-tight px-1 py-0.5 rounded-r mb-0.5 truncate" title="⏳ ${client}">⏳ ${clean}</div>`;
        });
        dayNotes.forEach(n => {
          cellContent += `<div class="text-[9px] leading-tight px-1 py-0.5 rounded bg-[#EDE6DB] text-[#767A55] mb-0.5 truncate italic">${n.note.slice(0,18)}</div>`;
        });
        const dotA = (dayNotes.length || dayItems.length) ? `<span class="w-1 h-1 rounded-full bg-[#8B3E22] inline-block ml-0.5 mb-0.5"></span>` : '';

        html += `<td class="border border-[#D6CCC0]/30 p-1 h-16 align-top cursor-pointer hover:bg-[#F5EDE4] transition-colors"
          onclick="adminCalClick('${dateStr}','${day}')"
          ondblclick="adminCalDayDetail('${dateStr}')">
          <div class="flex items-center justify-center gap-0.5 mb-0.5">
            <span class="${isToday ? 'w-5 h-5 bg-[#8B3E22] text-white rounded-full inline-flex items-center justify-center' : ''} text-[10px] font-${isToday?'bold':'medium'} text-${isToday?'white':'[#2C2416]'}">${day}</span>${dotA}
          </div>
          ${cellContent}
        </td>`;
        col++;
        if (col % 7 === 0 && day < daysInMonth) html += `</tr><tr>`;
      }
      const rem = 7 - (col % 7);
      if (rem < 7) for (let i = 0; i < rem; i++) html += `<td class="border border-[#D6CCC0]/30 p-1 h-16 bg-[#F5EDE4]/30"></td>`;
