    })();
    async function _openClientInner(clientId) {

      window._currentAdminClientId = clientId;
      const sb = await getSB();
      const [{ data: c }, { data: docs }, { data: content }, { data: uploads }, { data: igCred }] = await Promise.all([
        sb.from('profiles').select('*').eq('id', clientId).single(),
        sb.from('documents').select('*').eq('client_id', clientId).order('created_at', { ascending: false }),
        sb.from('content_items').select('*').eq('client_id', clientId).order('created_at', { ascending: false }),
        sb.from('client_uploads').select('*').eq('client_id', clientId).order('created_at', { ascending: false }),
        sb.from('instagram_credentials').select('*').eq('client_id', clientId).single(),
      ]);

      const pending  = (content||[]).filter(i => i.status === 'pending').length;
      const approved = (content||[]).filter(i => i.status === 'approved').length;
      const rejected = (content||[]).filter(i => i.status === 'rejected').length;
      const total    = (content||[]).length;
      const docsNonInv = (docs||[]).filter(d => d.type !== 'facture');
      const docsInv    = (docs||[]).filter(d => d.type === 'facture');

      const statusBadge = (s, id) => {
        const click = id ? `onclick="toggleContentDetail('${id}')" ` : '';
        if (s === 'approved') return `<span ${click}class="cursor-pointer text-xs px-2 py-0.5 rounded-full bg-green-100 text-green-700"><span class="hidden sm:inline">Validé </span>✓</span>`;
        if (s === 'rejected') return `<span ${click}class="cursor-pointer text-xs px-2 py-0.5 rounded-full bg-red-100 text-red-600"><span class="hidden sm:inline">Refusé</span><span class="sm:hidden">✗</span></span>`;
        return `<span ${click}class="cursor-pointer text-xs px-2 py-0.5 rounded-full bg-yellow-100 text-yellow-700"><span class="hidden sm:inline">En attente</span><span class="sm:hidden">⏳</span></span>`;
      };

      // ── Rendu d'un item contenu (extrait pour le regroupement mensuel) ──────
      const _renderCtItem = (ct) => {
        let files = [];
        try { files = Array.isArray(ct.files) ? ct.files : (ct.files ? JSON.parse(ct.files) : []); } catch(e) { files = []; }
        const file0 = files[0];
        const isImg = file0?.url && /\.(jpg|jpeg|png|gif|webp|svg)(\?|$)/i.test(file0.url);
        const safeTitle = ct.title || '';
        const tMatch = safeTitle.match(/^\[([A-ZÉÈÀÙÂÊÎÔÛÇ\s\-]+)\]/i);
        const tType  = tMatch ? tMatch[1].toUpperCase() : '';
        const cleanT = safeTitle.replace(/^\[[^\]]+\]\s*/, '') || safeTitle || '(sans titre)';
        const TYPE_HEX  = { 'POST':'#3B82F6','STORY':'#EC4899','REEL':'#8B5CF6','CARROUSEL':'#10B981','PLANNING':'#F59E0B','CALENDRIER ÉDITORIAL':'#F59E0B','AUDIT':'#6B7280' };
        const TYPE_ICON = { 'POST':'solar:image-linear','STORY':'solar:smartphone-linear','REEL':'solar:videocamera-linear','CARROUSEL':'solar:gallery-linear','PLANNING':'solar:calendar-linear','CALENDRIER ÉDITORIAL':'solar:calendar-linear' };
        const TYPE_TAG  = { 'POST':'bg-blue-100 text-blue-700','STORY':'bg-pink-100 text-pink-700','REEL':'bg-purple-100 text-purple-700','CARROUSEL':'bg-emerald-100 text-emerald-700','PLANNING':'bg-orange-100 text-orange-700','CALENDRIER ÉDITORIAL':'bg-orange-100 text-orange-700','AUDIT':'bg-gray-100 text-gray-500' };
        const tHex  = TYPE_HEX[tType]  || '#8B3E22';
        const tIcon = TYPE_ICON[tType] || 'solar:document-text-linear';
        const tTagC = TYPE_TAG[tType]  || 'bg-[#8B3E22]/10 text-[#8B3E22]';
        const typeTag = tType ? `<span class="text-xs font-bold px-2.5 py-0.5 rounded-full ${tTagC} uppercase tracking-wide">${tType}</span>` : '';
        const schedDate = ct.scheduled_at
          ? new Date(ct.scheduled_at).toLocaleDateString('fr-FR',{day:'2-digit',month:'short',year:'numeric'}) + ' · ' + new Date(ct.scheduled_at).toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'})
          : new Date(ct.created_at).toLocaleDateString('fr-FR',{day:'2-digit',month:'short',year:'numeric'});
        const shortDesc = ct.description ? `<p class="text-xs text-[#767A55] line-clamp-2 mt-1 leading-relaxed">${ct.description.slice(0,100)}</p>` : '';
        const captionBlock = ct.description ? `<div class="bg-[#F5EDE4] rounded-lg p-3 mb-2 border border-[#D6CCC0]"><p class="text-xs text-[#767A55] uppercase tracking-widest mb-1">Légende</p><p class="text-sm text-[#2C2416]/75 leading-relaxed whitespace-pre-wrap">${ct.description}</p></div>` : '';
        const feedbackBlock = ct.feedback ? `<div class="bg-yellow-50 rounded-lg p-3 border border-yellow-200 mt-2"><p class="text-xs text-yellow-700 uppercase tracking-widest mb-1">Note du client</p><p class="text-sm text-yellow-800 leading-relaxed">${ct.feedback}</p></div>` : '';
