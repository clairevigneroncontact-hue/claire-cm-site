    async function loadClients() {
      const refreshIcon = document.querySelector('#refresh-btn iconify-icon');
      if (refreshIcon) refreshIcon.classList.add('animate-spin');

      // Charger clients + dernières activités en parallèle
      const [{ data: clients }, { data: recentContent }, { data: recentUploads }] = await Promise.all([
        sb.from('profiles').select('*').eq('role', 'client').order('created_at', { ascending: false }),
        sb.from('content_items').select('client_id, status, updated_at').order('updated_at', { ascending: false }),
        sb.from('client_uploads').select('client_id, file_url, created_at').order('created_at', { ascending: false }),
      ]);

      if (refreshIcon) refreshIcon.classList.remove('animate-spin');

      const pendingByClient = {};
      (recentContent||[]).forEach(i => { if (i.status === 'pending') pendingByClient[i.client_id] = (pendingByClient[i.client_id]||0)+1; });

      allClients = (clients || []).map(c => ({
        ...c,
        lastContent:  recentContent?.find(i => i.client_id === c.id),
        lastUpload:   recentUploads?.find(u => u.client_id === c.id),
        pendingCount: pendingByClient[c.id] || 0,
      }));

      renderClients(allClients);
      // Re-vérifier l'activité maintenant que allClients est peuplé
      loadAdminNotifs();
    }

    function renderClients(list) {
      const el    = document.getElementById('clients-list');
      const count = document.getElementById('clients-count');
      if (count) count.textContent = `${list.length} client${list.length > 1 ? 's' : ''}`;

      if (!list.length) {
        el.innerHTML = '<p class="text-sm text-[#2C2416]/40 italic">Aucun client trouvé.</p>';
        return;
      }

      const now = Date.now();
      // Trier : actifs en premier, puis nouveaux, puis par date
      const sorted = [...list].sort((a, b) => {
        const aAct = !!_recentActivity[a.id], bAct = !!_recentActivity[b.id];
        if (aAct !== bAct) return aAct ? -1 : 1;
        const aNew = (now - new Date(a.created_at).getTime()) < 24*3600*1000;
        const bNew = (now - new Date(b.created_at).getTime()) < 24*3600*1000;
        if (aNew !== bNew) return aNew ? -1 : 1;
        return new Date(b.created_at) - new Date(a.created_at);
      });
      el.innerHTML = sorted.map(c => {
        const createdAt = new Date(c.created_at);
        const isNew        = (now - createdAt.getTime()) < 24 * 3600 * 1000;
        const hasRecentAct = !!_recentActivity[c.id];
        const borderClass  = hasRecentAct ? 'border-2 border-[#5A1E0E] shadow-lg shadow-[#8B3E22]/20' : isNew ? 'border-[#8B3E22]' : 'border-[#D6CCC0]';
        const cardBg       = hasRecentAct ? 'bg-[#FFF5F0]' : 'bg-white';
        const dateStr      = createdAt.toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' });

        // Dernière activité
        let activity = '';
        if (c.lastContent) {
          const statusLabel = c.lastContent.status === 'approved' ? '✓ Contenu validé' : c.lastContent.status === 'rejected' ? '✗ Contenu refusé' : '⏳ Contenu en attente';
          const when = new Date(c.lastContent.updated_at).toLocaleDateString('fr-FR', { day:'2-digit', month:'short' });
          activity += `<span class="text-xs text-[#767A55]">${statusLabel} · ${when}</span>`;
        }
        if (c.lastUpload) {
          const when = new Date(c.lastUpload.created_at).toLocaleDateString('fr-FR', { day:'2-digit', month:'short' });
          const uploadLabel = (() => { try { return decodeURIComponent((c.lastUpload.file_url||'').split('/').pop().replace(/^\d+-/,'')) || 'Fichier déposé'; } catch(e) { return 'Fichier déposé'; } })();
          activity += `${activity ? ' &nbsp;·&nbsp; ' : ''}<span class="text-xs text-[#767A55]">📎 ${uploadLabel} · ${when}</span>`;
        }

        const pendingCount = c.pendingCount || 0;
        const avatarEl = c.avatar_url
          ? `<img src="${c.avatar_url}" alt="" class="w-full h-full object-cover" onerror="this.style.display='none'" />`
          : `<span class="text-sm font-bold">${(c.full_name || c.email || '?')[0].toUpperCase()}</span>`;
        const avatarBg = hasRecentAct ? 'bg-[#5A1E0E] text-white border-[#5A1E0E]' : 'bg-[#8B3E22]/10 text-[#8B3E22] border-[#D6CCC0]';

        return `
        <div class="relative overflow-hidden ${cardBg} rounded-2xl border ${borderClass} cursor-pointer hover:border-[#8B3E22] hover:shadow-md transition-all group" onclick="openClient('${c.id}')">
          ${hasRecentAct ? '<div class="absolute inset-y-0 left-0 w-1 bg-[#5A1E0E] rounded-l-2xl"></div>' : ''}
          <div class="p-5 ${hasRecentAct ? 'pl-6' : ''}">
            <!-- Avatar + nom + badges -->
            <div class="flex items-center gap-4">
              <div class="w-14 h-14 rounded-full flex items-center justify-center shrink-0 overflow-hidden border-2 ${avatarBg}">
                ${avatarEl}
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap mb-1">
                  <p class="font-semibold text-[#2C2416] text-lg truncate">${c.full_name || c.email}</p>
                  ${hasRecentAct ? '<span class="text-[10px] px-2 py-0.5 bg-[#5A1E0E] text-white rounded-full shrink-0 animate-pulse">● activité</span>' : isNew ? '<span class="text-[10px] px-2 py-0.5 bg-green-100 text-green-700 rounded-full shrink-0">Nouveau</span>' : ''}
                  ${pendingCount ? `<span class="text-[10px] px-2 py-0.5 bg-amber-100 text-amber-700 rounded-full shrink-0 font-bold">⏳ ${pendingCount}</span>` : ''}
                </div>
                <p class="text-sm text-[#767A55] truncate">${c.email}${c.instagram_handle ? ' · @' + c.instagram_handle : ''}</p>
              </div>
              <iconify-icon icon="solar:arrow-right-linear" stroke-width="1.5" class="text-[#D6CCC0] group-hover:text-[#8B3E22] shrink-0 transition-colors text-lg"></iconify-icon>
            </div>
            <!-- Offre + activité + date -->
            <div class="flex items-center justify-between gap-2 mt-4 pt-3 border-t border-[#D6CCC0]/40">
              <div class="flex items-center gap-2 flex-wrap min-w-0">
                ${c.offer ? `<span class="text-xs px-2.5 py-0.5 bg-[#8B3E22]/10 text-[#8B3E22] rounded-full font-medium shrink-0">${OFFER_MAP[c.offer] || c.offer}</span>` : ''}
                ${activity}
              </div>
              <p class="text-xs text-[#2C2416]/30 shrink-0">${dateStr}</p>
            </div>
          </div>
        </div>`;
      }).join('');
    }

    window.openClient = async (clientId) => {
      document.getElementById('view-list').classList.add('hidden');
      document.getElementById('view-client').classList.remove('hidden');
      document.getElementById('client-detail').innerHTML = '<p class="text-sm text-[#2C2416]/40 italic p-4">Chargement…</p>';
