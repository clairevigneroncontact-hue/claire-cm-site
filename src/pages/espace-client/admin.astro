  window.sendMonthlyReport = (clientId) => {
    _bilanClientId = clientId;
    // Pré-remplir mois et année précédents
    const prev  = new Date(new Date().getFullYear(), new Date().getMonth() - 1, 1);
    const mois  = ['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'];
    const sel   = document.getElementById('bilan-month');
    const yr    = document.getElementById('bilan-year');
    if (sel) sel.value = mois[prev.getMonth()];
    if (yr)  yr.value  = prev.getFullYear();
    // Vider les champs éditables
    ['bilan-contenus','bilan-abonnes','bilan-portee','bilan-engagement','bilan-highlights','bilan-next'].forEach(id => {
      const el = document.getElementById(id); if (el) el.value = '';
    });
    const msg = document.getElementById('bilan-send-msg');
