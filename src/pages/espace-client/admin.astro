    // ─── Événements français ──────────────────────────────────────────────────
    function getEasterDate(y) {
      const a=y%19,b=Math.floor(y/100),c=y%100,d=Math.floor(b/4),e=b%4,f=Math.floor((b+8)/25);
      const g=Math.floor((b-f+1)/3),h=(19*a+b-d-g+15)%30,i=Math.floor(c/4),k=c%4;
      const l=(32+2*e+2*i-h-k)%7,m=Math.floor((a+11*h+22*l)/451);
      return new Date(y,Math.floor((h+l-7*m+114)/31)-1,((h+l-7*m+114)%31)+1);
    }
    function getFrEvents(y) {
      const ev={};
      const add=(m,d,n)=>{ const k=`${y}-${String(m).padStart(2,'0')}-${String(d).padStart(2,'0')}`; if(!ev[k])ev[k]=[]; ev[k].push(n); };
      const addD=(dt,n)=>add(dt.getMonth()+1,dt.getDate(),n);
      add(1,1,'🥂 Jour de l\'an'); add(5,1,'🏛 Fête du Travail');
      add(7,14,'🎆 Fête Nationale'); add(11,1,'🕯 Toussaint');
      add(11,11,'🕊 Armistice'); add(12,25,'🎄 Noël');
      const pa=getEasterDate(y);
      addD(pa,'🐣 Pâques');
      const lpa=new Date(pa); lpa.setDate(pa.getDate()+1); addD(lpa,'🐣 Lundi Pâques');
      const asc=new Date(pa); asc.setDate(pa.getDate()+39);
      const pen=new Date(pa); pen.setDate(pa.getDate()+49);
      const lpe=new Date(pa); lpe.setDate(pa.getDate()+50);
      add(2,14,'❤️ St-Valentin'); add(3,8,'💜 Journée Femme');
      add(4,1,'🐟 Poisson d\'avril'); add(10,31,'🎃 Halloween'); add(12,31,'🥂 Réveillon');
      function lastSun(mo){const d=new Date(y,mo+1,0);d.setDate(d.getDate()-d.getDay());return d;}
      function firstSun(mo){const d=new Date(y,mo,1);while(d.getDay()!==0)d.setDate(d.getDate()+1);return d;}
      function nthSun(mo,n){const d=firstSun(mo);d.setDate(d.getDate()+(n-1)*7);return d;}
      function nthFri(mo,n){const d=new Date(y,mo,1);while(d.getDay()!==5)d.setDate(d.getDate()+1);d.setDate(d.getDate()+(n-1)*7);return d;}
      const fmt=(dt)=>`${y}-${String(dt.getMonth()+1).padStart(2,'0')}-${String(dt.getDate()).padStart(2,'0')}`;
      const fm=lastSun(4);
      addD(fmt(fm)===fmt(pen)?firstSun(5):fm,'💐 Fête des Mères');
      addD(nthSun(5,3),'👔 Fête des Pères');
      addD(nthFri(10,4),'🛍 Black Friday');
      return ev;
    }

