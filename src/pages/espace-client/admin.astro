                      ${isImg?`<img src="${u.file_url}" alt="${uName}" style="width:100%;height:90px;object-fit:cover;display:block" onerror="this.style.display='none'" />`:`<div style="height:130px;display:flex;align-items:center;justify-content:center"><iconify-icon icon="${icon}" stroke-width="1.5" style="color:#8B3E22;font-size:3rem"></iconify-icon></div>`}
