      _clientCalData = {
        approved: (allContent||[]).filter(a => a.status === 'approved'),
        pending:  (allContent||[]).filter(a => a.status === 'pending'),
        rejected: (allContent||[]).filter(a => a.status === 'rejected'),
        notes:    notes||[],
      };
      // Badge "Nouveau" : items validés depuis la dernière ouverture de ce calendrier
      const lsKey   = 'adminCalLastOpen_' + cid;
      const lastOpen = localStorage.getItem(lsKey) || new Date(Date.now() - 7*24*3600*1000).toISOString();
      _adminCalNewItems = new Set(_clientCalData.approved.filter(a => (a.updated_at||'') > lastOpen).map(a => a.id));
      localStorage.setItem(lsKey, new Date().toISOString());
      renderClientCal();
    }

    function renderClientCal() {
      const label = document.getElementById('client-cal-label');
      const grid  = document.getElementById('client-cal-grid');
      if (!label || !grid) return;
      const months = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
      label.textContent = `${months[clientCalMonth]} ${clientCalYear}`;
      const frEvents = getFrEvents(clientCalYear);
      const firstDay    = new Date(clientCalYear, clientCalMonth, 1).getDay();
      const startOffset = (firstDay === 0 ? 6 : firstDay - 1);
      const daysInMonth = new Date(clientCalYear, clientCalMonth+1, 0).getDate();
      const days = ['Lu','Ma','Me','Je','Ve','Sa','Di'];

      let html = `<table class="w-full border-collapse table-fixed"><thead><tr>`;
      days.forEach(d => { html += `<th class="py-2 text-center text-[#767A55] font-semibold text-xs uppercase tracking-wide">${d}</th>`; });
      html += `</tr></thead><tbody><tr>`;

      let col = 0;
      for (let i = 0; i < startOffset; i++) { html += `<td class="border border-[#D6CCC0]/30 p-1 bg-[#F5EDE4]/30" style="height:110px"></td>`; col++; }

      for (let day = 1; day <= daysInMonth; day++) {
        const dateStr  = `${clientCalYear}-${String(clientCalMonth+1).padStart(2,'0')}-${String(day).padStart(2,'0')}`;
        const isToday  = dateStr === new Date().toISOString().slice(0,10);
        const dayApproved = _clientCalData.approved.filter(a => (a.scheduled_at||a.updated_at||'').slice(0,10) === dateStr);
        const dayPending  = (_clientCalData.pending||[]).filter(a => (a.scheduled_at||a.created_at||'').slice(0,10) === dateStr);
        const dayNotes = _clientCalData.notes.filter(n => n.date === dateStr);

        let cell = '';
        // Contenus validés — couleur par type + draggable
        dayApproved.forEach(a => {
          const tMatch = a.title.match(/^\[([A-Z\s\-]+)\]/i);
          const tType  = tMatch ? tMatch[1].toUpperCase() : '';
          const color  = CAL_COLORS[tType] || '#8B3E22';
          const clean  = a.title.replace(/^\[[^\]]+\]\s*/,'').slice(0,16);
          const heure  = a.scheduled_at ? ' · ' + new Date(a.scheduled_at).toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'}) : '';
          const dragTime = (a.scheduled_at||'').slice(11,16) || '00:00';
          const newDot = _adminCalNewItems.has(a.id) ? '<span style="display:inline-block;background:#F59E0B;color:white;font-size:7px;font-weight:800;padding:0 3px;border-radius:3px;margin-right:3px;vertical-align:middle">NEW</span>' : '';
          cell += `<div draggable="true" data-drag-id="${a.id}" ondragstart="calDragStart(event,'${a.id}','${dragTime}')" ondragend="calDragEnd(event)" ontouchstart="calTouchStartItem(event,'${a.id}','${dragTime}',this)" style="background:${color}15;color:${color};border-left:2px solid ${color};font-size:14px;line-height:1.4;padding:2px 4px;border-radius:0 4px 4px 0;margin-bottom:2px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;font-weight:600;cursor:grab">${newDot}${clean}${heure}</div>`;
        });
        // Contenus en attente — jaune/ambre
        dayPending.forEach(a => {
          const clean = a.title.replace(/^\[[^\]]+\]\s*/,'').slice(0,16);
          const heure = a.scheduled_at ? ' · ' + new Date(a.scheduled_at).toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'}) : '';
          cell += `<div style="background:#FEF3C715;color:#D97706;border-left:2px dashed #D97706;font-size:14px;line-height:1.4;padding:2px 4px;border-radius:0 4px 4px 0;margin-bottom:2px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;font-weight:500">⏳ ${clean}${heure}</div>`;
        });
        dayNotes.forEach(n => {
          cell += `<div class="text-[12px] px-1 py-0.5 rounded bg-[#EDE6DB] text-[#767A55] mb-0.5 truncate italic">${n.note.slice(0,22)}</div>`;
        });
        const dotC = (dayNotes.length || dayApproved.length || dayPending.length) ? `<span class="w-1.5 h-1.5 rounded-full bg-[#8B3E22] inline-block ml-0.5 mb-0.5"></span>` : '';
        const dayFrEvents = (frEvents[dateStr] || []);
        const evCell = dayFrEvents.map(e => `<div style="font-size:12px;color:#8B3E22;line-height:1.4;padding:0 4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-weight:500">${e}</div>`).join('');

        html += `<td class="border border-[#D6CCC0]/30 p-1 align-top cursor-pointer hover:bg-[#F5EDE4] transition-colors ${dayFrEvents.length ? 'bg-[#FFF8F5]' : ''}"
          style="height:110px"
          data-cal-date="${dateStr}"
          ondragover="calDragOver(event)"
          ondragleave="calDragLeave(event)"
          ondrop="calDrop(event,'${dateStr}')"
          onclick="if(!window._calLastDrop||Date.now()-window._calLastDrop>400) clientCalCellClick('${dateStr}')"
          ondblclick="clientCalDayDetail('${dateStr}')">
          <div class="flex items-center justify-center gap-0.5 mb-1">
            <span class="${isToday?'w-6 h-6 bg-[#8B3E22] text-white rounded-full inline-flex items-center justify-center':''}" style="font-size:13px;font-weight:${isToday?'700':'500'};color:${isToday?'white':'#2C2416'}">${day}</span>${dotC}
          </div>
          ${cell}${evCell}
        </td>`;
        col++;
        if (col % 7 === 0 && day < daysInMonth) html += `</tr><tr>`;
      }
      const rem = 7 - (col % 7); if (rem < 7) for (let i=0;i<rem;i++) html += `<td class="border border-[#D6CCC0]/30 p-1 h-16 bg-[#F5EDE4]/30"></td>`;
      html += `</tr></tbody></table>`;
      grid.innerHTML = html;
    }

    window.clientCalNav = (dir) => { clientCalMonth += dir; if (clientCalMonth>11){clientCalMonth=0;clientCalYear++;} if (clientCalMonth<0){clientCalMonth=11;clientCalYear--;} renderClientCal(); };

    // ─── Drag-and-drop calendrier ─────────────────────────────────────────────
    let _calDragItemId   = null;
    let _calDragItemTime = '00:00';
    let _calDragGhost    = null;
    let _touchLongTimer  = null;
    let _touchGhost      = null;
    let _touchDragActive = false;
    window._calLastDrop  = 0;

    async function calMoveItem(id, time, newDate) {
      const sb2 = await getSB();
      const newScheduledAt = `${newDate}T${time || '00:00'}:00`;
      const { error } = await sb2.from('content_items').update({ scheduled_at: newScheduledAt }).eq('id', id);
      if (!error) {
        window._calLastDrop = Date.now();
        showAdminToast('📅 Déplacé au ' + new Date(newDate).toLocaleDateString('fr-FR', { day:'2-digit', month:'long' }));
        await loadClientCal();
      }
    }

    window.calDragStart = (e, id, time) => {
      _calDragItemId = id; _calDragItemTime = time || '00:00';
      e.dataTransfer.effectAllowed = 'move';
      e.dataTransfer.setData('text/plain', id);

      // Ghost personnalisé qui suit la souris
      const src = e.currentTarget;
      _calDragGhost = src.cloneNode(true);
      Object.assign(_calDragGhost.style, {
        position:'fixed', zIndex:'9999', pointerEvents:'none',
        top: (e.clientY - 12) + 'px', left: (e.clientX - 50) + 'px',
        opacity:'0.92', transform:'scale(1.08) rotate(-1.5deg)',
        boxShadow:'0 8px 24px rgba(0,0,0,0.3)', borderRadius:'4px',
        minWidth:'90px', maxWidth:'180px', padding:'3px 8px',
        transition:'none', cursor:'grabbing',
      });
      document.body.appendChild(_calDragGhost);

      // Masquer le ghost natif du navigateur
      const blank = new Image();
      blank.src = 'data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7';
      e.dataTransfer.setDragImage(blank, 0, 0);

      e.stopPropagation();
    };
    window.calDragEnd = () => {
      _calDragItemId = null;
      document.querySelectorAll('[data-cal-date]').forEach(el => el.style.background = '');
      if (_calDragGhost) { _calDragGhost.remove(); _calDragGhost = null; }
    };

    // Faire suivre le ghost à la souris pendant le drag
    document.addEventListener('drag', (e) => {
      if (!_calDragGhost) return;
      if (e.clientX === 0 && e.clientY === 0) return;
      _calDragGhost.style.left = (e.clientX - 50) + 'px';
      _calDragGhost.style.top  = (e.clientY - 12) + 'px';
    });
    window.calDragOver = (e) => {
      if (!_calDragItemId) return;
      e.preventDefault(); e.stopPropagation();
      e.dataTransfer.dropEffect = 'move';
      const cell = e.currentTarget.closest('[data-cal-date]') || e.currentTarget;
      cell.style.background = 'rgba(139,62,34,0.15)';
    };
    window.calDragLeave = (e) => {
      const cell = e.currentTarget.closest('[data-cal-date]') || e.currentTarget;
      cell.style.background = '';
    };
    window.calDrop = async (e, dateStr) => {
      e.preventDefault(); e.stopPropagation();
      const cell = e.currentTarget.closest('[data-cal-date]') || e.currentTarget;
      cell.style.background = '';
      if (!_calDragItemId) return;
      await calMoveItem(_calDragItemId, _calDragItemTime, dateStr);
      _calDragItemId = null;
    };

    // Touch long-press
    window.calTouchStartItem = (e, id, time, el) => {
      clearTimeout(_touchLongTimer);
      _touchLongTimer = setTimeout(() => {
        _calDragItemId = id; _calDragItemTime = time || '00:00'; _touchDragActive = true;
        const rect = el.getBoundingClientRect();
        _touchGhost = el.cloneNode(true);
        Object.assign(_touchGhost.style, { position:'fixed', zIndex:'9999', opacity:'0.85', pointerEvents:'none',
          left: rect.left + 'px', top: rect.top + 'px', width: rect.width + 'px',
          padding:'4px 8px', borderRadius:'4px', fontSize:'11px', whiteSpace:'nowrap',
          transform:'scale(1.15)', boxShadow:'0 4px 16px rgba(0,0,0,0.3)', background:'#8B3E22', color:'#fff' });
        document.body.appendChild(_touchGhost);
        el.style.opacity = '0.3';
        if (navigator.vibrate) navigator.vibrate(60);
        e.preventDefault();
      }, 500);
    };

    document.addEventListener('touchmove', (e) => {
      clearTimeout(_touchLongTimer);
      if (!_touchDragActive || !_touchGhost) return;
      e.preventDefault();
      const t = e.touches[0];
      _touchGhost.style.left = (t.clientX - _touchGhost.offsetWidth / 2) + 'px';
      _touchGhost.style.top  = (t.clientY - 16) + 'px';
      _touchGhost.style.display = 'none';
      const under = document.elementFromPoint(t.clientX, t.clientY);
      _touchGhost.style.display = '';
      document.querySelectorAll('[data-cal-date]').forEach(el => el.style.background = '');
      const cell = under?.closest('[data-cal-date]');
      if (cell) cell.style.background = 'rgba(139,62,34,0.15)';
    }, { passive: false });

    document.addEventListener('touchend', async (e) => {
      clearTimeout(_touchLongTimer);
      if (!_touchDragActive) return;
      const t = e.changedTouches[0];
      document.querySelectorAll('[data-cal-date]').forEach(el => el.style.background = '');
      if (_touchGhost) _touchGhost.style.display = 'none';
      const under = document.elementFromPoint(t.clientX, t.clientY);
      if (_touchGhost) _touchGhost.style.display = '';
      const cell = under?.closest('[data-cal-date]');
      if (cell && _calDragItemId) await calMoveItem(_calDragItemId, _calDragItemTime, cell.dataset.calDate);
      if (_touchGhost) { _touchGhost.remove(); _touchGhost = null; }
      document.querySelectorAll('[data-drag-id]').forEach(el => el.style.opacity = '');
      _touchDragActive = false; _calDragItemId = null;
    });

    document.addEventListener('touchcancel', () => {
      clearTimeout(_touchLongTimer);
      if (_touchGhost) { _touchGhost.remove(); _touchGhost = null; }
      document.querySelectorAll('[data-drag-id]').forEach(el => el.style.opacity = '');
      _touchDragActive = false; _calDragItemId = null;
    });

    let _clientFullDayDate = null;

    function getNextClientContentDate(after) {
      const dates = new Set([
        ..._clientCalData.approved.map(a => (a.scheduled_at||a.updated_at||'').slice(0,10)),
        ...(_clientCalData.pending||[]).map(a => (a.scheduled_at||a.created_at||'').slice(0,10)),
        ..._clientCalData.notes.map(n => n.date)
      ]);
      return [...dates].filter(d => d > after).sort()[0] || null;
    }

    window.clientCalGoToNext = () => {
      const next = getNextClientContentDate(_clientFullDayDate);
      if (next) window.clientCalDayDetail(next);
    };

    // Clic simple = détail (desktop et mobile)
    window.clientCalCellClick = (dateStr) => { window.clientCalDayDetail(dateStr); };

    // Crayon dans le header → formulaire note avec date picker
    window.clientCalOpenNoteForm = () => {
      const today = new Date().toISOString().slice(0,10);
      const picker = document.getElementById('client-cal-date-picker');
      picker.value = clientCalSel || today;
      document.getElementById('client-cal-input').value = '';
      const ex = _clientCalData.notes.find(n => n.date === picker.value);
      if (ex) document.getElementById('client-cal-input').value = ex.note;
      picker.onchange = () => {
        const e2 = _clientCalData.notes.find(n => n.date === picker.value);
        document.getElementById('client-cal-input').value = e2?.note || '';
      };
      const modal = document.getElementById('client-cal-note-modal');
      modal.classList.remove('hidden');
      modal.scrollIntoView({ behavior:'smooth', block:'nearest' });
    };

    window.clientCalDayDetail = (dateStr) => {
      _clientFullDayDate = dateStr;
      const dayApproved = _clientCalData.approved.filter(a => (a.scheduled_at||a.updated_at||'').slice(0,10) === dateStr);
      const dayPending  = (_clientCalData.pending||[]).filter(a => (a.scheduled_at||a.created_at||'').slice(0,10) === dateStr);
      const dayItems = [...dayApproved, ...dayPending];
      const dayNotes = _clientCalData.notes.filter(n => n.date === dateStr);
      const [y,m,d] = dateStr.split('-');
      const months = ['janvier','février','mars','avril','mai','juin','juillet','août','septembre','octobre','novembre','décembre'];
      const FDAY_HEX  = { 'POST':'#3B82F6','STORY':'#EC4899','REEL':'#8B5CF6','CARROUSEL':'#10B981','PLANNING':'#F59E0B','CALENDRIER ÉDITORIAL':'#F59E0B','AUDIT':'#6B7280' };
      const FDAY_ICON = { 'POST':'solar:image-linear','STORY':'solar:smartphone-linear','REEL':'solar:videocamera-linear','CARROUSEL':'solar:gallery-linear','PLANNING':'solar:calendar-linear','CALENDRIER ÉDITORIAL':'solar:calendar-linear' };
      let html = '';
      dayItems.forEach(a => {
        const tMatch = a.title.match(/^\[([A-Z\s\-]+)\]/i);
        const tType  = tMatch ? tMatch[1].toUpperCase() : '';
        const color  = FDAY_HEX[tType] || '#8B3E22';
        const icon   = FDAY_ICON[tType] || 'solar:document-text-linear';
        const clean  = a.title.replace(/^\[[^\]]+\]\s*/,'');
        let files = []; try { files = Array.isArray(a.files) ? a.files : JSON.parse(a.files||'[]'); } catch(e){}
        const isImgF = files[0]?.url && /\.(jpg|jpeg|png|gif|webp)(\?|$)/i.test(files[0].url);
        const _heureVal = a.scheduled_at || a.updated_at;
        const heure  = _heureVal ? new Date(_heureVal).toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'}) : '';
        const isPending = a.status === 'pending';
        const reschedDate = (a.scheduled_at || a.updated_at || '').slice(0,10);
        const reschedTime = (a.scheduled_at||'').slice(11,16) || '12:00';
        html += `<div class="rounded-2xl border ${isPending ? 'border-amber-300 bg-amber-50/30' : 'border-[#D6CCC0]'} overflow-hidden">
          <!-- En-tête : type + heure -->
          <div class="flex items-center justify-between px-4 py-3 border-b ${isPending ? 'border-amber-200 bg-amber-50' : 'border-[#D6CCC0]/50 bg-[#F5EDE4]/30'}">
            <div class="flex items-center gap-2 flex-wrap">
              <span style="background:${color}20;color:${color}" class="text-xs font-bold px-2.5 py-1 rounded-full">${tType||'—'}</span>
              ${isPending ? '<span class="text-xs text-amber-600 font-medium">⏳ En attente de validation</span>' : '<span class="text-xs text-green-600 font-medium">✓ Validé</span>'}
              ${_adminCalNewItems.has(a.id) ? '<span class="text-xs px-2 py-0.5 bg-amber-100 text-amber-700 rounded-full font-semibold border border-amber-200">✦ Nouveau</span>' : ''}
            </div>
            <div class="flex items-center gap-2">
              ${heure ? `<div class="flex items-center gap-1.5 text-sm font-semibold text-[#2C2416]"><iconify-icon icon="solar:clock-circle-linear" stroke-width="1.5" class="text-[#8B3E22]"></iconify-icon>${heure}</div>` : ''}
              <div class="flex items-center gap-1.5 flex-wrap">
                ${isPending ? `<button onclick="event.stopPropagation(); closeClientCalFullDay(); switchClientTab('contenu'); setTimeout(()=>{toggleContentDetail('${a.id}');toggleEdit('${a.id}');document.getElementById('edit-${a.id}')?.scrollIntoView({behavior:'smooth',block:'center'})},300)" class="text-xs px-2.5 py-1 rounded-lg bg-[#8B3E22]/10 text-[#8B3E22] hover:bg-[#8B3E22]/20 transition-colors font-medium">✏️ Modifier</button>` : ''}
                <button onclick="event.stopPropagation(); const _rp=document.getElementById('reschedule-${a.id}'); _rp.classList.toggle('hidden'); if(!_rp.classList.contains('hidden')) _rp.scrollIntoView({behavior:'smooth',block:'nearest'})" class="text-xs px-2.5 py-1 rounded-lg bg-[#8B3E22]/10 text-[#8B3E22] hover:bg-[#8B3E22]/20 transition-colors font-medium shrink-0">📅 Décaler</button>
                ${isPending ? `<button onclick="event.stopPropagation(); if(confirm('Supprimer ce contenu ?')) deleteContent('${a.id}','${files[0]?.url?files[0].url.replace(/'/g,"\\'"):''}','${_clientCalClientId}')" class="text-xs px-2.5 py-1 rounded-lg bg-red-50 text-red-500 hover:bg-red-100 transition-colors font-medium">🗑 Supprimer</button>` : ''}
              </div>
            </div>
          </div>
          <!-- Corps : image + infos -->
          <div class="flex">
            ${files[0]?.url ? `<div class="w-28 sm:w-40 shrink-0 overflow-hidden" style="background:${color}10;min-height:140px"><img src="${files[0].url}" style="width:100%;height:100%;object-fit:cover;min-height:140px;display:block" onerror="this.style.display='none'" /></div>` : ''}
            <div class="flex-1 p-4">
              <p class="text-base font-semibold text-[#2C2416] mb-2">${clean}</p>
              ${a.description ? `<div class="bg-white rounded-xl p-3 border border-[#D6CCC0]"><p class="text-xs text-[#767A55] uppercase tracking-widest mb-1">Légende / description</p><p class="text-sm text-[#2C2416]/80 leading-relaxed whitespace-pre-wrap">${a.description}</p></div>` : '<p class="text-xs text-[#2C2416]/30 italic">Aucune description</p>'}
              ${files[0]?.url ? `<a href="${files[0].url}" target="_blank" class="inline-flex items-center gap-1.5 mt-3 text-xs text-[#8B3E22] hover:underline font-medium"><iconify-icon icon="solar:eye-linear" stroke-width="1.5"></iconify-icon>Voir le fichier en grand</a>` : ''}
            </div>
          </div>
          <!-- Panneau Décaler (inline) -->
          <div id="reschedule-${a.id}" class="hidden border-t border-[#D6CCC0]/50 px-4 py-3 bg-[#F5EDE4]/50">
            <p class="text-xs text-[#767A55] uppercase tracking-widest mb-3">Reprogrammer la publication</p>
            <div class="space-y-2.5">
              <div>
                <label class="text-xs text-[#767A55] block mb-1">Nouvelle date</label>
                <input id="reschedule-date-${a.id}" type="date" value="${reschedDate}" class="w-full px-3 py-2 rounded-xl border border-[#D6CCC0] text-sm focus:outline-none focus:border-[#8B3E22] bg-white" />
              </div>
              <div>
                <label class="text-xs text-[#767A55] block mb-1">Heure</label>
                <div class="flex items-center gap-2">
                  <select id="reschedule-hour-${a.id}" class="flex-1 px-2 py-2 rounded-xl border border-[#D6CCC0] text-sm focus:outline-none focus:border-[#8B3E22] bg-white text-center">
                    <option value="">hh</option>
                    ${Array.from({length:24},(_,i)=>`<option value="${String(i).padStart(2,'0')}" ${reschedTime.slice(0,2)===String(i).padStart(2,'0')?'selected':''}>${String(i).padStart(2,'0')}</option>`).join('')}
                  </select>
                  <span class="font-bold text-[#2C2416]">:</span>
                  <select id="reschedule-min-${a.id}" class="flex-1 px-2 py-2 rounded-xl border border-[#D6CCC0] text-sm focus:outline-none focus:border-[#8B3E22] bg-white text-center">
                    <option value="">mm</option>
                    ${Array.from({length:60},(_,i)=>`<option value="${String(i).padStart(2,'0')}" ${reschedTime.slice(3,5)===String(i).padStart(2,'0')?'selected':''}>${String(i).padStart(2,'0')}</option>`).join('')}
                  </select>
                </div>
              </div>
              <div class="flex gap-2 pt-1">
                <button onclick="saveReschedule('${a.id}')" class="flex-1 py-2 bg-[#8B3E22] text-white rounded-xl text-xs font-medium hover:bg-[#6B2E1A] transition-colors">Enregistrer</button>
                <button onclick="document.getElementById('reschedule-${a.id}').classList.add('hidden')" class="px-4 py-2 border border-[#D6CCC0] text-[#2C2416]/60 rounded-xl text-xs hover:bg-[#EDE6DB] transition-colors">Annuler</button>
              </div>
            </div>
          </div>
        </div>`;
      });
      dayNotes.forEach(n => {
        html += `<div class="p-4 rounded-2xl bg-[#EDE6DB] border border-[#D6CCC0]"><p class="text-xs text-[#767A55] uppercase tracking-widest mb-2">Note</p><p class="text-sm text-[#2C2416]/80 italic leading-relaxed">${n.note}</p></div>`;
      });
      if (!html) html = '<p class="text-sm text-[#2C2416]/40 italic">Aucune publication programmée ce jour.</p>';
      document.getElementById('cal-fullday-title').textContent = `${parseInt(d)} ${months[parseInt(m)-1]} ${y}`;
      document.getElementById('cal-fullday-content').innerHTML = html;
      // Flèche "Suivant"
      const nextDate = getNextClientContentDate(dateStr);
      const nextBtn = document.getElementById('cal-next-day-btn');
      if (nextBtn) { nextBtn.classList.toggle('hidden', !nextDate); nextBtn.classList.toggle('inline-flex', !!nextDate); }
      // Sur desktop (md+) : garder le calendrier visible, juste montrer le panneau droit
      const isDesktop = window.matchMedia('(min-width: 768px)').matches;
      if (!isDesktop) {
        document.getElementById('cal-main-view').classList.add('hidden');
        document.getElementById('cal-fullday-view').scrollIntoView({ behavior:'smooth', block:'start' });
      }
      document.getElementById('cal-fullday-view').classList.remove('hidden');
    };

    window.closeClientCalFullDay = () => {
      document.getElementById('cal-fullday-view').classList.add('hidden');
      document.getElementById('cal-main-view').classList.remove('hidden');
    };

    window.saveReschedule = async (contentId) => {
      const sb2 = await getSB();
      const dateVal = document.getElementById('reschedule-date-' + contentId)?.value;
      const h = document.getElementById('reschedule-hour-' + contentId)?.value;
      const m = document.getElementById('reschedule-min-' + contentId)?.value;
      if (!dateVal) { showAdminToast('⚠️ Sélectionne une date'); return; }
      const timeStr = (h && m) ? `${h}:${m}` : '12:00';
      const scheduledAt = `${dateVal}T${timeStr}:00`;
      const { error } = await sb2.from('content_items').update({ scheduled_at: scheduledAt }).eq('id', contentId);
      if (!error) {
        showAdminToast('✅ Date de publication mise à jour');
        document.getElementById('reschedule-' + contentId)?.classList.add('hidden');
        await loadClientCal();
        window.clientCalDayDetail(dateVal);
      } else {
        showAdminToast('❌ Erreur lors de la mise à jour');
      }
    };

    window.saveClientCalNote = async () => {
      const sb2 = await getSB();
      const note = document.getElementById('client-cal-input').value.trim();
      const date = document.getElementById('client-cal-date-picker').value || clientCalSel;
      if (!note || !date) return;
      const existing = _clientCalData.notes.find(n => n.date === date);
      if (existing) {
        await sb2.from('calendar_notes').update({ note }).eq('id', existing.id);
      } else {
        await sb2.from('calendar_notes').insert({ date, note, client_id: _clientCalClientId, created_by: session.user.id });
      }
      document.getElementById('client-cal-note-modal').classList.add('hidden');
      await loadClientCal();
    };

    // Stocker le clientId courant pour le calendrier et les tâches
    const _origOpenClient = window.openClient;
    window.openClient = async (clientId) => {
      _clientCalClientId = clientId;
      window._currentAdminClientId = clientId;
      clientCalYear  = new Date().getFullYear();
      clientCalMonth = new Date().getMonth();
      _adminTasksClientId = clientId;
      await _origOpenClient(clientId);
      _currentClientName = document.querySelector('#view-client h2')?.textContent?.trim() || '';
      // Afficher la bulle discussion
      const widget = document.getElementById('admin-discussion-widget');
      if (widget) widget.classList.remove('hidden');
      const titleEl = document.getElementById('admin-discussion-title');
      if (titleEl) titleEl.textContent = 'Discussion — ' + (_currentClientName.split(' ')[0] || 'Client');
      // Charger tout dès l'ouverture
      await loadClientCal();
      await loadAdminTasks(clientId);
      await window.loadAdminClientNotes(clientId);
      // Handler Enter sur la zone de réponse
      const replyInput = document.getElementById('admin-reply-input');
      if (replyInput) {
        replyInput.onkeydown = (e) => {
          if (e.key === 'Enter' && !e.shiftKey && !_isMobileDevice()) {
            e.preventDefault();
            window.sendAdminNote(clientId);
          }
        };
      }
    };

    // Realtime — tâches : mise à jour auto quand le client coche/ajoute une tâche
    sb.channel('admin-tasks-sync')
      .on('postgres_changes', { event: '*', schema: 'public', table: 'tasks' }, (payload) => {
        const cid = payload.new?.client_id || payload.old?.client_id;
        if (cid && cid === _adminTasksClientId) loadAdminTasks(_adminTasksClientId);
      })
      .subscribe();

    // Realtime — messages client : nouvelle note visible immédiatement
    sb.channel('admin-client-notes-sync')
      .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'client_notes' }, (payload) => {
        if (payload.new?.client_id === window._currentAdminClientId)
          window.loadAdminClientNotes(window._currentAdminClientId);
        // Notif dans la cloche si message du client (pas de l'admin)
        if (!payload.new?.from_admin) {
          loadAdminNotifs();
          showAdminToast('💬 Nouveau message d\'un client');
        }
      })
      .subscribe();

    // Mise à jour automatique du calendrier quand un client valide un contenu
    sb.channel('admin-content-approved')
      .on('postgres_changes', { event: 'UPDATE', schema: 'public', table: 'content_items' }, async (payload) => {
        if (payload.new?.status === 'approved' && payload.new?.client_id === _clientCalClientId) {
          await loadClientCal();
        }
      })
      .subscribe();

    // ─── Tâches admin ──────────────────────────────────────────────────────────
    window.loadAdminTasks = async (clientId) => {
      if (!clientId) return;
      _adminTasksClientId = clientId;
      const sb2 = await getSB();
      const { data } = await sb2.from('tasks').select('*').eq('client_id', clientId).order('created_at', { ascending: true });
      const el = document.getElementById('admin-tasks-list');
      if (!el) return;
      if (!data || !data.length) { el.innerHTML = '<p class="text-xs text-[#2C2416]/30 italic">Aucune tâche</p>'; return; }
      el.innerHTML = data.map(t => {
        const title = (t.title||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        return `<div class="flex items-center gap-2 p-2 rounded-xl hover:bg-[#F5EDE4] transition-colors group" data-search="${(t.title||'').toLowerCase()}">
          <button onclick="adminToggleTask('${t.id}',${t.done},'${clientId}')" class="w-5 h-5 rounded-full border-2 flex items-center justify-center shrink-0 transition-colors ${t.done ? 'bg-[#8B3E22] border-[#8B3E22]' : 'border-[#D6CCC0] hover:border-[#8B3E22]'}">
            ${t.done ? '<iconify-icon icon="solar:check-linear" stroke-width="2.5" class="text-white" style="font-size:9px"></iconify-icon>' : ''}
          </button>
          <span class="text-sm flex-1 ${t.done ? 'line-through text-[#2C2416]/40' : 'text-[#2C2416]'}">${title}</span>
          <button onclick="adminDeleteTask('${t.id}','${clientId}')" class="opacity-0 group-hover:opacity-100 text-[#D6CCC0] hover:text-red-400 transition-all shrink-0">
            <iconify-icon icon="solar:close-circle-linear" stroke-width="1.5" class="text-base"></iconify-icon>
          </button>
        </div>`;
      }).join('');
    };
    window.addAdminTask = async () => {
      const cid = _adminTasksClientId;
      if (!cid) return;
      const sb2 = await getSB();
      const input = document.getElementById('admin-task-input');
      const title = input?.value.trim();
      if (!title) return;
      const { error } = await sb2.from('tasks').insert({ client_id: cid, title });
      if (!error) {
        input.value = '';
        input.focus();
        await window.loadAdminTasks(cid);
      }
    };
    window.adminToggleTask = async (id, done, clientId) => {
      const sb2 = await getSB();
      await sb2.from('tasks').update({ done: !done }).eq('id', id);
      await window.loadAdminTasks(clientId);
    };
    window.adminDeleteTask = async (id, clientId) => {
      const sb2 = await getSB();
      await sb2.from('tasks').delete().eq('id', id);
      await window.loadAdminTasks(clientId);
    };

    // ─── Fil discussion client ↔ admin ───────────────────────────────────────
    window.loadAdminClientNotes = async (clientId) => {
      if (!clientId) return;
      const sb2 = await getSB();
      const { data } = await sb2.from('client_notes').select('*').eq('client_id', clientId).order('created_at', { ascending: true }).limit(100);
      const feed = document.getElementById('admin-client-notes-feed');
      if (!feed) return;
      if (!data || !data.length) {
        feed.innerHTML = '<p class="text-sm text-[#F5EDE4]/40 italic">Aucun message pour l\'instant.</p>';
        return;
      }
      const clientFirstName = (_currentClientName || 'Client')[0]?.toUpperCase() || '?';
      feed.innerHTML = data.map(n => {
        const d   = new Date(n.created_at).toLocaleDateString('fr-FR', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' });
        const txt = n.note.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
        if (n.from_admin) {
          return `<div style="display:flex;justify-content:flex-end;align-items:flex-end;gap:8px;padding-left:40px;margin-bottom:8px">
            <div style="background:#8B3E22;border-radius:18px 18px 4px 18px;padding:10px 16px;max-width:78%">
              <p style="font-size:14px;color:#fff;line-height:1.5;margin:0">${txt}</p>
              <p style="font-size:10px;color:rgba(255,255,255,0.5);margin:6px 0 0;text-align:right">${d}</p>
            </div>
            <div style="width:28px;height:28px;background:#8B3E22;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-size:11px;font-weight:700;flex-shrink:0">C</div>
          </div>`;
        }
        return `<div style="display:flex;align-items:flex-end;gap:8px;padding-right:40px;margin-bottom:8px">
          <div style="width:28px;height:28px;background:rgba(255,255,255,0.2);border-radius:50%;display:flex;align-items:center;justify-content:center;color:#F5EDE4;font-size:11px;font-weight:700;flex-shrink:0">${clientFirstName}</div>
          <div style="background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.1);border-radius:18px 18px 18px 4px;padding:10px 16px;max-width:78%">
            <p style="font-size:14px;color:#F5EDE4;line-height:1.5;margin:0">${txt}</p>
            <p style="font-size:10px;color:rgba(245,237,228,0.4);margin:6px 0 0">${d}</p>
          </div>
        </div>`;
      }).join('');
      feed.scrollTop = feed.scrollHeight;

      // Badge sur la bulle si panel fermé et messages non lus du client
      const panel = document.getElementById('admin-discussion-panel');
      if (panel && panel.classList.contains('hidden')) {
        const lastSeen = localStorage.getItem('adminDiscussionSeen_' + clientId) || '1970-01-01';
        const unread = (data||[]).filter(n => !n.from_admin && n.created_at > lastSeen).length;
        const badge = document.getElementById('admin-discussion-badge');
        if (badge) { badge.classList.toggle('hidden', unread === 0); badge.textContent = unread > 9 ? '9+' : String(unread); }
      }
    };

    window.sendAdminNote = async (clientId) => {
      if (!clientId) return;
      const sb2 = await getSB();
      const ta = document.getElementById('admin-reply-input');
      const note = ta?.value.trim();
      if (!note) return;

      // Tentative avec from_admin:true, fallback sans si la colonne n'existe pas encore
      let { error } = await sb2.from('client_notes').insert({ client_id: clientId, note, from_admin: true });
      if (error && error.message?.includes('from_admin')) {
        const res = await sb2.from('client_notes').insert({ client_id: clientId, note });
        error = res.error;
      }

      if (!error) {
        ta.value = '';
        await window.loadAdminClientNotes(clientId);
        showAdminToast('✅ Note envoyée au client');
        // Notification email message
        fetch('/api/send-notification', {
          method:'POST', headers:{'Content-Type':'application/json'},
          body: JSON.stringify({ clientId, type:'message', data:{ preview: note.slice(0,200) } }),
        }).catch(()=>{});
      } else {
        showAdminToast('❌ Erreur : ' + (error.message || 'impossible d\'envoyer'));
      }
    };

  });

