      msg.textContent = isColMissing
        ? '⚠️ Colonne manquante en DB — exécute le SQL dans Supabase'
        : error ? `Erreur : ${error.message || 'inconnue'}`
        : `${toSave.slots.length} créneau(x) enregistré(s) ✓`;
      msg.classList.remove('hidden');
      setTimeout(() => msg.classList.add('hidden'), 5000);
    }
    if (!error) { renderPrefSlotsList(); renderPrefChips(); }
  };

