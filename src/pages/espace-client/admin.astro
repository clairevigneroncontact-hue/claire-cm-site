      try { await _openClientInner(clientId); } catch(err) {
        console.error('openClient error:', err);
        document.getElementById('client-detail').innerHTML = `<div class="bg-red-50 rounded-2xl p-6 border border-red-200"><p class="text-sm font-medium text-red-700 mb-1">Erreur lors du chargement</p><p class="text-xs text-red-600 font-mono">${String(err?.message||err)}</p></div>`;
      }
    };

    // Retour OAuth Instagram
    (async () => {
      const _igP = new URLSearchParams(window.location.search);
      if (_igP.get('ig_connected') === '1') {
