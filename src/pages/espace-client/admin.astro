    const allBtns = ED.map(([e, k]) =>
      `<button type="button" data-e="${e}" data-k="${k}" onclick="window._pickEmoji('${e.replace(/'/g,'&#39;')}')" class="text-xl p-1 rounded-lg hover:bg-[#EDE6DB] transition-colors leading-none" title="${k.split(' ')[0]}">${e}</button>`
    ).join('');

    const picker = document.createElement('div');
    picker.id = 'emoji-picker';
    picker.className = 'hidden fixed z-[300] bg-white rounded-2xl shadow-2xl border border-[#D6CCC0] overflow-hidden';
    picker.style.cssText = 'width:296px';
    picker.innerHTML =
      `<div class="px-2 pt-2 pb-1 border-b border-[#EDE6DB]">
        <input id="emoji-search" type="text" placeholder="🔍 Rechercher un emoji…"
          oninput="window._filterEmojis(this.value)"
          class="w-full px-3 py-1.5 text-xs rounded-xl border border-[#D6CCC0] focus:outline-none focus:border-[#8B3E22] bg-[#F5EDE4]/50" />
      </div>
      <div id="emoji-grid" class="grid grid-cols-9 gap-0.5 max-h-52 overflow-y-auto p-1.5">${allBtns}</div>
      <p id="emoji-empty" class="hidden text-xs text-[#2C2416]/30 italic text-center py-4">Aucun résultat</p>`;
    document.body.appendChild(picker);

    let _emojiTargetId = null;

    window._filterEmojis = (q) => {
      const term = q.toLowerCase().trim();
      let count = 0;
      document.querySelectorAll('#emoji-grid button[data-e]').forEach(btn => {
        const show = !term || btn.dataset.k.includes(term) || btn.dataset.e.includes(term);
        btn.style.display = show ? '' : 'none';
        if (show) count++;
      });
      const empty = document.getElementById('emoji-empty');
      if (empty) empty.classList.toggle('hidden', count > 0);
    };

    window.toggleEmojiPicker = (btn, targetId) => {
      const p = document.getElementById('emoji-picker');
      if (!p) return;
      if (!p.classList.contains('hidden') && _emojiTargetId === targetId) { p.classList.add('hidden'); return; }
      _emojiTargetId = targetId;
      const rect = btn.getBoundingClientRect();
      const top  = Math.min(rect.bottom + 6, window.innerHeight - 280);
      const left = Math.max(8, Math.min(rect.left - 120, window.innerWidth - 306));
      p.style.top = top + 'px'; p.style.left = left + 'px';
      p.classList.remove('hidden');
      const search = document.getElementById('emoji-search');
      if (search) { search.value = ''; window._filterEmojis(''); search.focus(); }
    };

    window._pickEmoji = (emoji) => {
      const ta = _emojiTargetId ? document.getElementById(_emojiTargetId) : null;
      if (ta) {
        const s = ta.selectionStart ?? ta.value.length, e = ta.selectionEnd ?? ta.value.length;
        ta.value = ta.value.slice(0, s) + emoji + ta.value.slice(e);
        ta.selectionStart = ta.selectionEnd = s + emoji.length;
        ta.focus();
      }
      document.getElementById('emoji-picker')?.classList.add('hidden');
    };

    document.addEventListener('click', ev => {
      if (!ev.target.closest('#emoji-picker') && !ev.target.closest('[data-emoji-btn]'))
        document.getElementById('emoji-picker')?.classList.add('hidden');
    });
  })();
