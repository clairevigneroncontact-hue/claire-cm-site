---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const calendarLink = 'https://calendar.app.google/3MNsKo33KBsLdFB18';
---

<BaseLayout
  title="Contact — Claire Vigneron · Community Manager"
  description="Parlons de votre projet Instagram. Contactez Claire Vigneron, Community Manager pour artisans et indépendants."
>
  <Nav />

  <!-- Hero -->
  <section class="pt-32 pb-12 px-6 bg-[#F5EDE4]">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-5xl md:text-6xl text-[#2C2416] tracking-tight mb-3">Contact</h1>
      <p class="text-2xl font-serif italic text-[#8B3E22]">Parlons de votre projet</p>
    </div>
  </section>

  <!-- Bloc principal terracotta -->
  <section class="px-6 bg-[#F5EDE4]">
    <div class="max-w-4xl mx-auto">
      <div class="bg-[#8B6B4A] rounded-2xl px-10 py-12 md:px-14 md:py-16">
        <p class="text-[#F5EDE4] text-lg md:text-xl font-light leading-relaxed mb-2">
          Vous souhaitez développer votre présence sur Instagram ou structurer votre communication ?
        </p>
        <p class="text-[#F5EDE4] text-lg md:text-xl font-light leading-relaxed mb-6">
          Je vous invite à me contacter pour échanger sur votre activité, vos objectifs et voir comment je peux vous accompagner.
        </p>
        <p class="text-[#F5EDE4]/70 font-light mb-10">
          Je vous répondrai dans les plus brefs délais.
        </p>
        <a
          href={calendarLink}
          target="_blank"
          rel="noopener"
          class="inline-block px-8 py-3 border-2 border-[#F5EDE4] text-[#F5EDE4] rounded-full font-medium hover:bg-[#F5EDE4] hover:text-[#2C2416] transition-colors duration-300"
        >
          Réserver un appel
        </a>
      </div>
    </div>
  </section>

  <!-- Coordonnées -->
  <section class="py-16 px-6 bg-[#F5EDE4]">
    <div class="max-w-4xl mx-auto flex flex-col sm:flex-row gap-8 items-start">
      <a href="tel:0678301358" class="flex items-center gap-4 text-[#2C2416]/80 hover:text-[#8B3E22] transition-colors group">
        <div class="w-10 h-10 rounded-full bg-[#8B3E22]/10 flex items-center justify-center group-hover:bg-[#8B3E22]/20 transition-colors">
          <iconify-icon icon="solar:phone-linear" stroke-width="1.5" class="text-xl text-[#8B3E22]"></iconify-icon>
        </div>
        <span class="text-lg font-light">06 78 30 13 58</span>
      </a>
      <a href="mailto:clairevigneron.contact@gmail.com" class="flex items-center gap-4 text-[#2C2416]/80 hover:text-[#8B3E22] transition-colors group">
        <div class="w-10 h-10 rounded-full bg-[#8B3E22]/10 flex items-center justify-center group-hover:bg-[#8B3E22]/20 transition-colors">
          <iconify-icon icon="solar:letter-linear" stroke-width="1.5" class="text-xl text-[#8B3E22]"></iconify-icon>
        </div>
        <span class="text-lg font-light">clairevigneron.contact@gmail.com</span>
      </a>
    </div>
  </section>

  <Footer />
</BaseLayout>
