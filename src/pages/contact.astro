---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import BackArrow from '../components/BackArrow.astro';

const calendarLink = 'https://cal.com/claire-vigneron-k5okcq/30min?user=claire-vigneron-k5okcq&overlayCalendar=true';

const faq = [
  {
    q: 'Est-ce qu\'on se parle avant de commencer ?',
    r: 'Toujours. Chaque collaboration commence par un appel découverte gratuit de 30 minutes. C\'est l\'occasion de comprendre votre activité, vos besoins et de voir si on est bien alignées.',
  },
  {
    q: 'Dans combien de temps pouvez-vous démarrer ?',
    r: 'En général sous 1 à 2 semaines après la validation du devis. Cela dépend de mes disponibilités du moment — n\'hésitez pas à me contacter pour connaître mes créneaux.',
  },
  {
    q: 'Travaillez-vous avec tous les secteurs ?',
    r: 'Je travaille principalement avec des artisans, indépendants et petites entreprises qui ont une activité établie et une offre claire. Si vous avez un doute, l\'appel découverte est fait pour ça.',
  },
  {
    q: 'Comment se déroule la collaboration au quotidien ?',
    r: 'Vous recevez les contenus à valider chaque semaine, par message ou email selon votre préférence. Tout est transparent et prévisible — pas de surprise.',
  },
];
---

<BaseLayout
  title="Contact — Claire Vigneron · Community Manager"
  description="Parlons de votre projet Instagram. Contactez Claire Vigneron, Community Manager pour artisans et indépendants."
>
  <Nav />

  <!-- Hero -->
  <section class="pt-24 md:pt-28 pb-16 px-6 bg-[#F5EDE4]">
    <div class="max-w-5xl mx-auto">
      <BackArrow />
      <span class="text-xs font-medium uppercase tracking-widest text-[#767A55] mb-4 block">Travaillons ensemble</span>
      <div class="inline-block">
        <h1 class="text-4xl md:text-6xl text-[#2C2416] tracking-tight mb-4 leading-tight">
          Parlons de<br /><span class="italic font-light text-[#8B3E22]">votre projet</span>
        </h1>
      </div>
      <p class="text-xl text-[#2C2416]/60 font-light max-w-xl mt-4">
        La première étape est simple : un appel de 30 minutes, gratuit, sans engagement — pour voir si on est faites pour travailler ensemble.
      </p>
    </div>
  </section>

  <!-- Contenu principal -->
  <section class="py-16 px-6 bg-[#F5EDE4]">
    <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12">

      <!-- Gauche : appel + coordonnées -->
      <div class="space-y-8">

        <!-- Bloc appel principal -->
        <div class="bg-[#2C2416] rounded-2xl p-8 md:p-10">
          <span class="text-xs uppercase tracking-widest text-[#767A55] block mb-6">Étape 1 — La plus simple</span>
          <h2 class="text-3xl text-[#F5EDE4] tracking-tight mb-4 leading-tight">
            Réservez un appel découverte gratuit
          </h2>
          <p class="text-[#F5EDE4]/60 font-light leading-relaxed mb-8">
            30 minutes pour vous présenter votre activité, vos objectifs et vos questions. Je vous donne mon analyse et on voit ensemble quelle offre correspond à votre situation.
          </p>
          <div class="space-y-3 mb-8">
            {['Gratuit et sans engagement', 'En visio ou par téléphone', 'Réponse sous 24h'].map(item => (
              <div class="flex items-center gap-3 text-[#F5EDE4]/70 text-sm">
                <iconify-icon icon="solar:check-circle-linear" stroke-width="1.5" class="text-[#8B3E22] text-base shrink-0"></iconify-icon>
                {item}
              </div>
            ))}
          </div>
          <a
            href={calendarLink}
            target="_blank"
            rel="noopener"
            class="block w-full py-4 bg-[#8B3E22] text-[#F5EDE4] rounded-xl text-center font-medium hover:bg-[#6B2E1A] transition-colors"
          >
            Choisir un créneau →
          </a>
        </div>

        <!-- Coordonnées -->
        <div class="bg-[#EDE6DB] rounded-2xl p-8">
          <p class="text-xs uppercase tracking-widest text-[#767A55] mb-6">Ou contactez-moi directement</p>
          <div class="space-y-4">
            <a href="tel:0678301358" class="flex items-center gap-4 text-[#2C2416]/80 hover:text-[#8B3E22] transition-colors group">
              <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center shadow-sm group-hover:bg-[#8B3E22]/10 transition-colors">
                <iconify-icon icon="solar:phone-linear" stroke-width="1.5" class="text-xl text-[#8B3E22]"></iconify-icon>
              </div>
              <div>
                <p class="text-xs text-[#767A55] mb-0.5">Téléphone</p>
                <p class="font-medium">06 78 30 13 58</p>
              </div>
            </a>
            <a href="mailto:clairevigneron.contact@gmail.com" class="flex items-center gap-4 text-[#2C2416]/80 hover:text-[#8B3E22] transition-colors group">
              <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center shadow-sm group-hover:bg-[#8B3E22]/10 transition-colors">
                <iconify-icon icon="solar:letter-linear" stroke-width="1.5" class="text-xl text-[#8B3E22]"></iconify-icon>
              </div>
              <div>
                <p class="text-xs text-[#767A55] mb-0.5">Email</p>
                <p class="font-medium text-sm">clairevigneron.contact@gmail.com</p>
              </div>
            </a>
          </div>
        </div>
      </div>

      <!-- Droite : FAQ -->
      <div>
        <p class="text-xs uppercase tracking-widest text-[#767A55] mb-8">Questions fréquentes</p>
        <div class="space-y-0">
          {faq.map((item, i) => (
            <div class={`py-6 ${i < faq.length - 1 ? 'border-b border-[#D6CCC0]' : ''}`}>
              <h3 class="text-lg text-[#2C2416] font-medium mb-3 leading-snug">{item.q}</h3>
              <p class="text-[#2C2416]/65 font-light leading-relaxed">{item.r}</p>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
