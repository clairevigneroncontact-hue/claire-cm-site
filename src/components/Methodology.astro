---
interface Props {
  imageUrl?: string;
  imageAlt?: string;
}

const {
  imageUrl = 'https://images.unsplash.com/photo-1499951360447-b19be8fe80f5?q=80&w=2070&auto=format&fit=crop',
  imageAlt = 'Editorial Desk',
} = Astro.props;
---

<section id="process" class="py-20 px-6 md:px-12 bg-[#1C1C1C] text-[#F5F3EF] rounded-t-[3rem]">
  <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

    <!-- Image -->
    <div class="relative">
      <div class="absolute inset-0 bg-stone-700 rounded-2xl rotate-3 opacity-30"></div>
      <img
        src={imageUrl}
        alt={imageAlt}
        class="relative rounded-2xl shadow-2xl grayscale-[50%] hover:grayscale-0 transition-all duration-700 w-full object-cover h-[600px]"
      />
    </div>

    <!-- Text -->
    <div class="space-y-8">
      <span class="text-stone-400 uppercase tracking-widest text-sm font-semibold">The Methodology</span>
      <h3 class="text-5xl md:text-6xl font-serif leading-tight tracking-tight">Strategy before aesthetics.</h3>
      <p class="text-lg md:text-xl text-stone-300 font-light leading-relaxed">
        Every premium engagement moves through our rigorous, transparent framework. We don't believe in commodity creative work; we believe in comprehensive brand transformations designed for long-term equity.
      </p>
      <p class="text-lg text-stone-400 font-light">
        From initial discovery and positioning to creative direction, bespoke design, and ongoing growth support, we ensure your digital presence matches the caliber of your real-world expertise.
      </p>
      <div class="pt-6">
        <a href="#" class="inline-block bg-[#F5F3EF] text-stone-900 px-8 py-4 rounded-full font-medium hover:bg-stone-300 transition-colors text-center">
          View Our Process
        </a>
      </div>
    </div>
  </div>
</section>
