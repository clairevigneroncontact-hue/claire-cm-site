<!-- Bouton scroll-to-top — droite, visible -->
<button
  id="scroll-top"
  class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#2C2416] hover:bg-[#8B3E22] text-white rounded-full hidden items-center justify-center shadow-2xl border-2 border-white/20 transition-all duration-300 hover:scale-110"
  aria-label="Remonter en haut"
>
  <iconify-icon icon="solar:arrow-up-bold" class="text-2xl"></iconify-icon>
</button>

<script>
  const btn = document.getElementById('scroll-top')!;

  window.addEventListener('scroll', () => {
    const pct = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
    const show = pct > 0.65;
    btn.classList.toggle('hidden', !show);
    btn.classList.toggle('flex', show);
  });

  btn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
</script>
