---
interface Props {
  label?: string;
  headline?: string;
  subheadline?: string;
  ctaPrimary?: string;
  ctaSecondary?: string;
  imageUrl?: string;
}

const {
  label = 'Elevate Your Authority',
  headline = 'Personal brands crafted with',
  subheadline = 'A full-service digital agency for high-performing founders, authors, and executives. We build cohesive brand assets, signature websites, and content systems that look as valuable as your expertise.',
  ctaPrimary = 'Book a Brand Audit',
  ctaSecondary = 'Explore Services',
  imageUrl = 'https://images.unsplash.com/photo-1600607688969-a5bfcd646154?q=80&w=2070&auto=format&fit=crop',
} = Astro.props;
---

<header class="relative w-full min-h-[90vh] flex flex-col items-center justify-center text-center px-4 md:px-0 py-20 overflow-hidden">

  <!-- Background glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#EBE8E0] rounded-full blur-3xl -z-10 opacity-60"></div>

  <div class="max-w-5xl mx-auto space-y-8 z-10">

    <span class="inline-block py-1 px-3 border border-stone-300 rounded-full text-xs font-medium uppercase tracking-widest text-stone-500 mb-4 bg-white/30 backdrop-blur-sm">
      {label}
    </span>

    <h1 class="text-6xl md:text-8xl lg:text-9xl text-stone-900 leading-[0.9] tracking-tighter mix-blend-darken">
      {headline}<br />
      <span class="italic font-light text-stone-800">editorial</span> precision.
    </h1>

    <p class="max-w-xl mx-auto text-lg md:text-xl text-stone-600 font-light leading-relaxed mt-6">
      {subheadline}
    </p>

    <div class="flex flex-col md:flex-row items-center justify-center gap-4 mt-10">
      <button class="group relative px-8 py-4 bg-stone-900 text-[#F5F3EF] rounded-full overflow-hidden transition-all hover:scale-[1.02] duration-300 w-full md:w-auto">
        <span class="relative z-10 flex items-center gap-2 font-medium">
          {ctaPrimary}
          <iconify-icon icon="solar:arrow-right-linear" stroke-width="1.5" class="group-hover:translate-x-1 transition-transform"></iconify-icon>
        </span>
      </button>
      <button class="px-8 py-4 border border-stone-300 text-stone-900 rounded-full hover:bg-stone-200 transition-all duration-300 w-full md:w-auto font-medium">
        {ctaSecondary}
      </button>
    </div>
  </div>

  <!-- Hero image -->
  <div
    class="mt-16 w-full max-w-6xl h-64 md:h-96 bg-cover bg-center rounded-t-3xl md:rounded-3xl opacity-90 grayscale-[20%] sepia-[10%] shadow-2xl shadow-[#D1CEC7]/50"
    style={`background-image: url('${imageUrl}')`}
  ></div>
</header>
