---
interface Props {
  quote?: string;
  audience?: string;
  tagline?: string;
}

const {
  quote = "Our engagements are designed for serious operators who recognize their personal brand is their most valuable <em class=\"italic text-stone-500\">business asset</em>.",
  audience = 'Built for Founders • Executives • Authors • Speakers',
  tagline = 'Transparent process. Editorial standards. Real outcomes.',
} = Astro.props;
---

<section class="py-24 px-6 md:px-12 bg-[#F5F3EF]">
  <div class="max-w-4xl mx-auto text-center">
    <iconify-icon icon="solar:shield-check-linear" stroke-width="1.5" class="text-stone-900 text-5xl inline-block mb-4"></iconify-icon>
    <h4
      class="mt-8 text-3xl md:text-5xl font-serif leading-tight text-stone-900 tracking-tight"
      set:html={`"${quote}"`}
    ></h4>
    <div class="mt-10 pt-8 border-t border-stone-300/60 flex flex-col items-center justify-center space-y-2">
      <p class="text-stone-600 font-medium tracking-wide uppercase text-sm">{audience}</p>
      <p class="text-stone-500 text-sm">{tagline}</p>
    </div>
  </div>
</section>
