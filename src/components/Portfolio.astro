---
const projets = [
  {
    client: 'Bahati Body Sculpt',
    secteur: 'Bien-être · Drainage lymphatique',
    mission: 'Création et lancement du compte Instagram',
    duree: '3 mois',
    image: '/projets/bahati/bahati-02.png',
    href: '/a-propos#bahati',
  },
  {
    client: 'Transakauto',
    secteur: 'Revente automobile · Angers & Tours',
    mission: 'Création et développement du compte Instagram',
    duree: '1 an',
    image: '/projets/transakauto/transak-01.png',
    href: '/a-propos#transakauto',
  },
  {
    client: 'Garage automobile',
    secteur: 'Carrosserie · Mécanique',
    mission: 'Calendrier éditorial et stratégie de contenu',
    duree: '1 mois',
    image: '/projets/garage/garage-01.png',
    href: '/a-propos#garage',
  },
];
---

<section class="py-12 md:py-20 px-6 md:px-12 border-t border-[#D6CCC0] bg-[#EDE6DB]">
  <div class="max-w-7xl mx-auto">

    <div class="flex flex-col md:flex-row justify-between items-end mb-14 gap-6">
      <div>
        <span class="text-xs font-medium uppercase tracking-widest text-[#767A55] mb-3 block">Références clients</span>
        <h3 class="text-4xl md:text-5xl text-[#2C2416] tracking-tight">Projets réalisés</h3>
      </div>
      <a href="/a-propos#projets" class="text-[#2C2416] border-b border-[#2C2416] pb-1 hover:opacity-60 transition-opacity shrink-0">
        Voir le détail →
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {projets.map(projet => (
        <a href={projet.href} class="group block bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300">
          <div class="aspect-[4/5] overflow-hidden bg-[#F5EDE4]">
            <img
              src={projet.image}
              alt={`${projet.client} — réalisation`}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
            />
          </div>
          <div class="p-6">
            <span class="text-xs uppercase tracking-widest text-[#767A55] font-medium block mb-2">{projet.secteur}</span>
            <h4 class="text-xl text-[#2C2416] tracking-tight mb-1">{projet.client}</h4>
            <p class="text-sm text-[#2C2416]/60 font-light mb-4">{projet.mission}</p>
            <div class="flex items-center justify-between">
              <span class="text-xs text-[#8B3E22] font-medium">{projet.duree}</span>
              <span class="text-xs text-[#2C2416]/40 group-hover:text-[#8B3E22] transition-colors">Voir le projet →</span>
            </div>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>
