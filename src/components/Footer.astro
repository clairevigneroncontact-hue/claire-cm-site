---
const exploreLinks = [
  { label: 'Offres', href: '#offres' },
  { label: 'Comment ça marche', href: '#process' },
  { label: 'À propos', href: '#apropos' },
  { label: 'Blog', href: '#' },
];

const serviceLinks = [
  { label: 'Audit Instagram', href: '#offres' },
  { label: 'Pack Contenu', href: '#offres' },
  { label: 'Accompagnement mensuel', href: '#offres' },
  { label: 'Appel découverte', href: '#contact' },
];
---

<footer class="bg-[#2C2416] text-[#F5EDE4] pt-20 pb-10 px-6 md:px-12">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12 border-b border-[#F5EDE4]/10 pb-16">

    <!-- Marque -->
    <div class="md:col-span-1 space-y-6">
      <a href="/" class="text-2xl font-serif tracking-tight">
        Claire Vigneron <span class="text-[#767A55]">·</span> CM
      </a>
      <p class="text-[#F5EDE4]/50 text-sm leading-relaxed">
        Community Manager spécialisée dans la valorisation du savoir-faire des artisans et indépendants.
      </p>
      <div class="flex space-x-4">
        <a href="#" class="w-10 h-10 border border-[#F5EDE4]/20 rounded-full flex items-center justify-center hover:bg-[#F5EDE4] hover:text-[#2C2416] transition-colors" aria-label="Instagram">
          <iconify-icon icon="solar:camera-linear" stroke-width="1.5" class="text-lg"></iconify-icon>
        </a>
        <a href="mailto:clairevigneron.contact@gmail.com" class="w-10 h-10 border border-[#F5EDE4]/20 rounded-full flex items-center justify-center hover:bg-[#F5EDE4] hover:text-[#2C2416] transition-colors" aria-label="Email">
          <iconify-icon icon="solar:letter-linear" stroke-width="1.5" class="text-lg"></iconify-icon>
        </a>
      </div>
    </div>

    <!-- Navigation -->
    <div class="col-span-1">
      <h5 class="font-serif text-xl mb-6 text-[#F5EDE4]/60 tracking-tight">Navigation</h5>
      <ul class="space-y-3 text-sm text-[#F5EDE4]/50">
        {exploreLinks.map(link => (
          <li><a href={link.href} class="hover:text-white transition-colors">{link.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Services -->
    <div class="col-span-1">
      <h5 class="font-serif text-xl mb-6 text-[#F5EDE4]/60 tracking-tight">Offres</h5>
      <ul class="space-y-3 text-sm text-[#F5EDE4]/50">
        {serviceLinks.map(link => (
          <li><a href={link.href} class="hover:text-white transition-colors">{link.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Contact -->
    <div class="col-span-1" id="contact">
      <h5 class="font-serif text-xl mb-6 text-[#F5EDE4]/60 tracking-tight">Contact</h5>
      <p class="text-xs text-[#F5EDE4]/40 mb-6 leading-relaxed">
        Un projet, une question, envie de travailler ensemble ? Commençons par un appel découverte gratuit.
      </p>
      <a
        href="mailto:clairevigneron.contact@gmail.com"
        class="inline-block bg-[#8B3E22] text-[#F5EDE4] px-6 py-3 rounded-lg text-sm font-medium hover:bg-[#6B2E1A] transition-colors text-center w-full"
      >
        Réserver un appel découverte
      </a>
    </div>
  </div>

  <!-- Copyright -->
  <div class="max-w-7xl mx-auto pt-10 flex flex-col md:flex-row justify-between items-center text-xs text-[#F5EDE4]/30">
    <p>© 2025 Claire Vigneron · Community Manager. Tous droits réservés.</p>
    <div class="flex space-x-6 mt-4 md:mt-0">
      <a href="#" class="hover:text-white transition-colors">Mentions légales</a>
      <a href="#" class="hover:text-white transition-colors">Politique de confidentialité</a>
    </div>
  </div>
</footer>
