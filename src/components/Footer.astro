---
const calendarLink = 'https://cal.com/claire-vigneron-k5okcq/30min?user=claire-vigneron-k5okcq&overlayCalendar=true';
const serviceLinks = [
  { label: 'Audit Instagram', href: '/offres#audit' },
  { label: 'Pack Contenu', href: '/offres#pack' },
  { label: 'Accompagnement mensuel', href: '/offres#mensuel' },
];
const legalLinks = [
  { label: 'Mentions légales', href: '/mentions-legales' },
  { label: 'CGV', href: '/cgv' },
  { label: 'CGU', href: '/cgu' },
  { label: 'Confidentialité', href: '/confidentialite' },
  { label: 'Accessibilité', href: '/accessibilite' },
];
---

<footer class="bg-[#2C2416] text-[#F5EDE4] pt-12 md:pt-16 pb-8 px-6 md:px-12">
  <div class="max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-5 gap-8 border-b border-[#F5EDE4]/10 pb-10 md:pb-12">

    <!-- Marque (span 2 colonnes sur mobile) -->
    <div class="col-span-2 md:col-span-1 space-y-4">
      <a href="/" class="text-xl font-serif tracking-tight block">
        Claire Vigneron <span class="text-[#767A55]">·</span> CM
      </a>
      <p class="text-[#F5EDE4]/70 text-sm leading-relaxed">
        Community Manager spécialisée dans la valorisation du savoir-faire des artisans et indépendants.
      </p>
      <div class="flex space-x-3">
        <a href="tel:0678301358" class="w-9 h-9 border border-[#F5EDE4]/20 rounded-full flex items-center justify-center hover:bg-[#F5EDE4] hover:text-[#2C2416] transition-colors" aria-label="Appeler Claire">
          <iconify-icon icon="solar:phone-linear" stroke-width="1.5" class="text-base"></iconify-icon>
        </a>
        <a href="mailto:clairevigneron.contact@gmail.com" class="w-9 h-9 border border-[#F5EDE4]/20 rounded-full flex items-center justify-center hover:bg-[#F5EDE4] hover:text-[#2C2416] transition-colors" aria-label="Email">
          <iconify-icon icon="solar:letter-linear" stroke-width="1.5" class="text-base"></iconify-icon>
        </a>
      </div>
    </div>

    <!-- Offres -->
    <div>
      <h5 class="text-sm font-medium text-[#F5EDE4]/70 mb-4">Offres</h5>
      <ul class="space-y-2.5 text-sm text-[#F5EDE4]/60">
        {serviceLinks.map(link => (
          <li><a href={link.href} class="hover:text-white transition-colors">{link.label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Contact -->
    <div id="contact">
      <h5 class="text-sm font-medium text-[#F5EDE4]/70 mb-4">Contact</h5>
      <p class="text-sm text-[#F5EDE4]/60 mb-4 leading-relaxed">
        Un projet ? Commençons par un appel gratuit de 30 min.
      </p>
      <a
        href={calendarLink}
        target="_blank"
        rel="noopener"
        class="inline-block bg-[#8B3E22] text-[#F5EDE4] px-4 py-2.5 rounded-lg text-sm font-medium hover:bg-[#6B2E1A] transition-colors"
      >
        Réserver un appel
      </a>
    </div>

    <!-- FAQ -->
    <div>
      <h5 class="text-sm font-medium text-[#F5EDE4]/70 mb-4">Support</h5>
      <a href="/faq" class="flex items-center gap-2 text-sm text-[#F5EDE4]/60 hover:text-white transition-colors">
        <iconify-icon icon="solar:question-circle-linear" stroke-width="1.5" class="text-[#8B3E22] text-base shrink-0"></iconify-icon>
        Questions fréquentes
      </a>
    </div>

    <!-- Légal & qualité -->
    <div>
      <h5 class="text-sm font-medium text-[#F5EDE4]/70 mb-4">Légal & qualité</h5>
      <ul class="space-y-2 text-sm text-[#F5EDE4]/60">
        {legalLinks.map(link => (
          <li><a href={link.href} class="hover:text-white transition-colors">{link.label}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Copyright -->
  <div class="max-w-7xl mx-auto pt-6 flex flex-col md:flex-row justify-between items-center gap-3 text-sm text-[#F5EDE4]/50">
    <p>© 2026 Claire Vigneron · Community Manager</p>
    <a href="/espace-client" class="hover:text-white transition-colors">Espace client</a>
  </div>
</footer>
