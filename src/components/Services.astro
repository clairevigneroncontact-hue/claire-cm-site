---
const offers = [
  {
    icon: 'solar:document-text-linear',
    tag: 'Sans engagement',
    title: 'Audit Instagram',
    price: '97 €',
    description: "Je passe votre compte au peigne fin et vous livre un plan d'action concret. Vous savez exactement quoi changer — et pourquoi.",
    features: [
      'Analyse complète du compte',
      'Identification des points bloquants',
      "Plan d'action PDF livré en 5 à 7 jours",
    ],
    cta: "Commander l'audit",
    highlighted: false,
  },
  {
    icon: 'solar:palette-linear',
    tag: 'Sans engagement',
    title: 'Pack Contenu',
    price: '320 €',
    description: '8 posts créés pour vous — visuels + textes — prêts à publier, pensés pour votre activité et votre cible.',
    features: [
      '8 visuels aux couleurs de votre marque',
      '8 textes adaptés à votre savoir-faire',
      'Livré en 7 à 10 jours, clé en main',
    ],
    cta: 'Commander le pack',
    highlighted: false,
  },
  {
    icon: 'solar:refresh-circle-linear',
    tag: '⭐ Le plus populaire',
    title: 'Accompagnement Mensuel',
    price: '550 €/mois',
    description: "Je gère votre Instagram chaque mois : stratégie, contenu, publication. Vous n'avez rien à faire.",
    features: [
      'Audit offert dès le premier mois',
      'Contenu créé et publié chaque semaine',
      'Analyses statistiques chaque mois',
      'Engagement minimum de 3 mois',
    ],
    cta: "Démarrer l'accompagnement",
    highlighted: true,
  },
];
---

<section id="offres" class="py-20 px-6 md:px-12 border-t border-[#D6CCC0]">
  <div class="max-w-7xl mx-auto">

    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
      <div>
        <h3 class="text-4xl md:text-5xl text-[#2C2416] mb-2 tracking-tight">Par où commencer ?</h3>
        <p class="text-[#2C2416]/60">Trois façons de travailler ensemble, selon votre situation.</p>
      </div>
      <a href="#contact" class="text-[#2C2416] border-b border-[#2C2416] pb-1 hover:opacity-60 transition-opacity">
        Réserver un appel découverte →
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {offers.map(offer => (
        <div class={`group p-8 md:p-10 rounded-2xl flex flex-col h-full transition-colors duration-300 ${offer.highlighted ? 'bg-[#2C2416] text-[#F5EDE4]' : 'bg-[#EDE6DB] hover:bg-[#E5DDD3]'}`}>

          <!-- Icône + tag -->
          <div class="flex items-center justify-between mb-8">
            <div class={`w-12 h-12 rounded-full flex items-center justify-center group-hover:scale-110 transition-transform shrink-0 ${offer.highlighted ? 'bg-[#8B3E22] text-[#F5EDE4]' : 'bg-[#2C2416] text-[#F5EDE4]'}`}>
              <iconify-icon icon={offer.icon} stroke-width="1.5" class="text-2xl"></iconify-icon>
            </div>
            <span class={`text-xs font-medium uppercase tracking-wider px-3 py-1 rounded-full ${offer.highlighted ? 'bg-[#8B3E22] text-[#F5EDE4]' : 'bg-[#F5EDE4] text-[#767A55]'}`}>
              {offer.tag}
            </span>
          </div>

          <!-- Titre + prix -->
          <h4 class={`text-2xl mb-1 tracking-tight ${offer.highlighted ? 'text-[#F5EDE4]' : 'text-[#2C2416]'}`}>{offer.title}</h4>
          <p class={`text-3xl font-serif mb-4 ${offer.highlighted ? 'text-[#D6CCC0]' : 'text-[#8B3E22]'}`}>{offer.price}</p>

          <!-- Description -->
          <p class={`mb-8 leading-relaxed flex-grow ${offer.highlighted ? 'text-[#F5EDE4]/80' : 'text-[#2C2416]/70'}`}>{offer.description}</p>

          <!-- Features -->
          <ul class="space-y-3 mb-10">
            {offer.features.map(f => (
              <li class={`flex items-start gap-3 text-sm ${offer.highlighted ? 'text-[#F5EDE4]/80' : 'text-[#2C2416]/80'}`}>
                <iconify-icon icon="solar:check-circle-linear" stroke-width="1.5" class={`text-lg shrink-0 mt-0.5 ${offer.highlighted ? 'text-[#8B3E22]' : 'text-[#767A55]'}`}></iconify-icon>
                {f}
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <a
            href="#contact"
            class={`mt-auto inline-flex items-center justify-center gap-2 px-6 py-3 rounded-full font-medium transition-colors duration-300 ${offer.highlighted ? 'bg-[#8B3E22] text-[#F5EDE4] hover:bg-[#6B2E1A]' : 'bg-[#2C2416] text-[#F5EDE4] hover:bg-[#8B3E22]'}`}
          >
            {offer.cta}
            <iconify-icon icon="solar:arrow-right-up-linear" stroke-width="1.5" class="ml-1"></iconify-icon>
          </a>
        </div>
      ))}
    </div>

    <!-- Appel découverte gratuit -->
    <p class="text-center text-[#2C2416]/60 text-sm mt-10">
      Pas sûre de quel format vous convient ?
      <a href="#contact" class="text-[#8B3E22] font-medium hover:underline">Commencez par un appel découverte gratuit de 30 min.</a>
    </p>
  </div>
</section>
