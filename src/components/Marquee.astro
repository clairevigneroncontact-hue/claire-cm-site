---
const items = [
  'Brand Strategy',
  'Signature Websites',
  'Social Content Systems',
  'Video Production',
  'Paid Creative',
];
// Doubler pour l'effet de boucle infinie
const doubled = [...items, ...items];
---

<section class="border-y border-stone-300 py-4 bg-[#EBE8E0] overflow-hidden">
  <div class="marquee-container w-full whitespace-nowrap overflow-hidden">
    <div class="animate-scroll inline-block">
      {doubled.map(item => (
        <>
          <span class="text-2xl md:text-4xl font-serif italic px-8 text-stone-400">•</span>
          <span class="text-sm md:text-base font-medium tracking-widest uppercase text-stone-800">{item}</span>
        </>
      ))}
    </div>
  </div>
</section>

<style>
  .marquee-container {
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }
  @keyframes scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-scroll {
    animation: scroll 30s linear infinite;
  }
</style>
