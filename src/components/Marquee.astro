---
const items = [
  'Stratégie Instagram',
  'Création de contenu',
  'Audit de compte',
  'Pack contenu',
  'Accompagnement mensuel',
  'Community Management',
  'Valorisation du savoir-faire',
];
const doubled = [...items, ...items];
---

<section class="border-y border-[#D6CCC0] py-4 bg-[#EDE6DB] overflow-hidden">
  <div class="marquee-container w-full whitespace-nowrap overflow-hidden">
    <div class="animate-scroll inline-block">
      {doubled.map(item => (
        <>
          <span class="text-2xl md:text-4xl font-serif italic px-8 text-[#767A55]">•</span>
          <span class="text-sm md:text-base font-medium tracking-widest uppercase text-[#2C2416]">{item}</span>
        </>
      ))}
    </div>
  </div>
</section>

<style>
  .marquee-container {
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
  }
  @keyframes scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-scroll {
    animation: scroll 30s linear infinite;
  }
</style>
