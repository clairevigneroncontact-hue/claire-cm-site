---
---

<section class="bg-[#EDE6DB] py-20 md:py-32 px-6 md:px-12 overflow-hidden relative">

  <!-- Cercles décoratifs fond -->
  <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full bg-[#D6CCC0]/40 -translate-y-1/3 translate-x-1/3 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-[350px] h-[350px] rounded-full bg-[#D6CCC0]/30 translate-y-1/3 -translate-x-1/3 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto relative z-10">

    <!-- Badge + accroche -->
    <div class="text-center mb-16">
      <span class="inline-flex items-center gap-2 bg-[#8B3E22]/10 border border-[#8B3E22]/20 text-[#8B3E22] text-xs font-semibold uppercase tracking-widest px-4 py-2 rounded-full mb-6">
        <iconify-icon icon="solar:star-bold" class="text-[#8B3E22]"></iconify-icon>
        Inclus dans chaque collaboration
      </span>
      <h2 class="text-4xl md:text-6xl font-serif text-[#2C2416] leading-tight mb-6">
        Votre Instagram,<br />
        <span class="italic text-[#8B3E22]">sous vos yeux en permanence.</span>
      </h2>
      <p class="text-xl text-[#2C2416]/50 font-light max-w-2xl mx-auto leading-relaxed">
        Un espace privé, pensé pour vous, mis à jour en temps réel.
      </p>
    </div>

    <!-- Mockup dashboard + features -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-20">

      <!-- Mockup navigateur -->
      <div class="relative">
        <!-- Halo lumineux derrière -->
        <div class="absolute inset-0 bg-[#8B3E22]/20 rounded-3xl blur-3xl scale-95"></div>

        <!-- Fenêtre navigateur -->
        <div class="relative bg-[#1a1610] rounded-2xl border border-[#F5EDE4]/10 overflow-hidden shadow-2xl">
          <!-- Barre navigateur -->
          <div class="flex items-center gap-2 px-4 py-3 bg-[#13100a] border-b border-[#F5EDE4]/5">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-[#F5EDE4]/10"></div>
              <div class="w-3 h-3 rounded-full bg-[#F5EDE4]/10"></div>
              <div class="w-3 h-3 rounded-full bg-[#F5EDE4]/10"></div>
            </div>
            <div class="flex-1 bg-[#F5EDE4]/5 rounded-md px-3 py-1 text-[10px] text-[#F5EDE4]/20 font-mono">
              claire-cm.fr/espace-client
            </div>
          </div>

          <!-- Contenu dashboard simulé -->
          <div class="p-5 space-y-4">
            <!-- Header dashboard -->
            <div class="flex items-center justify-between">
              <div>
                <p class="text-[#F5EDE4]/30 text-xs mb-0.5">Bonjour,</p>
                <p class="text-[#F5EDE4] text-sm font-semibold">Marie Dupont 👋</p>
              </div>
              <div class="flex gap-2">
                <div class="w-7 h-7 rounded-lg bg-[#8B3E22]/30 flex items-center justify-center">
                  <iconify-icon icon="solar:bell-linear" stroke-width="1.5" class="text-[#8B3E22] text-sm"></iconify-icon>
                </div>
              </div>
            </div>

            <!-- Stats row -->
            <div class="grid grid-cols-3 gap-2">
              {[
                { label: 'Abonnés', value: '1 247', trend: '+34', up: true },
                { label: 'Portée', value: '8 420', trend: '+12%', up: true },
                { label: 'Engagement', value: '5,8%', trend: '+0,4%', up: true },
              ].map(s => (
                <div class="bg-[#F5EDE4]/5 rounded-xl p-3">
                  <p class="text-[#F5EDE4] text-base font-bold">{s.value}</p>
                  <p class="text-[#F5EDE4]/30 text-[10px]">{s.label}</p>
                  <p class="text-green-400 text-[10px] mt-1">{s.trend}</p>
                </div>
              ))}
            </div>

            <!-- Contenus à valider -->
            <div class="bg-[#F5EDE4]/5 rounded-xl p-3">
              <div class="flex items-center justify-between mb-2">
                <p class="text-[#F5EDE4]/60 text-xs uppercase tracking-widest">Contenus à valider</p>
                <span class="bg-[#8B3E22] text-white text-[10px] px-2 py-0.5 rounded-full font-semibold">2 nouveaux</span>
              </div>
              {[
                { type: 'REEL', title: 'Présentation atelier — mars', date: 'Lundi 10 mars · 09h00' },
                { type: 'POST', title: 'Coulisses fabrication', date: 'Mercredi 12 mars · 18h00' },
              ].map(c => (
                <div class="flex items-center gap-3 py-2 border-t border-[#F5EDE4]/5">
                  <span class={`text-[9px] font-bold px-1.5 py-0.5 rounded ${c.type === 'REEL' ? 'bg-purple-500/20 text-purple-300' : 'bg-blue-500/20 text-blue-300'}`}>{c.type}</span>
                  <div class="flex-1 min-w-0">
                    <p class="text-[#F5EDE4]/80 text-xs truncate">{c.title}</p>
                    <p class="text-[#F5EDE4]/30 text-[10px]">{c.date}</p>
                  </div>
                  <div class="flex gap-1">
                    <div class="w-6 h-6 rounded-lg bg-green-500/20 flex items-center justify-center">
                      <iconify-icon icon="solar:check-circle-linear" stroke-width="1.5" class="text-green-400 text-xs"></iconify-icon>
                    </div>
                    <div class="w-6 h-6 rounded-lg bg-red-500/10 flex items-center justify-center">
                      <iconify-icon icon="solar:close-circle-linear" stroke-width="1.5" class="text-red-400 text-xs"></iconify-icon>
                    </div>
                  </div>
                </div>
              ))}
            </div>

            <!-- Bilan post -->
            <div class="flex items-center gap-3 bg-[#8B3E22]/15 border border-[#8B3E22]/20 rounded-xl p-3">
              <div class="w-10 h-10 rounded-lg bg-[#8B3E22]/20 flex items-center justify-center shrink-0 text-lg">🏆</div>
              <div>
                <p class="text-[#F5EDE4]/50 text-[10px] uppercase tracking-widest">Meilleur post du mois</p>
                <p class="text-[#F5EDE4] text-xs font-medium">Coulisses atelier poterie</p>
                <p class="text-[#D6CCC0] text-[10px]">❤️ 214 · 💬 38 · ↻ 47 · 🔖 92</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Badge flottant "Temps réel" -->
        <div class="absolute -top-4 -right-4 bg-[#8B3E22] text-white text-xs font-semibold px-3 py-1.5 rounded-full shadow-lg">
          ⚡ Temps réel
        </div>
        <!-- Badge flottant "Votre espace" -->
        <div class="absolute -bottom-4 -left-4 bg-white text-[#2C2416] text-xs font-semibold px-3 py-1.5 rounded-full shadow-lg">
          🔐 Espace 100% privé
        </div>
      </div>

      <!-- Features liste -->
      <div class="space-y-5">
        <p class="text-[#8B3E22] uppercase tracking-widest text-xs font-semibold mb-6">Ce que vous avez dans votre espace</p>

        {[
          {
            icon: 'solar:check-circle-bold',
            title: 'Validation de chaque contenu',
            desc: "Rien n'est publié sans votre accord. Vous validez, refusez ou commentez directement — sans email, sans WhatsApp.",
            badge: null,
          },
          {
            icon: 'solar:chart-2-bold',
            title: 'Statistiques Instagram en direct',
            desc: "Abonnés, portée, taux d'engagement, courbes d'évolution et meilleur post du mois — vos vraies données, pas des estimations.",
            badge: null,
          },
          {
            icon: 'solar:calendar-bold',
            title: 'Calendrier éditorial complet',
            desc: "Le planning du mois en un coup d'œil. Vous savez exactement ce qui sera publié, quand, et dans quel format.",
            badge: null,
          },
          {
            icon: 'solar:chat-round-dots-bold',
            title: 'Messagerie directe',
            desc: "Échangez avec moi directement — sans vous perdre dans vos emails.",
            badge: null,
          },
          {
            icon: 'solar:folder-bold',
            title: 'Tous vos documents',
            desc: "Contrats, devis, comptes-rendus : accessibles et téléchargeables à tout moment.",
            badge: null,
          },
          {
            icon: 'solar:graph-new-up-bold',
            title: 'Bilan mensuel avec objectifs',
            desc: "Chaque mois, un rapport complet avec vos stats, vos objectifs atteints et les nouvelles cibles pour le mois suivant.",
            badge: null,
          },
        ].map(f => (
          <div class="flex gap-4 group">
            <div class="w-10 h-10 rounded-xl bg-[#8B3E22]/15 border border-[#8B3E22]/20 flex items-center justify-center shrink-0 group-hover:bg-[#8B3E22]/25 transition-colors">
              <iconify-icon icon={f.icon} style="color:#8B3E22;font-size:1.2rem"></iconify-icon>
            </div>
            <div>
              <p class="text-[#2C2416] font-medium text-sm mb-1">{f.title}</p>
              <p class="text-[#767A55] text-sm font-light leading-relaxed">{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Citation forte -->
    <div class="border-t border-[#D6CCC0] pt-14 text-center">
      <blockquote class="text-2xl md:text-3xl font-serif italic text-[#2C2416]/70 max-w-3xl mx-auto leading-relaxed mb-8">
        "Vous déléguez votre Instagram — mais vous restez aux commandes."
      </blockquote>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://cal.com/claire-vigneron-k5okcq/30min?user=claire-vigneron-k5okcq&overlayCalendar=true"
          target="_blank" rel="noopener"
          class="inline-flex items-center gap-2 bg-[#2C2416] text-[#F5EDE4] px-8 py-4 rounded-full font-medium hover:bg-[#8B3E22] transition-colors">
          Découvrir les offres →
        </a>
        <a href="/espace-client" class="text-[#2C2416]/40 text-sm hover:text-[#2C2416]/70 transition-colors underline underline-offset-4">
          Déjà client ? Accéder à mon espace
        </a>
      </div>
    </div>

  </div>
</section>
