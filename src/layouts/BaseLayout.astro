---
import '../styles/global.css';
import ChatWidget from '../components/ChatWidget.astro';
import ScrollHelpers from '../components/ScrollHelpers.astro';

interface Props {
  title?: string;
  description?: string;
  hideChatWidget?: boolean;
}

const {
  title = 'Claire Vigneron · Community Manager — Instagram pour artisans',
  description = "Community Manager spécialisée dans la valorisation du savoir-faire des artisans et indépendants. Audit Instagram, pack contenu, accompagnement mensuel.",
  hideChatWidget = false,
} = Astro.props;
---

<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=5" />
    <link rel="shortcut icon" type="image/svg+xml" href="/favicon.svg?v=5" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=5" sizes="32x32" />
    <link rel="apple-touch-icon" sizes="192x192" href="/icon-192.png?v=5" />
    <link rel="apple-touch-icon" sizes="512x512" href="/icon-512.png?v=5" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#2C2416" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Claire CM" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Manrope:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Iconify -->
    <script is:inline src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
  </head>

  <body class="antialiased selection:bg-stone-800 selection:text-white overflow-x-hidden">
    <slot />
    {!hideChatWidget && <ChatWidget />}
    <ScrollHelpers />
    <!-- Spellcheck + autocorrect globaux sur tous les champs texte -->
    <script is:inline>
      function _applySpellcheck(root) {
        (root.querySelectorAll ? root.querySelectorAll('input[type="text"], textarea') : [root])
          .forEach(function(el) {
            if (el.dataset.noSpellcheck) return;
            el.spellcheck = true;
            el.setAttribute('autocorrect', 'on');
            el.setAttribute('autocapitalize', 'sentences');
            el.setAttribute('lang', 'fr');
          });
      }
      document.addEventListener('DOMContentLoaded', function() {
        _applySpellcheck(document);
        new MutationObserver(function(muts) {
          muts.forEach(function(m) {
            m.addedNodes.forEach(function(n) {
              if (n.nodeType !== 1) return;
              if (n.matches && n.matches('input[type="text"], textarea')) {
                if (!n.dataset.noSpellcheck) {
                  n.spellcheck = true;
                  n.setAttribute('autocorrect', 'on');
                  n.setAttribute('autocapitalize', 'sentences');
                  n.setAttribute('lang', 'fr');
                }
              } else if (n.querySelectorAll) {
                _applySpellcheck(n);
              }
            });
          });
        }).observe(document.body, { childList: true, subtree: true });
      });
    </script>
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      }
    </script>
  </body>
</html>
